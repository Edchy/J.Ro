---
import Base from "../layouts/Base.astro";
import DevNav from "../components/DevNav.astro";
import Hero from "../components/Hero.astro";
import ColorGrid from "../components/ColorGrid.astro";
import LoremSection from "../components/LoremSection.astro";
import ImageSection from "../components/ImageSection.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Järna Rosteri — V7">
  <DevNav active="V7" />

  <Hero
    title="Järna Rosteri"
    titleColor="var(--jr-poabs-bry)"
    titleSize="var(--text-display)"
    bg="var(--jr-franchese)"
    gradient="linear-gradient(to right, rgba(58, 175, 156, 0.08) 1px, transparent 1px), linear-gradient(to bottom, rgba(58, 175, 156, 0.08) 1px, transparent 1px), radial-gradient(circle 700px at 30% 50%, rgba(43, 75, 88, 0.6), transparent), radial-gradient(circle 500px at 80% 20%, rgba(58, 175, 156, 0.2), transparent)"
    gradientSize="80px 80px, 80px 80px, 100% 100%, 100% 100%"
  />

  <ImageSection
    image="/assets/images/allbags.png"
    bgSize="contain"
    bg="var(--jr-franchese)"
  />

  <ColorGrid
    colors={[
      "var(--jr-grande)",
      "var(--jr-franchese)",
      "var(--jr-poabs-esp)",
      "var(--jr-poabs-bry)",
      "var(--jr-mezzo)",
      "var(--jr-brun)",
    ]}
    iconColors={[
      "var(--jr-franchese)",
      "var(--jr-grande)",
      "var(--jr-ocra)",
      "var(--jr-mezzo)",
      "var(--jr-poabs-bry)",
      "var(--jr-morkrost)",
    ]}
    columns={3}
    rows={2}
  />

  <ImageSection
    image="/assets/images/view.png"
    bgPosition="center 50%"
    caption="Ekologiskt odlat & KRAV-certifierat. Våra kaffebönor odlas utan kemiska bekämpningsmedel och uppfyller Fairtrade-standarder för rättvis handel."
    captionPosition="bottom-right"
    captionColor="var(--jr-vit)"
  />

  <LoremSection bg="var(--jr-mezzo)" textColor="var(--jr-gold)" />

  <Footer
    bg="var(--jr-franchese)"
    textColor="var(--jr-vit)"
    accentColor="var(--jr-grande)"
  />
</Base>
