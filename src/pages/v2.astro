---
import Base from "../layouts/Base.astro";
import DevNav from "../components/DevNav.astro";
import ColorGrid from "../components/ColorGrid.astro";
import LoremSection from "../components/LoremSection.astro";
import ImageSection from "../components/ImageSection.astro";
import Footer from "../components/FooterV2.astro";
---

<Base title="Järna Rosteri — V2">
  <DevNav active="V2" />

  <!-- HERO V2 — Seal / orbital type -->
  <section class="hero-v2">

    <!-- Flanking vertical text columns -->
    <div class="col col-l1">
      <span>Honduras</span>
      <span>Etiopien</span>
      <span>Colombia</span>
    </div>
    <div class="col col-l2">
      <span>Direkthandel</span>
      <span>Lättrostat</span>
      <span>Mörkrostat</span>
    </div>
    <div class="col col-r1">
      <span>Fairtrade</span>
      <span>Ekologiskt</span>
      <span>KRAV</span>
    </div>
    <div class="col col-r2">
      <span>Est. Järna</span>
      <span>59°N 17°E</span>
      <span>Sverige</span>
    </div>

    <!-- Central seal -->
    <div class="seal-wrap">

      <!-- Orbiting text ring (CSS animation) -->
      <div class="orbit" aria-hidden="true">
        <svg viewBox="0 0 300 300" class="orbit-svg">
          <defs>
            <path
              id="circle-path-v2"
              d="M 150,150 m -120,0 a 120,120 0 1,1 240,0 a 120,120 0 1,1 -240,0"
            />
          </defs>
          <text class="orbit-text">
            <textPath href="#circle-path-v2" startOffset="0%">
              EKOLOGISKT · KRAV-CERTIFIERAT · JÄRNA ROSTERI · SPECIALKAFFE · SVERIGE ·&nbsp;
            </textPath>
          </text>
        </svg>
      </div>

      <!-- Filled circle -->
      <div class="seal-disc">
        <div class="seal-inner">
          <span class="seal-word">JÄRNA</span>
          <div class="seal-rule"></div>
          <span class="seal-word">ROSTERI</span>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="hero-foot">
      <span class="foot-l">Rostat med omsorg</span>
      <span class="foot-r">MMXXVI</span>
    </div>

  </section>

  <ImageSection
    image="/assets/images/coffee-packages.png"
    bgSize="40%"
    bg="var(--jr-ljusgul)"
    caption="Ekologiskt odlat & KRAV-certifierat. Våra kaffebönor odlas utan kemiska bekämpningsmedel och uppfyller Fairtrade-standarder för rättvis handel."
    captionPosition="bottom-left"
    captionColor="var(--jr-morkrost)"
    captionShadow={false}
  />
  <LoremSection bg="var(--jr-vit)" textColor="var(--jr-franchese)" />

  <ImageSection
    image="/assets/images/view.png"
    bgPosition="center 40%"
    caption="Ekologiskt odlat & KRAV-certifierat. Våra kaffebönor odlas utan kemiska bekämpningsmedel och uppfyller Fairtrade-standarder för rättvis handel."
    captionPosition="bottom-right"
  />
  <ImageSection
    image="/assets/images/allbags.png"
    bgSize="contain"
    bg="var(--jr-gron)"
  />
  <Footer />
</Base>

<style>
  .hero-v2 {
    width: 100%;
    height: 100svh;
    min-height: 600px;
    background: var(--jr-gron);
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .col {
    position: absolute;
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 3vh, 2rem);
    animation: fade-in 1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .col span {
    font-family: var(--font);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--jr-ocra);
    opacity: 0.35;
    writing-mode: vertical-rl;
    text-orientation: mixed;
  }

  .col-l1 { left: var(--space-lg); animation-delay: 0.4s; }
  .col-l2 { left: calc(var(--space-lg) + 1.4rem); animation-delay: 0.5s; }
  .col-r1 { right: calc(var(--space-lg) + 1.4rem); animation-delay: 0.5s; }
  .col-r2 { right: var(--space-lg); animation-delay: 0.4s; }

  .seal-wrap {
    position: relative;
    width: clamp(260px, 42vmin, 480px);
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: seal-in 1.2s cubic-bezier(0.16, 1, 0.3, 1) 0.1s both;
  }

  .orbit {
    position: absolute;
    inset: 0;
    animation: spin 28s linear infinite;
  }

  .orbit-svg {
    width: 100%;
    height: 100%;
  }

  .orbit-text {
    font-family: var(--font);
    font-size: 11px;
    fill: var(--jr-ocra);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    opacity: 0.75;
  }

  .seal-disc {
    width: 78%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--jr-ocra);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .seal-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .seal-word {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 3.5vmin, 2.2rem);
    color: var(--jr-gron);
    letter-spacing: 0.04em;
    line-height: 1;
  }

  .seal-rule {
    width: clamp(1.5rem, 4vmin, 2.5rem);
    height: 1px;
    background: var(--jr-gron);
    opacity: 0.4;
  }

  .hero-foot {
    position: absolute;
    bottom: var(--space-lg);
    left: var(--space-lg);
    right: var(--space-lg);
    display: flex;
    justify-content: space-between;
    animation: fade-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.7s both;
  }

  .foot-l,
  .foot-r {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--jr-ocra);
    opacity: 0.3;
  }

  @keyframes seal-in {
    from { opacity: 0; transform: scale(0.88); }
    to   { opacity: 1; transform: scale(1); }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .orbit { animation: none; }
    .seal-wrap, .col, .hero-foot { animation: none; }
  }

  @media (max-width: 600px) {
    .col { display: none; }
  }
</style>
