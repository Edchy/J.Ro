---
import Base from "../layouts/Base.astro";
import DevNav from "../components/DevNav.astro";
import Hero3 from "../components/Hero3.astro";
import Section from "../components/Section.astro";
import LogoMark from "../components/LogoMark.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Järna Rosteri">
  <DevNav active="V11" />

  <!-- ── HERO ─────────────────────────────────────────────── -->
  <Hero3 logoWidth="clamp(14rem, 32vw, 32rem)" />

  <!-- ── ABOUT ──────────────────────────────────────────────── -->
  <Section
    label="Om oss"
    num="01"
    body="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat."
    bg="var(--jr-gron)"
    color="var(--jr-ljusgul)"
    marker="bean"
  />

  <!-- ── LANDSCAPE ─────────────────────────────────────────── -->
  <section class="landscape">
    <div class="landscape-img" style={`background-image: url('${base}/assets/images/view.png')`}></div>
    <div class="landscape-caption">
      <p>
        Ekologiskt odlat &amp; KRAV-certifierat.<br />Våra kaffebönor odlas utan
        kemiska bekämpningsmedel och uppfyller<br />Fairtrade-standarder för
        rättvis handel.
      </p>
    </div>
  </section>

  <!-- ── PHILOSOPHY ─────────────────────────────────────────── -->
  <Section
    label="Filosofi"
    num="02"
    body="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat."
    bg="var(--jr-vit)"
    color="var(--jr-brun)"
    ruleOpacity={0.07}
    marker="bean"
  />

  <!-- ── PRODUCTS ───────────────────────────────────────────── -->
  <Section
    label="Vårt kaffe"
    bg="var(--jr-ocra)"
    color="var(--jr-vit)"
    image="/assets/images/coffee-packages.png"
    imageFit="38%"
    ruleOpacity={0.1}
  />

  <!-- ── FOOTER ─────────────────────────────────────────────── -->
  <footer class="site-footer">
    <div class="footer-mark">
      <LogoMark color="var(--jr-ljusgul)" width="clamp(12rem, 36vw, 36rem)" />
    </div>

    <div class="footer-grid">
      <div class="footer-col footer-col--contact">
        <span class="footer-col-label">Kontakt</span>
        <a href="mailto:info@jarnarosteri.se">info@jarnarosteri.se</a>
        <a href="tel:+46708401365">070-840 13 65</a>
      </div>

      <div class="footer-col footer-col--address">
        <span class="footer-col-label">Adress</span>
        <p>Maskinvägen 5</p>
        <p>153 30 Järna</p>
      </div>

      <div class="footer-col footer-col--social">
        <span class="footer-col-label">Socialt</span>
        <a
          href="https://www.instagram.com/jarnarosteri"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-instagram"
        >
          &#64;jarnarosteri
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© 2026 Järna Rosteri</span>
      <span>Ekologiskt &amp; KRAV-certifierat</span>
    </div>
  </footer>
</Base>

<style>
  /* ── LANDSCAPE ──────────────────────────────────────────── */
  .landscape {
    width: 100%;
    height: 100svh;
    position: relative;
    overflow: hidden;
  }

  .landscape-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center center;
  }

  .landscape-caption {
    position: absolute;
    bottom: var(--space-xl);
    left: var(--space-lg);
    z-index: 2;
    max-width: 400px;
  }

  .landscape-caption::before {
    content: "";
    display: block;
    width: 2rem;
    height: 1px;
    background: var(--jr-vit);
    opacity: 0.6;
    margin-bottom: var(--space-sm);
  }

  .landscape-caption p {
    font-family: var(--font);
    font-size: var(--text-ui);
    line-height: 1.65;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--jr-vit);
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.5);
  }

  /* ── FOOTER ──────────────────────────────────────────────── */
  .site-footer {
    background: var(--jr-svart);
    color: var(--jr-ljusgul);
    padding: 0 var(--space-lg);
    padding-bottom: var(--space-lg);
  }

  .footer-mark {
    padding-top: clamp(4rem, 10vw, 8rem);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid rgba(244, 213, 104, 0.15);
  }

.footer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    border-bottom: 1px solid rgba(244, 213, 104, 0.15);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    padding: var(--space-xl) 0;
    padding-right: var(--space-lg);
  }

  .footer-col + .footer-col {
    border-left: 1px solid rgba(244, 213, 104, 0.15);
    padding-left: var(--space-lg);
    padding-right: 0;
  }

  .footer-col-label {
    font-family: var(--font-display);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--jr-ljusgul);
    opacity: 0.4;
    margin-bottom: var(--space-sm);
  }

  .footer-col a,
  .footer-col p {
    font-family: var(--font);
    font-size: var(--text-ui);
    line-height: 1.7;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--jr-ljusgul);
    text-decoration: none;
  }

  .footer-col a:hover {
    opacity: 0.6;
  }

  .footer-instagram {
    letter-spacing: 0.03em !important;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    padding-top: var(--space-lg);
  }

  .footer-bottom span {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--jr-ljusgul);
    opacity: 0.25;
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }

    .footer-col + .footer-col {
      border-left: none;
      border-top: 1px solid rgba(244, 213, 104, 0.15);
      padding-left: 0;
      padding-top: var(--space-lg);
    }

    .footer-col {
      padding-bottom: var(--space-lg);
    }
  }

  /* ── RESPONSIVE ──────────────────────────────────────────── */
  @media (max-width: 640px) {
    .products-img {
      background-size: 80%;
    }
  }
</style>
