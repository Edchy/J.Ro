    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
  }

  :global(body.is-loaded) .hero-logo-wrap,
  :global(body.is-loaded) .hero-corner--tl,
  :global(body.is-loaded) .hero-corner--bl,
  :global(body.is-loaded) .hamburger,
  [data-reveal].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  :global(body.is-loaded) .hero-corner--tl {
    transition-delay: 0.05s;
