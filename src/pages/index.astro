---
import Base from "../layouts/Base.astro";
import DevNav from "../components/DevNav.astro";
import Hero from "../components/Hero.astro";
import LoremSection from "../components/LoremSection.astro";
import ImageSection from "../components/ImageSection.astro";
import Footer from "../components/Footer.astro";
---

<Base title="Järna Rosteri">
  <DevNav active="IDX" />

  <Hero
    image="/assets/images/hero-no-text.png"
    title="Järna Rosteri"
    titleColor="var(--jr-ocra)"
    titleSize="var(--text-display)"
    bgPosition="center 30%"
  />

  <LoremSection
    bg="var(--jr-gron)"
    textColor="var(--jr-ljusgul)"
    labelColor="var(--jr-ljusgul)"
  />

  <ImageSection
    image="/assets/images/view.png"
    bgPosition="center center"
    caption="Ekologiskt odlat & KRAV-certifierat. Våra kaffebönor odlas utan kemiska bekämpningsmedel och uppfyller Fairtrade-standarder för rättvis handel."
  />
  <LoremSection
    bg="var(--jr-vit)"
    textColor="var(--jr-brun)"
    labelColor="var(--jr-brun)"
  />

  <ImageSection
    image="/assets/images/coffee-packages.png"
    bgSize="40%"
    bg="var(--jr-ocra)"
  />

  <Footer
    bg="var(--jr-ocra)"
    textColor="var(--jr-ljusgul)"
    accentColor="var(--jr-ljusgul)"
  /></Base
>
