            ></path>
            <path
              d="M11480 1329 c-64 -10 -92 -23 -135 -61 -50 -43 -75 -99 -75 -168 0 -107 43 -161 175 -221 39 -17 98 -44 132 -60 35 -15 74 -40 87 -54 59 -63 34 -179 -46 -215 -112 -51 -227 3 -262 121 -7 22 -14 41 -17 42 -15 5 -99 -28 -99 -39 0 -29 41 -121 69 -154 45 -55 122 -92 201 -98 177 -12 300 93 300 258 -1 129 -51 186 -236 265 -148 63 -184 94 -184 159 0 36 6 52 29 78 26 29 35 33 98 36 64 4 72 2 103 -24 18 -16 42 -48 52 -71 10 -24 22 -43 27 -43 4 0 29 7 55 16 40 14 46 19 40 38 -44 143 -166 219 -314 195z"
