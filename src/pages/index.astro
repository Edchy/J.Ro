---
import Base from "../layouts/Base.astro";
import DevNav from "../components/DevNav.astro";
import LogoMark from "../components/LogoMark.astro";
import ImageSection from "../components/ImageSection.astro";
import FooterV5 from "../components/FooterV5.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title="Järna Rosteri">
  <DevNav active="IDX" />

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <span class="hero-corner hero-corner--tl">
        <svg
          class="hero-wordmark"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 1770 190"
          aria-label="Järna Rosteri"
          role="img"
        >
          <g
            transform="translate(0,190) scale(0.1,-0.1)"
