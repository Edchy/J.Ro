        </div>
      </dialog>
      <div class="hero-logo-wrap">
        <LogoMark color="var(--jr-gron)" width="clamp(21rem, 96vw, 1400px)" />
      </div>
      <span class="hero-corner hero-corner--bl" data-hero-scroll-text
        >Ekologiskt <span class="hero-dot">·</span> Biodynamiskt <span
          class="hero-dot">·</span
        > Kaffe</span
      >
    </div>
  </section>
  <!-- ─── PRODUCTS ─────────────────────────────────────────────── -->
  <div class="products-scroller" data-blend-scroller>
    <div class="products-stage" data-blend-stage>
      <p class="section-kicker products-kicker" data-products-kicker data-kicker-reveal>
        våra blandningar
      </p>
      {
        blends.map((blend, index) => (
          <div
            class="blend-strip"
            data-blend-strip
            data-index={index}
            style={`--strip-index: ${index};`}
          >
            <img
              class="blend-strip-image"
              src={`${base}/assets/images/${blend.image}`}
              alt={blend.name}
            />
          </div>
        ))
      }
    </div>
  </div>

  <!-- ─── CONTACT ──────────────────────────────────────────────── -->
  <section id="contact" class="contact-section">
    <div class="contact-section-inner">
      <p class="section-kicker" data-kicker-reveal>Kontakt</p>
      <nav class="contact-items" aria-label="Kontaktvägar">
        <a href="mailto:info@jarnarosteri.se" class="contact-item"
          >info@jarnarosteri.se</a
        >
        <a href="tel:+46708401365" class="contact-item">070-840 13 65</a>
        <!-- <a
          href="https://www.instagram.com/jarnarosteri"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-item"
        >Instagram</a> -->
      </nav>
      <p class="contact-address">Maskinvägen 5 · 153 30 Järna</p>
    </div>
  </section>

  <!-- ─── ABOUT ────────────────────────────────────────────────── -->
  <section
    id="about"
    class="about-section"
    aria-label="Kollage från Järna Rosteri"
  >
    <div class="about-section-inner">
      <div class="about-section-copy">
        <p class="section-kicker" data-kicker-reveal>Om rosteriet</p>
        <p>
          Hos oss handlar kaffe om mer än bara rostning – det är ett hantverk
          grundat i relationer, hållbarhet och passion. Vi samarbetar direkt med
          Demeter-certifierade kaffegårdar, där varje böna odlas i samklang med
          naturen och bär på en berättelse om balans, respekt och mänskliga
          möten. Vårt personliga engagemang genomsyrar hela processen, från
          ursprung till kopp.
        </p>
      </div>
      <div
        class="about-section-image"
        style={`background-image: url('${base}/assets/images/collage.avif')`}
        aria-hidden="true"
      >
      </div>
    </div>
  </section>

  <!-- ─── PACKAGES ─────────────────────────────────────────────── -->
  <!-- <section class="packages-section" data-reveal>
    <div class="packages-section-inner">
      <img
        src={`${base}/assets/images/coffee-packages.png`}
        alt="Kaffepåsar från Järna Rosteri"
        class="packages-section-image"
      />
      <p class="packages-section-caption">
        <span class="section-kicker section-kicker--warm">Aktuell påse</span>
        POAB'S ESP. En av våra espresso sorter. Indisk arabica och robusta.
      </p>
    </div>
  </section> -->

  <!-- ─── IMAGE + CAPTION ──────────────────────────────────────── -->
  <section class="image-block">
    <div
      class="image-block-photo"
      style={`background-image: url('${base}/assets/images/hero-no-text.avif')`}
      aria-hidden="true"
    ></div>
    <p class="section-kicker image-block-top" data-kicker-reveal>Följ oss</p>
    <div class="image-block-bottom">
      <p class="image-block-caption">För mer från våra resor, rosteriet & vardagen</p>
      <a
        href="https://www.instagram.com/jarnarosteri"
        target="_blank"
        rel="noopener noreferrer"
        class="image-block-cta"
      >
        <span class="image-block-cta-label">Instagram</span>
        <span class="image-block-cta-handle">@jarnarosteri</span>
      </a>
    </div>
    <div class="image-block-scrim" aria-hidden="true"></div>
  </section>

  <!-- ─── FOOTER ───────────────────────────────────────────────── -->
  <footer class="index-footer">
    <div class="index-footer-inner">
      <span
        class="index-footer-wordmark"
        style={`--wordmark-mask: url('${base}/assets/images/jarna-rosteri-wordmark.svg')`}
        role="img"
        aria-label="Järna Rosteri"></span>
      <nav class="index-footer-nav">
        <a href="#contact" class="index-footer-link">Kontakt</a>
        <a href="#about" class="index-footer-link">Om oss</a>
      </nav>
      <p class="index-footer-copyright">© Järna Rosteri AB</p>
    </div>
  </footer>

  <style>
    :root {
      --page-inset: var(--space-lg);
      --page-max: 1080px;
      --content-shell-max: 1200px;
      --content-line-start: max(
        var(--page-inset),
        calc((100vw - var(--content-shell-max)) / 2 + var(--page-inset))
      );
      --header-height: 4.5rem;
      --hamburger-size: 2.35rem;
    }

    :global(body) {
      background: var(--jr-vit);
    }

    :global(html.menu-open) {
      overflow-y: scroll;
      scrollbar-gutter: stable;
    }

    :global(body.menu-open) {
      overflow: hidden;
    }

    :global(body.menu-open) {
      position: fixed;
      inset: 0;
      width: 100%;
      touch-action: none;
    }

    /* ── HERO ─────────────────────────────────────────────────────── */
    .hero {
      position: relative;
      min-height: 100svh;
      background-color: var(--jr-vit);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .hero::after {
      content: "";
      position: absolute;
      bottom: 0;
      inset-inline: 0;
      height: 40rem;
      background: linear-gradient(
        to bottom,
        transparent 0%,
        color-mix(in srgb, var(--jr-vit) 10%, transparent) 25%,
        color-mix(in srgb, var(--jr-vit) 35%, transparent) 48%,
        color-mix(in srgb, var(--jr-vit) 68%, transparent) 68%,
        color-mix(in srgb, var(--jr-vit) 88%, transparent) 82%,
        var(--jr-vit) 100%
      );
      pointer-events: none;
      z-index: 2;
    }

    .hero-parallax-bg {
      display: none;
    }

    .hero-inner {
      position: relative;
      z-index: 3;
      width: 100%;
      max-width: var(--content-shell-max);
      height: 100svh;
      margin: 0 auto;
      padding: 2rem;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      padding-bottom: 8svh;
    }

    .hero-corner {
      position: absolute;
      font-family: var(--font-display);
      font-size: var(--text-body);
      text-transform: uppercase;
      letter-spacing: 0.45em;
      color: var(--jr-gron);
      opacity: 0.5;
      line-height: 1;
    }

    .hero-corner--tl {
      top: var(--space-lg);
      left: 2rem;
      pointer-events: none;
    }
    .hero-corner--tr {
      position: fixed;
      z-index: 60;
      top: calc(
        var(--space-lg) -
          ((var(--hamburger-size) - (var(--text-ui) * 1.5)) / 2) -
          (var(--text-ui) * 0.375)
      );
      right: max(2rem, calc(50vw - 600px + 2rem));
    }
    .hero-corner--bl {
      bottom: var(--space-lg);
      left: 2rem;
      padding: 0;
      color: var(--jr-morkrost);
      background: transparent;
      border: none;
      backdrop-filter: none;
    }
    .hero-corner--br {
      bottom: var(--space-lg);
      right: var(--space-lg);
    }

    /* ── HAMBURGER ───────────────────────────────────────────────── */
    .hamburger {
      position: fixed;
      z-index: 60;
      background: transparent;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      border: none;
      border-radius: 50%;
      box-shadow: none;
      cursor: pointer;
      padding: 0;
      width: var(--hamburger-size);
      height: var(--hamburger-size);
      color: var(--jr-gron);
      transition:
        opacity 0.25s ease,
        border-color 0.25s ease,
        box-shadow 0.25s ease;
    }

    :global(body.menu-open) .hamburger {
      background: color-mix(in srgb, var(--jr-vit) 72%, transparent);
      box-shadow: none;
    }

    .hamburger:hover {
      opacity: 0.8;
    }

    .hamburger-bar {
      display: block;
      position: absolute;
      left: 50%;
      top: 50%;
      width: 18px;
      height: 1.5px;
      background: currentColor;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      transform-origin: center;
    }

    .hamburger-bar--top {
      transform: translate(-50%, calc(-50% - 2.5px));
    }
    .hamburger-bar--bot {
      transform: translate(-50%, calc(-50% + 2.5px));
    }

    .hamburger.is-open .hamburger-bar--top {
      transform: translate(-50%, -50%) rotate(45deg);
    }

    .hamburger.is-open .hamburger-bar--bot {
      transform: translate(-50%, -50%) rotate(-45deg);
    }

    .hamburger.is-open {
      opacity: 0.5;
    }

    .hamburger.is-open:hover {
      opacity: 0.8;
    }

    /* ── MENU DIALOG ─────────────────────────────────────────────── */
    .menu-dialog {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      max-width: 100%;
      max-height: 100%;
      margin: 0;
      padding: 0;
      border: none;
      background-color: var(--jr-vit);
      color: var(--jr-gron);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(0.25rem);
      transition:
        opacity 0.08s linear,
        transform 0.12s cubic-bezier(0.2, 0.8, 0.2, 1),
        visibility 0s linear 0.12s;
    }

    .menu-dialog[open] {
      visibility: visible;
    }

    .menu-dialog::backdrop {
      background: transparent;
    }

    .menu-dialog.is-visible {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
      transition:
        opacity 0.08s linear,
        transform 0.1s cubic-bezier(0.2, 0.8, 0.2, 1),
