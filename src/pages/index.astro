            ></path>
            <path
              d="M3140 875 l0 -445 60 0 60 0 0 190 0 191 82 -3 81 -3 111 -197 112 -196 51 31 51 30 -109 179 c-108 178 -109 179 -84 188 37 14 104 79 128 124 31 58 30 174 0 232 -54 102 -118 124 -365 124 l-178 0 0 -445z m378 321 c45 -23 66 -60 66 -115 0 -64 -28 -110 -84 -138 -37 -19 -60 -23 -142 -23 l-98 0 0 143 c0 79 3 147 8 151 13 15 215 0 250 -18z"
