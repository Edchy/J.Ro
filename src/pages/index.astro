---
import Base from "../layouts/Base.astro";
import LogoMark from "../components/LogoMark.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const blends = [
  {
    name: "POAB´S ESP",
    desc: "Demeter-certifierad espresso med indisk arabica och robusta. Fyllig, kryddig och chokladig med låg syra och lång eftersmak.",
    tags: ["Espresso", "Hela bönor", "450 gram"],
    image: "blends/poabs-esp.webp",
    cardBg: "var(--jr-poabs-esp)",
    cardText: "var(--jr-gron)",
    crop: "20% 15%",
  },
  {
    name: "POAB´S BRY",
    desc: "Demeter-certifierat bryggkaffe med indiskt ursprung. Mjukt och balanserat med låg syra, toner av kakao, torkad frukt och kryddor.",
    tags: ["Brygg", "Malda bönor", "450 gram"],
    image: "blends/poabs-bry.webp",
    cardBg: "var(--jr-poabs-bry)",
    cardText: "var(--jr-vit)",
    crop: "80% 10%",
  },
  {
    name: "MEZZO",
    desc: "Vår mest mångsidiga blandning. En mjuk balanserad mellanrost med florala toner från Etiopien, fyllighet och balans från Sydamerika.",
    tags: ["Mellanrost", "Malda bönor", "450 gram"],
    image: "blends/mezzo.webp",
    cardBg: "var(--jr-mezzo)",
    cardText: "var(--jr-vit)",
    crop: "15% 80%",
  },
  {
    name: "FRANCHESE",
    desc: "Vår Franchese är en hyllning till den klassiska franskrosten. Intensiv & kryddig. Mörkrost för dig som gillar ett klassiskt och kraftfullt kaffe.",
    tags: ["Mörkrost", "Malda bönor", "450 gram"],
    image: "blends/franchese.webp",
    cardBg: "var(--jr-franchese)",
    cardText: "var(--jr-vit)",
    crop: "85% 75%",
  },
  {
    name: "GRANDE",
    desc: "Vår klassiska italienska espresso med kraft och balans. Rund, nötig och chokladig i tonen. Perfekt med skummad mjölk eller som en elegant espresso.",
    tags: ["Espresso", "Hela bönor", "450 gram"],
    image: "blends/grande.webp",
    cardBg: "var(--jr-grande)",
    cardText: "var(--jr-vit)",
    crop: "50% 20%",
  },
  {
    name: "18 CONEJO",
    desc: "Uppkallad efter gården i Honduras där kaffet odlas, 1250–1700 möh. Den biodynamiska blandningen av Catuai, Bourbon och Parainema ger fruktiga och florala toner.",
    tags: ["Brygg", "Malda bönor", "450 gram"],
    image: "blends/conejo.webp",
    cardBg: "var(--jr-conejo)",
    cardText: "var(--jr-morkrost)",
    crop: "70% 85%",
  },
];
---

<Base title="Järna Rosteri">
  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="hero hero-v9" data-reveal="hero">
    <header class="hero-meta">
      <span
        class="meta-wordmark"
        style={`--wordmark-mask: url('${base}/assets/images/jarna-rosteri-wordmark.svg')`}
        role="img"
        aria-label="Järna Rosteri"></span>
    </header>

    <button
      class="hamburger hero-corner hero-corner--tr"
      aria-label="Öppna meny"
      aria-expanded="false"
      aria-controls="site-menu"
    >
      <span class="hamburger-bar hamburger-bar--top"></span>
      <span class="hamburger-bar hamburger-bar--bot"></span>
    </button>

    <div class="hero-body">
      <div class="hero-left">
        <div class="wordmark-stack">
          <LogoMark color="var(--jr-gron)" width="clamp(14rem, 30vw, 28rem)" />
          <p class="wordmark-tagline">Kaffekultur, Hantverk &amp; hållbarhet</p>
        </div>
        <div class="hero-rule-horiz"></div>
        <div class="hero-left-grafs">
          <p class="hero-intro-graf">
            Här på Järna Rosteri, strax söder om Stockholm, rostar vi ekologiskt
            kaffe. För hand, varje vecka, sedan 2013.
          </p>
          <p class="hero-intro-graf">
            Det enda biodynamiska rosteriet i Norden. Hundra procent ekologiska
            bönor, direktköpta från kretsloppsgårdar vi litar på. Rostat
            småskaligt så att varje böna kommer till sin rätt.
          </p>
        </div>
      </div>

      <div class="hero-rule-vert"></div>

      <div class="hero-right">
        <p class="hero-intro-graf">
          Hos oss handlar kaffe om mer än bara rostning. Det är ett hantverk
          grundat i relationer, hållbarhet och passion. Det handlar om kaffe i
          balans med människa och natur.
        </p>
        <p class="hero-intro-graf">
          Vi samarbetar direkt med Demeter-certifierade kaffegårdar, där varje
          böna odlas i samklang med naturen och bär på en berättelse om balans,
          respekt och mänskliga möten.
        </p>
        <p class="hero-intro-graf">
          Vårt personliga engagemang genomsyrar hela processen, från ursprung
          till kopp.
        </p>
        <div class="scroll-indicator">
          <div class="scroll-labels">
            <a href="#products" class="scroll-label">Blandningar</a>
            <a href="#about" class="scroll-label">Ursprung</a>
            <a href="#contact" class="scroll-label">Kontakt</a>
          </div>
        </div>
      </div>
    </div>

    <footer class="hero-foot">
      <span class="foot-mark"></span>
      <span
        class="foot-wordmark"
        style={`--wordmark-mask: url('${base}/assets/images/jarna-rosteri-wordmark.svg')`}
        role="img"
        aria-label="Järna Rosteri"></span>
    </footer>
  </section>

  <dialog id="site-menu" class="menu-dialog">
    <button type="button" class="hamburger menu-close" aria-label="Stäng meny">
      <span class="hamburger-bar hamburger-bar--top"></span>
      <span class="hamburger-bar hamburger-bar--bot"></span>
    </button>
    <div class="menu-inner">
      <nav class="menu-nav">
        <a href="#about" class="menu-link">Ursprung</a>
        <a href="#contact" class="menu-link">Kontakt</a>
      </nav>
      <div class="menu-footer">
        <svg
          class="menu-logomark"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="6 0 430 224"
          aria-label="J.Rø"
          role="img"
        >
          <path
            d="M 388.88 201.12 C381.85,203.30 369.00,203.52 362.00,201.57 C342.56,196.15 329.55,179.67 324.29,153.81 C322.13,143.19 321.89,113.86 323.88,103.00 C329.28,73.41 344.92,55.36 368.11,51.94 C382.10,49.88 396.79,54.79 406.91,64.91 C417.91,75.91 424.12,92.46 426.09,116.00 C428.62,146.21 421.84,173.95 408.22,189.10 C402.97,194.94 397.20,198.53 388.88,201.12 ZM 302.14 207.79 C301.60,207.97 297.53,209.87 293.10,212.01 L 285.05 215.90 L 276.96 199.20 C272.52,190.02 261.86,167.99 253.28,150.25 L 237.67 118.00 L 218.02 118.00 L 217.50 200.50 L 198.00 201.07 L 198.00 13.00 L 224.79 13.00 C254.02,13.00 259.43,13.72 268.00,18.74 C273.97,22.24 281.52,30.11 284.41,35.85 C288.68,44.35 290.25,51.75 290.29,63.50 C290.35,87.09 281.64,104.05 264.86,112.99 L 259.12 116.06 L 262.94 124.28 C265.04,128.80 274.95,149.37 284.95,169.98 C294.95,190.59 302.69,207.60 302.14,207.79 ZM 65.50 201.64 C58.01,203.64 45.60,203.31 38.67,200.93 C31.00,198.29 26.51,195.35 20.84,189.28 C11.52,179.28 8.29,169.24 7.35,147.26 L 6.69 132.00 L 27.00 132.00 L 27.02 141.75 C27.06,161.30 29.79,170.78 37.38,177.78 C42.28,182.30 46.96,183.99 54.63,183.99 C69.24,184.01 78.04,173.37 79.99,153.34 C80.52,147.93 80.96,114.14 80.97,78.25 L 81.00 13.00 L 101.13 13.00 L 100.76 87.25 C100.35,169.05 100.58,165.97 93.93,179.13 C88.40,190.09 78.05,198.28 65.50,201.64 ZM 218.00 30.79 L 218.00 100.23 L 234.25 99.82 C252.58,99.34 255.51,98.50 261.36,92.03 C267.26,85.50 269.36,78.34 269.43,64.50 C269.47,57.03 269.01,51.12 268.20,48.83 C265.83,42.15 261.27,37.01 255.18,34.18 C249.95,31.75 248.24,31.51 233.75,31.17 ZM 366.00 72.00 C353.30,72.00 343.00,96.60 343.00,127.00 C343.00,157.40 353.30,182.00 366.00,182.00 L 366.00 72.00 Z M 384.00 72.00 L 384.00 182.00 C396.70,182.00 407.00,157.40 407.00,127.00 C407.00,96.60 396.70,72.00 384.00,72.00 ZM 154.77 183.25 L 154.50 200.50 L 135.00 201.07 L 135.00 166.00 L 155.05 166.00 Z"
            fill="currentColor"></path>
        </svg>
        <p class="menu-address">Kaffekultur, Hantverk & hållbarhet</p>
        <img
          src={`${base}/assets/images/Demeter_RGB.svg`}
          alt="Demeter-certifierat"
          class="menu-demeter"
        />
      </div>
    </div>
  </dialog>
  <!-- ─── PRODUCTS ─────────────────────────────────────────────── -->
  <div id="products" class="products-scroller" data-blend-scroller>
    <div class="products-stage" data-blend-stage>
      <p
        class="section-kicker products-kicker"
        data-products-kicker
        data-kicker-reveal
      >
        våra blandningar
      </p>
      {
        blends.map((blend, index) => (
          <button
            type="button"
            class="blend-strip"
            data-blend-strip
            data-index={index}
            aria-label={`Expandera ${blend.name}`}
            aria-expanded="false"
            style={`--strip-index: ${index}; --card-bg: ${blend.cardBg};`}
          >
            <img
              class="blend-strip-image"
              src={`${base}/assets/images/${blend.image}`}
              alt={blend.name}
              loading="lazy"
              decoding="async"
              style={`--crop: ${blend.crop};`}
            />
          </button>
        ))
      }
    </div>
  </div>

  <!-- ─── CONTACT ──────────────────────────────────────────────── -->
  <section id="contact" class="contact-section">
    <div class="contact-section-inner">
      <p class="section-kicker" data-kicker-reveal>Kontakt</p>
      <nav class="contact-items" aria-label="Kontaktvägar">
        <a href="mailto:info@jarnarosteri.se" class="contact-item"
          >info@jarnarosteri.se</a
        >
        <a href="tel:+46708401365" class="contact-item">070-840 13 65</a>
        <a
          href="https://www.instagram.com/jarnarosteri"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-item">instagram ↗</a
        >
      </nav>
      <p class="contact-address">Maskinvägen 5 · 153 30 Järna</p>
    </div>
  </section>

  <!-- ─── ABOUT ────────────────────────────────────────────────── -->
  <section
    id="about"
    class="about-section"
    aria-label="Kollage från Järna Rosteri"
  >
    <div class="about-section-inner">
      <div class="about-section-copy">
        <p class="section-kicker" data-kicker-reveal>Om rosteriet</p>
        <p>
          Vi startade Järna Rosteri för att det saknades något. Det fanns inget
          biodynamiskt, Demeter-certifierat kaffe i Sverige, och vi ville testa
          om det gick att göra rätt från början.
        </p>
        <p>
          Det biodynamiska handlar inte om tro. Det handlar om cirkularitet och
          balans, ett system där allt hänger ihop. Vi märkte att odlarna som
          jobbade så här brydde sig mer — om marken, om kvaliteten, om
          hållbarheten på lång sikt.
        </p>
        <p>
          Vi köper råkaffe direkt från mindre kretsloppsgårdar där kaffet har
          fått växa långsamt. Varje parti rostas för hand, varje vecka. Allt
          handlar om en bra råvara som vi utvecklar genom rostning — och om att
          göra något vi själva blir glada över.
        </p>
      </div>
      <div
        class="about-section-image"
        style={`background-image: url('${base}/assets/images/collage.avif')`}
        aria-hidden="true"
      >
      </div>
    </div>
  </section>

  <div class="image-footer-stack">
    <!-- ─── IMAGE + CAPTION ──────────────────────────────────────── -->
    <section class="image-block">
      <div
        class="image-block-photo"
        style={`background-image: url('${base}/assets/images/hero-no-text.avif')`}
        aria-hidden="true"
      >
      </div>
      <p class="section-kicker image-block-top" data-kicker-reveal>Följ oss</p>
      <div class="image-block-bottom">
        <p class="image-block-caption">
          För mer från våra resor, rosteriet & vardagen
        </p>
        <a
          href="https://www.instagram.com/jarnarosteri"
          target="_blank"
          rel="noopener noreferrer"
          class="image-block-cta"
        >
          <!-- <span class="image-block-cta-label">se vår</span> -->
          <span class="image-block-cta-handle">instagram ↗</span>
        </a>
      </div>
      <div class="image-block-scrim" aria-hidden="true"></div>
    </section>

    <!-- ─── FOOTER ───────────────────────────────────────────────── -->
    <footer class="index-footer">
      <div class="index-footer-inner">
        <span
          class="index-footer-wordmark"
          style={`--wordmark-mask: url('${base}/assets/images/jarna-rosteri-wordmark.svg')`}
          role="img"
          aria-label="Järna Rosteri"></span>
        <nav class="index-footer-nav">
          <a href="#contact" class="index-footer-link">Kontakt</a>
          <a href="#about" class="index-footer-link">Ursprung</a>
        </nav>
        <p class="index-footer-copyright">© Järna Rosteri AB</p>
      </div>
    </footer>
  </div>

  <style>
    :root {
      --page-inset: var(--space-lg);
      --page-max: 1080px;
      --content-shell-max: 1200px;
      --content-line-start: max(
        var(--page-inset),
        calc((100vw - var(--content-shell-max)) / 2 + var(--page-inset))
      );
      --header-height: 4.5rem;
      --hamburger-size: 2.75rem;
    }

    :global(body) {
      background: var(--jr-vit);
    }

    :global(html.menu-open) {
      overflow: hidden;
    }

    :global(body.menu-open) {
      overflow: hidden;
    }

    :global(body.menu-open) {
      position: fixed;
      inset: 0;
      width: 100%;
      touch-action: none;
    }

    /* ── HERO ─────────────────────────────────────────────────────── */
    .hero-v9 {
      position: relative;
      width: 100%;
      height: 100svh;
      min-height: 600px;
      display: grid;
      grid-template-rows: auto 1fr auto;
      padding: var(--space-lg);
      overflow: clip;
      background-color: var(--jr-vit);
    }

    .hero-meta,
    .hero-body,
    .hero-foot {
      width: min(100%, var(--content-shell-max));
      margin-inline: auto;
    }

    .hero-meta {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      gap: var(--space-sm);
      padding-right: 0;
      animation: fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-delay: 0.1s;
    }

    .meta-wordmark {
      height: clamp(0.75rem, 1.4vw, 1rem);
      aspect-ratio: 1770 / 190;
      width: auto;
      display: block;
      flex: 0 0 auto;
      background: var(--jr-gron);
      -webkit-mask: var(--wordmark-mask) center / contain no-repeat;
      mask: var(--wordmark-mask) center / contain no-repeat;
      opacity: 0.55;
    }

    .hero-body {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      gap: clamp(2rem, 5vw, 5rem);
      padding: clamp(2rem, 5vh, 4rem) 0;
    }

    .hero-left {
      flex: 1 1 auto;
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: clamp(1.5rem, 3vw, 2.5rem);
      animation: fade-up 1s cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-delay: 0.2s;
    }

    .wordmark-stack {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      line-height: 0.88;
    }

    .wordmark-tagline {
      margin: 0;
      font-family: var(--font-display);
      font-size: var(--text-ui);
      line-height: 1.25;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--jr-gron);
      opacity: 0.45;
    }

    .hero-rule-horiz {
      width: 100%;
      height: 1px;
      background: color-mix(in srgb, var(--jr-gron) 25%, transparent);
      margin-top: clamp(1.5rem, 3vh, 2.5rem);
      transform-origin: left center;
      transform: scaleX(0);
      opacity: 0;
      transition:
        transform 1s cubic-bezier(0.16, 1, 0.3, 1) 0.5s,
        opacity 0.6s ease 0.5s;
    }

    :global(body.is-loaded) .hero-rule-horiz {
      transform: scaleX(1);
      opacity: 1;
    }

    .hero-left-grafs {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      padding-top: clamp(1rem, 2vh, 1.75rem);
    }

    .hero-rule-vert {
      width: 1px;
      align-self: stretch;
      background: color-mix(in srgb, var(--jr-gron) 25%, transparent);
      flex-shrink: 0;
      transform-origin: top center;
      transform: scaleY(0);
      opacity: 0;
      transition:
        transform 1.1s cubic-bezier(0.16, 1, 0.3, 1) 0.4s,
        opacity 0.5s ease 0.4s;
    }

    :global(body.is-loaded) .hero-rule-vert {
      transform: scaleY(1);
      opacity: 1;
    }

    .hero-right {
      flex: 0 0 clamp(180px, 25vw, 280px);
      display: flex;
      flex-direction: column;
      gap: clamp(1.5rem, 4vh, 2.5rem);
      animation: fade-up 1s cubic-bezier(0.16, 1, 0.3, 1) both;
      animation-delay: 0.45s;
    }

    .hero-intro-graf {
      margin: 0;
      font-family: var(--font);
      font-size: var(--text-ui);
      line-height: 1.65;
      color: var(--jr-gron);
      opacity: 0.6;
      letter-spacing: 0.02em;
    }

    .scroll-indicator {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      margin-top: auto;
      padding-top: 1rem;
    }

    .scroll-labels {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      gap: 1.1rem;
    }

    .scroll-line {
      display: block;
      width: 1px;
      height: 2.5rem;
      background: var(--jr-gron);
      opacity: 0.3;
      animation: scroll-pulse 2.5s ease-in-out infinite;
    }

    .scroll-label {
      font-family: var(--font);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--jr-gron);
      opacity: 0.35;
      writing-mode: vertical-lr;
      transform: rotate(180deg);
      transition: opacity 0.2s ease;
    }

    .scroll-label:hover {
      opacity: 0.7;
    }

    .hero-foot {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      opacity: 0;
      transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.6s;
    }

    :global(body.is-loaded) .hero-foot {
      opacity: 1;
    }

    .foot-mark {
      display: inline-block;
      font-family: var(--font-display);
      font-size: clamp(0.9rem, 1.5vw, 1.1rem);
      color: var(--jr-gron);
      opacity: 0.4;
      letter-spacing: -0.03em;
    }

    .foot-wordmark {
      height: clamp(0.75rem, 1.4vw, 1rem);
      aspect-ratio: 1770 / 190;
      width: auto;
      display: block;
      flex: 0 0 auto;
      background: var(--jr-gron);
      -webkit-mask: var(--wordmark-mask) center / contain no-repeat;
      mask: var(--wordmark-mask) center / contain no-repeat;
      opacity: 0.55;
    }

    .meta-wordmark,
    .wordmark-stack,
    .hero-intro-graf,
    .scroll-indicator,
    .foot-mark,
    .foot-wordmark,
    .hero-rule-horiz,
    .hero-rule-vert {
      will-change: transform;
    }

    .hero-corner--tr {
      position: fixed;
      z-index: 60;
      top: calc(
        var(--space-lg) -
          ((var(--hamburger-size) - (var(--text-ui) * 1.5)) / 2) -
          (var(--text-ui) * 0.375)
      );
      right: max(var(--space-lg), calc((100vw - var(--content-shell-max)) / 2 + var(--space-lg)));
    }

    .hamburger {
      background: transparent;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      border: none;
      border-radius: 50%;
      box-shadow: none;
      cursor: pointer;
      padding: 0;
      width: var(--hamburger-size);
      height: var(--hamburger-size);
      color: var(--jr-gron);
      transition:
        opacity 0.25s ease,
        border-color 0.25s ease,
        box-shadow 0.25s ease;
    }

    :global(body.menu-open) .hamburger {
      background: color-mix(in srgb, var(--jr-vit) 72%, transparent);
      box-shadow: none;
    }

    .hamburger:hover {
      opacity: 0.8;
    }

    .hamburger-bar {
      display: block;
      position: absolute;
      left: 50%;
      top: 50%;
      width: 18px;
      height: 1.5px;
      background: currentColor;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
      transform-origin: center;
    }

    .hamburger-bar--top {
      transform: translate(-50%, calc(-50% - 2.5px));
    }
    .hamburger-bar--bot {
      transform: translate(-50%, calc(-50% + 2.5px));
    }

    .hamburger.is-open .hamburger-bar--top {
      transform: translate(-50%, -50%) rotate(45deg);
    }

    .hamburger.is-open .hamburger-bar--bot {
      transform: translate(-50%, -50%) rotate(-45deg);
    }

    .hamburger.is-open {
      opacity: 0.5;
    }

    .hamburger.is-open:hover {
      opacity: 0.8;
    }

    /* ── MENU DIALOG ─────────────────────────────────────────────── */
    .menu-dialog {
      position: fixed;
      inset: 0;
      z-index: 50;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      height: 100%;
      max-width: 100%;
      max-height: 100%;
      margin: 0;
      padding: 0;
      border: none;
      overflow: hidden;
      background-color: var(--jr-vit);
      color: var(--jr-gron);
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: translateY(0.25rem);
      transition:
        opacity 0.08s linear,
        transform 0.12s cubic-bezier(0.2, 0.8, 0.2, 1),
        visibility 0s linear 0.12s;
    }

    .menu-close {
      position: fixed;
      z-index: 60;
      top: calc(
        var(--space-lg) -
          ((var(--hamburger-size) - (var(--text-ui) * 1.5)) / 2) -
          (var(--text-ui) * 0.375)
      );
      right: max(var(--space-lg), calc((100vw - var(--content-shell-max)) / 2 + var(--space-lg)));
      opacity: 1;
      background: color-mix(in srgb, var(--jr-vit) 72%, transparent);
    }

    .menu-close .hamburger-bar--top {
      transform: translate(-50%, -50%) rotate(45deg);
    }

    .menu-close .hamburger-bar--bot {
      transform: translate(-50%, -50%) rotate(-45deg);
    }

    .menu-dialog[open] {
      visibility: visible;
    }

    .menu-dialog::backdrop {
      background: transparent;
    }

    .menu-dialog.is-visible {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
      transition:
        opacity 0.08s linear,
        transform 0.1s cubic-bezier(0.2, 0.8, 0.2, 1),
        visibility 0s linear 0s;
    }

    .menu-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: var(--space-xl);
      width: 100%;
      height: 100%;
      padding: var(--space-xl) var(--page-inset)
        max(var(--space-xl), env(safe-area-inset-bottom));
      opacity: 0;
      transform: translateY(0.25rem);
      transition:
        opacity 0.08s linear,
        transform 0.12s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .menu-dialog.is-visible .menu-inner {
      opacity: 1;
      transform: translateY(0);
    }

    .menu-nav {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-lg);
    }

    .menu-link {
      font-family: var(--font);
      font-size: clamp(2.5rem, 8vw, 5rem);
      text-transform: uppercase;
      letter-spacing: -0.02em;
      color: inherit;
      text-decoration: none;
      opacity: 0.9;
      line-height: 1;
    }

    .menu-link:hover {
      opacity: 1;
    }

    .menu-tagline {
      font-family: var(--font);
      font-size: var(--text-ui);
      text-transform: uppercase;
      letter-spacing: 0.22em;
      color: inherit;
      opacity: 0.38;
      text-align: center;
      margin: 0;
    }

    .menu-footer {
      position: absolute;
      bottom: 0;
      inset-inline: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-lg) var(--page-inset)
        max(var(--space-lg), env(safe-area-inset-bottom));
      max-width: var(--content-shell-max);
      margin-inline: auto;
    }

    .menu-logomark {
      height: 1.4rem;
      width: auto;
      display: block;
      color: inherit;
    }

    .menu-address {
      font-family: var(--font);
      font-size: var(--text-ui);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: inherit;
      margin: 0;
      text-align: center;
    }

    .menu-demeter {
      height: 1.6rem;
      width: auto;
      display: block;
    }

    @keyframes fade-up {
      from {
        opacity: 0;
        transform: translateY(1.2rem);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes scroll-pulse {
      0%,
      100% {
        opacity: 0.15;
        transform: scaleY(0.7);
        transform-origin: top;
      }
      50% {
        opacity: 0.4;
        transform: scaleY(1);
        transform-origin: top;
      }
    }

    @media (max-width: 640px) {
      .hero-v9 {
        padding: var(--space-lg);
      }

      .hero-meta {
        flex-wrap: wrap;
        padding-right: calc(var(--hamburger-size) + 0.75rem);
      }

      .hero-body {
        flex-direction: column;
        align-items: flex-start;
        gap: var(--space-lg);
      }

      .hero-rule-vert,
      .hero-right {
        display: none;
      }
    }

    .section-kicker {
      display: inline-block;
      margin-bottom: 1rem;
      font-family: var(--font-display);
      font-size: var(--text-body);
      text-transform: uppercase;
      letter-spacing: 0.28em;
      color: var(--jr-ocra);
    }

    .section-kicker--warm {
      display: block;
      color: var(--jr-ocra);
    }

    /* ── ABOUT SECTION ──────────────────────────────────────────── */
    .about-section {
      width: 100%;
      /*margin-top: clamp(4rem, 10vw, 8rem);*/
      padding: clamp(3rem, 8vw, 6rem) var(--page-inset) clamp(6rem, 16vw, 12rem);
      background-color: var(--jr-vit);
    }

    .about-section-inner {
      width: min(100%, var(--content-shell-max));
      margin: 0 auto;
      display: grid;
      grid-template-columns: minmax(0, 34rem) minmax(0, 1fr);
      align-items: center;
      column-gap: clamp(2rem, 6vw, 6rem);
      row-gap: clamp(1.5rem, 4vw, 3rem);
      min-height: clamp(30rem, 72svh, 44rem);
    }

    .about-section-copy {
      width: 100%;
      max-width: 34rem;
      grid-column: 2;
      grid-row: 1;
    }

    .about-section-image {
      display: block;
      width: 100%;
      aspect-ratio: 4 / 3;
      background-size: contain;
      background-position: center;
      background-repeat: no-repeat;
      grid-column: 1;
      grid-row: 1;
    }

    @media (max-width: 1200px) {
      .about-section {
        padding: clamp(3rem, 8vw, 4.5rem) var(--page-inset);
      }

      .about-section-inner {
        grid-template-columns: 1fr;
        min-height: auto;
        row-gap: clamp(1.5rem, 5vw, 2.5rem);
      }

      .about-section-copy {
        width: 100%;
        max-width: 64ch;
        grid-column: auto;
        grid-row: auto;
        margin-left: auto;
      }

      .about-section-image {
        width: 75%;
        grid-column: auto;
        grid-row: auto;
        aspect-ratio: 1 / 1;
        justify-self: center;
      }
    }

    .about-section-copy p:not(.section-kicker) {
      font-family: var(--font);
      font-size: clamp(0.875rem, 1.2vw, 1rem);
      line-height: 1.75;
      color: var(--jr-morkrost);
      opacity: 0.9;
      text-align: left;
      margin: 0;
    }

    .about-section-copy p:not(.section-kicker) + p:not(.section-kicker) {
      margin-top: 1.25em;
    }

    .about-section-copy > p:last-child::selection {
      background: color-mix(in srgb, var(--jr-ljusgul) 72%, white);
      color: var(--jr-morkrost);
    }

    @media (max-width: 550px) {
      .about-section-inner {
        row-gap: 1.5rem;
      }

      .about-section-image {
        width: 100%;
        aspect-ratio: 1 / 1;
      }
    }

    /* ── PACKAGES SECTION ───────────────────────────────────────── */
    .packages-section {
      --packages-side-pad: var(--page-inset);
      position: relative;
      width: 100%;
      min-height: 100svh;
      padding: clamp(5rem, 10vw, 8rem) var(--packages-side-pad)
        clamp(2rem, 6vw, 4rem);
      background: var(--jr-vit);
      align-items: center;
    }

    .packages-section-inner {
      width: min(100%, var(--content-shell-max));
      min-height: calc(100svh - (clamp(2rem, 6vw, 4rem) * 2));
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr;
      grid-template-rows: 1fr auto;
      align-items: center;
    }

    .packages-section-image {
      display: block;
      width: min(32rem, 100%);
      max-width: 100%;
      height: auto;
      object-fit: contain;
      justify-self: center;
      align-self: center;
      grid-row: 1 / 2;
    }

    .packages-section-caption {
      margin: 0;
      max-width: 24rem;
      font-family: var(--font-mono);
      font-size: var(--text-body);
      line-height: var(--line-height);
      color: var(--jr-morkrost);
      grid-row: 2 / 3;
      justify-self: start;
      align-self: end;
      text-align: left;
      opacity: 0.82;
    }

    @media (max-width: 800px) {
      .packages-section {
        --packages-side-pad: 1rem;
        padding: clamp(2rem, 6vw, 4rem) var(--packages-side-pad);
      }
    }

    @media (max-width: 550px) {
      .packages-section-inner {
        min-height: calc(100svh - (clamp(2rem, 6vw, 4rem) * 2));
      }

      .packages-section-image {
        width: min(28rem, 100%);
      }
    }

    /* ── IMAGE BLOCK ─────────────────────────────────────────────── */
    .image-footer-stack {
      display: grid;
      grid-template-rows: minmax(0, 1fr) auto;
      min-height: 100svh;
      background: var(--jr-vit);
    }

    .image-block {
      position: relative;
      width: min(100%, var(--content-shell-max));
      margin-inline: auto;
      height: 100%;
      min-height: 0;
      overflow: hidden;
      background: var(--jr-vit);
    }

    .image-block-photo {
      position: absolute;
      inset: 0;
      background-size: cover;
      background-position: center 30%;
    }

    .image-block-scrim {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(
          ellipse 55% 40% at 0% 0%,
          rgba(0, 0, 0, 0.82) 0%,
          transparent 100%
        ),
        linear-gradient(
          to top,
          rgba(0, 0, 0, 0.72) 0%,
          rgba(0, 0, 0, 0.28) 35%,
          transparent 62%
        );
      pointer-events: none;
    }

    .image-block-top {
      position: absolute;
      top: var(--page-inset);
      inset-inline: 0;
      width: min(100%, var(--content-shell-max));
      margin: 0 auto;
      padding-inline: 2rem;
      z-index: 1;
      color: var(--jr-vit);
    }

    .image-block-bottom {
      position: absolute;
      bottom: 0;
      inset-inline: 0;
      z-index: 1;
      width: min(100%, var(--content-shell-max));
      margin: 0 auto;
      padding-inline: 2rem;
      padding-block: var(--page-inset) clamp(1.5rem, 4vw, 2.5rem);
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: clamp(1rem, 3vw, 2rem);
    }

    .image-block-caption {
      font-family: var(--font);
      font-size: var(--text-body);
      line-height: 1.55;
      color: var(--jr-vit);
      opacity: 0.65;
      max-width: 26ch;
      margin: 0;
    }

    .image-block-cta {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 0.25rem;
      color: var(--jr-vit);
      text-decoration: none;
      flex-shrink: 0;
      transition: opacity 0.2s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .image-block-cta:hover {
      opacity: 0.55;
    }

    .image-block-cta-label {
      font-family: var(--font);
      font-size: var(--text-ui);
      text-transform: uppercase;
      letter-spacing: 0.28em;
      color: var(--jr-vit);
      opacity: 0.6;
      line-height: 1;
    }

    .image-block-cta-handle {
      font-family: var(--font);
      font-size: clamp(1.4rem, 3vw, 2.5rem);
      letter-spacing: -0.03em;
      line-height: 1;
    }

    /* ── CONTACT SECTION ────────────────────────────────────────── */
    .contact-section {
      background: var(--jr-vit);
      color: var(--jr-gron);
      min-height: 100svh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding-inline: var(--page-inset);
      box-sizing: border-box;
    }

    .contact-section-inner {
      width: min(100%, var(--content-shell-max));
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
      text-align: center;
    }

    .contact-items {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
    }

    .contact-item {
      font-family: var(--font);
      font-size: clamp(1.4rem, 3vw, 2.5rem);
      line-height: 1;
      letter-spacing: -0.03em;
      color: var(--jr-gron);
      text-decoration: none;
      transition: opacity 0.2s cubic-bezier(0.22, 1, 0.36, 1);
      display: block;
    }

    .contact-item:hover {
      opacity: 0.55;
    }

    @media (max-width: 800px) {
      .contact-item,
      .index-footer-link {
        display: inline-flex;
        align-items: center;
        min-height: 44px;
      }
    }

    .contact-address {
      font-family: var(--font);
      font-size: var(--text-ui);
      text-transform: uppercase;
      letter-spacing: 0.2em;
      color: var(--jr-brun);
      opacity: 0.72;
      margin-top: clamp(2.5rem, 6vw, 4rem);
    }

    /* ── INDEX FOOTER ───────────────────────────────────────────── */
    .index-footer {
      background: var(--jr-vit);
      color: var(--jr-gron);
    }

    .index-footer-inner {
      width: min(100%, var(--content-shell-max));
      margin: 0 auto;
      padding-inline: 2rem;
      padding-block: 2rem max(2rem, env(safe-area-inset-bottom));
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--space-lg);
    }

    .index-footer-wordmark {
      height: clamp(1rem, 2.5vw, 1.4rem);
      aspect-ratio: 1770 / 190;
      width: auto;
      display: block;
      flex: 0 0 auto;
      color: var(--jr-gron);
      background: currentColor;
      -webkit-mask: var(--wordmark-mask) center / contain no-repeat;
      mask: var(--wordmark-mask) center / contain no-repeat;
      opacity: 0.55;
    }

    .index-footer-nav {
      display: flex;
      gap: var(--space-xl);
    }

    .index-footer-copyright,
    .index-footer-link {
      font-family: var(--font);
      font-size: var(--text-ui);
      color: var(--jr-gron);
      text-decoration: none;
      opacity: 0.55;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition: opacity 0.2s ease;
    }

    .index-footer-copyright {
      white-space: nowrap;
    }

    .index-footer-link:hover {
      opacity: 1;
    }

    /* ── PRODUCTS ────────────────────────────────────────────────── */
    /* ── BLEND STRIP SCROLLER ───────────────────────────────────── */
    .products-scroller {
      position: relative;
      height: 300svh;
    }

    .products-stage {
      position: sticky;
      top: 0;
      height: 100svh;
      max-width: var(--content-shell-max);
      margin: 0 auto;
      perspective: 1200px;
      perspective-origin: 0% 50%;
      overflow: hidden;
    }

    .products-kicker {
      position: absolute;
      bottom: clamp(1.5rem, 4svh, 3rem);
      right: var(--page-inset);
      z-index: 2;
      margin: 0;
      color: var(--jr-morkrost);
      text-align: right;
      will-change: opacity, transform;
    }

    .blend-strip {
      position: absolute;
      top: 50%;
      translate: 0 -50%;
      height: 80svh;
      will-change: transform;
      display: block;
      padding: 0;
      border: 0;
      border-radius: 0;
      background: transparent;
      cursor: pointer;
      appearance: none;
    }

    .blend-strip-image {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .blend-strip::after {
      content: "";
      position: absolute;
      inset: 0;
      box-shadow: inset 0 0 0 5px white;
      pointer-events: none;
      z-index: 2;
    }

    @media (max-width: 900px) {
      .blend-strip::after {
        display: none;
      }
    }

    .blend-strip:focus-visible {
      outline: 2px solid var(--jr-morkrost);
      outline-offset: -2px;
    }

    /* ── PRODUCTS: REDUCED-MOTION (desktop static fan) ──────────── */
    @media (prefers-reduced-motion: reduce) {
      .products-scroller {
        height: auto;
      }

      .products-stage {
        position: relative;
        height: auto;
        min-height: 72svh;
        padding: clamp(3rem, 8svh, 5rem) var(--page-inset)
          clamp(4rem, 10svh, 6rem);
        perspective: 1200px;
        perspective-origin: 50% 50%;
        overflow: visible;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .products-kicker {
        position: absolute;
        bottom: clamp(1rem, 3svh, 2rem);
        right: var(--page-inset);
        opacity: 1;
        transform: none;
      }

      .blend-strip {
        position: relative;
        top: auto;
        translate: none;
        height: clamp(14rem, 28svh, 22rem);
        width: calc(100% / 6 * 0.88) !important;
        flex-shrink: 0;
        transform: none !important;
      }

      .products-stage {
        gap: 0;
      }

      /* Fan each strip with a fixed tilt — no JS needed */
      .blend-strip:nth-child(2) {
        transform: rotateY(-14deg) translateX(-1%) !important;
        z-index: 1;
      }
      .blend-strip:nth-child(3) {
        transform: rotateY(-8deg) translateX(-0.5%) !important;
        z-index: 2;
      }
      .blend-strip:nth-child(4) {
        transform: rotateY(0deg) !important;
        z-index: 3;
      }
      .blend-strip:nth-child(5) {
        transform: rotateY(8deg) translateX(0.5%) !important;
        z-index: 2;
      }
      .blend-strip:nth-child(6) {
        transform: rotateY(14deg) translateX(1%) !important;
        z-index: 1;
      }
      .blend-strip:nth-child(7) {
        transform: rotateY(18deg) translateX(1.5%) !important;
        z-index: 0;
      }
    }

    /* ── PRODUCTS: MOBILE / TABLET GRID ─────────────────────────── */
    @media (max-width: 900px) {
      .products-scroller {
        height: auto !important;
      }

      .products-stage {
        position: relative !important;
        top: auto !important;
        height: auto !important;
        min-height: 0;
        max-width: 100%;
        display: grid;
        grid-template-columns: 1fr 1fr;
        grid-template-rows: auto repeat(3, clamp(12rem, 36vw, 20rem));
        perspective: none;
        overflow: visible;
        padding: 0;
        gap: 0;
      }

      .products-kicker {
        position: relative;
        bottom: auto;
        right: auto;
        grid-column: 1 / -1;
        grid-row: 1;
        padding: clamp(2rem, 6vw, 3.5rem) var(--page-inset)
          clamp(1rem, 3vw, 1.5rem);
        text-align: left;
        opacity: 1;
        transform: none;
      }

      .blend-strip {
        position: relative;
        top: auto;
        left: auto !important;
        translate: none;
        width: 100% !important;
        height: 100%;
        margin-top: 0;
        transform: none !important;
        will-change: auto;
        overflow: visible;
        z-index: 0;
      }

      .blend-strip.is-expanded {
        z-index: 1;
      }

      /* All images: top-anchored, 200% tall */
      .blend-strip .blend-strip-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 200%;
        object-fit: cover;
        object-position: top center;
        transition: clip-path 0.45s cubic-bezier(0.22, 1, 0.36, 1);
      }

      /* Rows 1–2: clip bottom half, expand downward */
      .blend-strip:nth-child(2) .blend-strip-image,
      .blend-strip:nth-child(3) .blend-strip-image,
      .blend-strip:nth-child(4) .blend-strip-image,
      .blend-strip:nth-child(5) .blend-strip-image {
        clip-path: inset(0 0 50% 0);
      }

      .blend-strip:nth-child(2).is-expanded .blend-strip-image,
      .blend-strip:nth-child(3).is-expanded .blend-strip-image,
      .blend-strip:nth-child(4).is-expanded .blend-strip-image,
      .blend-strip:nth-child(5).is-expanded .blend-strip-image {
        clip-path: inset(0 0 0% 0);
      }

      /* Row 3: anchored bottom, expand upward */
      .blend-strip:nth-child(6) .blend-strip-image,
      .blend-strip:nth-child(7) .blend-strip-image {
        top: auto;
        bottom: 0;
        clip-path: inset(50% 0 0 0);
      }

      .blend-strip:nth-child(6).is-expanded .blend-strip-image,
      .blend-strip:nth-child(7).is-expanded .blend-strip-image {
        clip-path: inset(0 0 0 0);
      }
    }

    @media (max-width: 900px) and (prefers-reduced-motion: reduce) {
      .blend-strip {
        transform: none !important;
      }
    }

    .section-kicker[data-kicker-reveal] {
      opacity: 0;
      transform: translateY(1.1rem);
      will-change: opacity, transform;
      transition:
        opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
        transform 1s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .section-kicker[data-kicker-reveal].is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    .hamburger {
      opacity: 0;
      transform: translateY(1rem);
      transition:
        opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
        transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    }

    :global(body.is-loaded) .hamburger {
      opacity: 1;
      transform: translateY(0);
    }

    :global(body.is-loaded) .hamburger {
      transition-delay: 0.08s;
    }

    @media (prefers-reduced-motion: reduce) {
      .image-block-cta,
      .contact-link,
      .product-image,
      .hero-meta,
      .hero-left,
      .hero-left-grafs,
      .hero-rule-vert,
      .hero-rule-horiz,
      .hero-right,
      .hamburger,
      .section-kicker[data-kicker-reveal] {
        animation: none;
        transition: none;
        transform: none;
        opacity: 1;
        filter: none;
      }

      .hero-foot {
        transition: none;
        transform: none;
        opacity: 1;
      }

      .scroll-line {
        animation: none;
      }
    }

    /* ── RESPONSIVE ──────────────────────────────────────────────── */
    @media (max-width: 800px) {
      .text-inner {
        grid-template-columns: 1fr;
        gap: var(--space-lg);
      }

      .packages-section-caption,
      .about-section-copy,
      .about-section-copy p:not(.section-kicker),
      .about-section-copy .section-kicker,
      .product-info,
      .product-desc,
      .product-tags,
      .index-footer-inner,
      .index-footer-nav,
      .index-footer-copyright {
        text-align: center;
      }

      .product-row,
      .product-row--reverse {
        grid-template-columns: 1fr;
        direction: ltr;
        row-gap: 2.25rem;
      }

      .products {
        padding: clamp(3.5rem, 12vw, 5rem) 0;
      }

      .about-section-inner,
      .packages-section,
      .product-card {
        min-height: 100svh;
      }

      .product-card {
        position: relative;
        top: auto;
        margin-top: 1rem;
        border: none;
        transform: none !important;
      }

      .product-card:not(:first-child) {
        display: none;
      }

      .product-index {
        display: none;
      }

      .product-info {
        align-items: center;
      }

      .product-tags {
        display: none;
      }

      .index-footer-inner {
        align-items: center;
        flex-direction: column;
        gap: 1.25rem;
        padding-inline: 2rem;
        padding-block: 1.5rem max(1.75rem, env(safe-area-inset-bottom));
        text-align: center;
      }

      .index-footer-wordmark {
        height: 1.15rem;
        opacity: 0.78;
      }

      .index-footer-nav {
        justify-content: center;
        gap: 1.25rem;
        flex-wrap: wrap;
      }

      .index-footer-link,
      .index-footer-copyright {
        opacity: 0.7;
      }

      .index-footer-copyright {
        width: 100%;
        padding-top: 0.75rem;
        font-size: calc(var(--text-ui) * 0.82);
        border-top: 1px solid
          color-mix(in srgb, var(--jr-ocra) 22%, transparent);
      }
    }

    @media (max-width: 550px) {
      :root {
        --page-inset: 1rem;
      }

      .product-row,
      .product-row--reverse {
        padding: 0 1rem;
      }

      .image-block-bottom {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
      }

      .image-block-caption {
        display: none;
      }

      .image-block {
        height: 100%;
      }

      .packages-section-caption {
        margin-inline: auto;
      }
    }

    @media (max-width: 374px) {
      .hero-corner--bl {
        font-size: calc(var(--text-body) * 0.82);
        letter-spacing: 0.14em;
      }
    }
  </style>

  <script>
    const hamburger = document.querySelector(".hamburger") as HTMLButtonElement;
    const dialog = document.getElementById("site-menu") as HTMLDialogElement;
    const menuTransitionMs = 120;
    let closeTimer: number | undefined;
    let scrollLockY = 0;
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const productsKicker = document.querySelector(
      "[data-products-kicker]",
    ) as HTMLElement | null;

    function clamp01(value: number): number {
      return Math.min(1, Math.max(0, value));
    }

    requestAnimationFrame(() => {
      document.body.classList.add("is-loaded");
    });

    function syncScrolledState() {
      document.body.classList.toggle("is-scrolled", window.scrollY > 0);
    }

    syncScrolledState();
    window.addEventListener("scroll", syncScrolledState, { passive: true });

    const heroDriftRight = Array.from(
      document.querySelectorAll(".meta-wordmark, .wordmark-stack, .foot-mark"),
    ) as HTMLElement[];
    const heroDriftLeft = Array.from(
      document.querySelectorAll(
        ".hero-intro-graf, .scroll-indicator, .foot-wordmark, .hero-rule-horiz",
      ),
    ) as HTMLElement[];
    const mobileDriftLeft = Array.from(
      document.querySelectorAll(".hero-left-grafs"),
    ) as HTMLElement[];
    const mobileDriftRight = Array.from(
      document.querySelectorAll(".hero-foot"),
    ) as HTMLElement[];

    const heroSection = document.querySelector(
      ".hero-v9",
    ) as HTMLElement | null;
    const heroDriftFade = Array.from(
      document.querySelectorAll(
        ".meta-wordmark, .hero-intro-graf, .scroll-indicator, .foot-mark, .foot-wordmark, .wordmark-tagline, .hero-left-grafs, .hero-rule-horiz",
      ),
    ) as HTMLElement[];

    const vertRule = document.querySelector(
      ".hero-rule-vert",
    ) as HTMLElement | null;
    const PARALLAX_MOBILE_BREAKPOINT = 640;

    function syncParallax() {
      const y = window.scrollY;
      const heroH = heroSection ? heroSection.offsetHeight : window.innerHeight;
      const isMobile = window.innerWidth <= PARALLAX_MOBILE_BREAKPOINT;

      if (!reduceMotion.matches && !isMobile) {
        const pull = y * 1.8;
        const fadeProgress = Math.min(1, y / (heroH * 0.28));
        heroDriftRight.forEach((element) => {
          element.style.transform = `translateX(${pull}px)`;
        });
        heroDriftLeft.forEach((element) => {
          element.style.transform = `translateX(-${pull}px)`;
        });
        heroDriftFade.forEach((element) => {
          element.style.opacity = String(Math.max(0, 1 - fadeProgress * 1.15));
        });
        if (vertRule) {
          vertRule.style.opacity = String(Math.max(0, 1 - fadeProgress * 1.15));
          vertRule.style.transform = `scaleY(1) translateY(-${fadeProgress * 60}px)`;
        }
        mobileDriftLeft.forEach((el) => el.style.removeProperty("transform"));
        mobileDriftRight.forEach((el) => el.style.removeProperty("transform"));
      } else if (!reduceMotion.matches && isMobile) {
        const pull = y * 1.8;
        mobileDriftLeft.forEach((el) => {
          el.style.transform = `translateX(-${pull}px)`;
        });
        mobileDriftRight.forEach((el) => {
          el.style.transform = `translateX(${pull}px)`;
        });
        [...heroDriftRight, ...heroDriftLeft].forEach((el) => el.style.removeProperty("transform"));
        heroDriftFade.forEach((el) => el.style.removeProperty("opacity"));
        if (vertRule) { vertRule.style.removeProperty("opacity"); vertRule.style.removeProperty("transform"); }
      } else {
        [...heroDriftRight, ...heroDriftLeft, ...mobileDriftLeft, ...mobileDriftRight].forEach((element) => {
          element.style.removeProperty("transform");
        });
        heroDriftFade.forEach((element) => {
          element.style.removeProperty("opacity");
        });
        if (vertRule) {
          vertRule.style.removeProperty("opacity");
          vertRule.style.removeProperty("transform");
        }
      }
    }
    syncParallax();
    window.addEventListener("scroll", syncParallax, { passive: true });

    // ── BLEND STRIP SCROLLER ─────────────────────────────────────
    const MOBILE_BREAKPOINT = 900;

    const blendScroller = document.querySelector(
      "[data-blend-scroller]",
    ) as HTMLElement | null;
    const blendStrips = Array.from(
      document.querySelectorAll("[data-blend-strip]"),
    ) as HTMLElement[];
    const EXPAND_DURATION = 450;
    blendStrips.forEach((strip) => {
      strip.addEventListener("click", () => {
        if (window.innerWidth > MOBILE_BREAKPOINT) return;
        const shouldExpand = !strip.classList.contains("is-expanded");
        blendStrips.forEach((otherStrip) => {
          if (otherStrip === strip) return;
          if (otherStrip.classList.contains("is-expanded")) {
            otherStrip.classList.remove("is-expanded");
            otherStrip.setAttribute("aria-expanded", "false");
            otherStrip.style.zIndex = "1";
            setTimeout(() => {
              otherStrip.style.removeProperty("z-index");
            }, EXPAND_DURATION);
          }
        });
        if (shouldExpand) {
          strip.style.zIndex = "3";
          strip.classList.add("is-expanded");
          strip.setAttribute("aria-expanded", "true");
          setTimeout(() => {
            strip.style.removeProperty("z-index");
          }, EXPAND_DURATION);
        } else {
          strip.classList.remove("is-expanded");
          strip.setAttribute("aria-expanded", "false");
        }
      });
    });
    const N = blendStrips.length;
    const OVERLAP = 0.6;
    const OVERLAP2 = 0.4;
    const FINAL_TILT = 18;
    let blendStageW = 0;
    let blendStripW = 0;
    let blendSlotStep = 0;
    let blendShelfOffset = 0;
    let blendStartLefts: number[] = [];
    let blendFinalLefts: number[] = [];
    let blendRafPending = false;

    function computeBlendLayout() {
      if (!blendScroller) return;
      const stageEl = blendScroller.querySelector(
        "[data-blend-stage]",
      ) as HTMLElement;
      blendStageW = stageEl.offsetWidth;
      const stageH = window.innerHeight * 0.8;
      const stripWByLayout =
        (blendStageW * 0.95) / ((N - 1) * (1 - OVERLAP) + 1);
      const stripWByRatio = stageH * (846 / 1450);
      blendStripW = Math.min(stripWByLayout, stripWByRatio);
      blendSlotStep = blendStripW * (1 - OVERLAP);
      const shelfW = (N - 1) * blendSlotStep + blendStripW;
      blendShelfOffset = (blendStageW - shelfW) / 2;
      blendStrips.forEach((strip, i) => {
        strip.style.width = `${blendStripW}px`;
        strip.style.zIndex = String(i + 1);
        blendFinalLefts[i] = blendShelfOffset + i * blendSlotStep;
        blendStartLefts[i] =
          i === 0 ? (blendStageW - blendStripW) / 2 : blendStageW + blendStripW;
      });
    }

    // Flush: N strips side by side with no gap, centered in stage
    // Strip width in flush state = stageW / N (may differ from blendStripW)
    function blendFlushLeft(i: number): number {
      const flushStripW = blendStageW / N;
      return i * flushStripW;
    }

    function applyBlendStrips() {
      blendRafPending = false;
      if (!blendScroller) return;
      const rect = blendScroller.getBoundingClientRect();
      const scrolled = -rect.top;
      const total = blendScroller.offsetHeight - window.innerHeight;
      const g = clamp01(scrolled / total);

      if (productsKicker && !reduceMotion.matches) {
        const fadeOut = clamp01((g - 0.82) / 0.18);
        productsKicker.style.opacity = String(1 - fadeOut);
        productsKicker.style.transform = `translateY(${fadeOut * 0.5}rem)`;
      }

      // Phase 1 (g 0→0.65): reveal strips one by one with tilt
      // Phase 2 (g 0.65→1): all straighten and spread to flush
      const PHASE1 = 0.65;
      const phase2P = clamp01((g - PHASE1) / (1 - PHASE1));

      blendStrips.forEach((strip, i) => {
        const stepStart = ((i * (1 - OVERLAP2)) / N) * PHASE1;
        const stepEnd = stepStart + (1 / N) * PHASE1;
        const p = clamp01((g - stepStart) / (stepEnd - stepStart));

        const tiltedLeft =
          blendStartLefts[i] + p * (blendFinalLefts[i] - blendStartLefts[i]);
        const flushLeft = blendFlushLeft(i);
        const flushStripW = blendStageW / N;

        strip.style.left = `${tiltedLeft + phase2P * (flushLeft - tiltedLeft)}px`;
        strip.style.width = `${blendStripW + phase2P * (flushStripW - blendStripW)}px`;
        strip.style.transform = `rotateY(${(1 - phase2P) * p * FINAL_TILT}deg)`;
      });
    }

    function onBlendScroll() {
      if (blendRafPending) return;
      blendRafPending = true;
      requestAnimationFrame(applyBlendStrips);
    }

    function isStaticProducts(): boolean {
      return reduceMotion.matches || window.innerWidth <= MOBILE_BREAKPOINT;
    }

    function initScrollProducts() {
      computeBlendLayout();
      applyBlendStrips();
    }

    function teardownScrollProducts() {
      if (!blendScroller) return;
      blendStrips.forEach((strip) => {
        strip.style.removeProperty("left");
        strip.style.removeProperty("width");
        strip.style.removeProperty("transform");
      });
      if (productsKicker) {
        productsKicker.style.removeProperty("opacity");
        productsKicker.style.removeProperty("transform");
      }
    }

    if (!isStaticProducts()) {
      initScrollProducts();
    } else {
      teardownScrollProducts();
    }

    window.addEventListener(
      "scroll",
      () => {
        if (!isStaticProducts()) onBlendScroll();
      },
      { passive: true },
    );
    window.addEventListener("resize", () => {
      if (isStaticProducts()) {
        teardownScrollProducts();
      } else {
        blendStrips.forEach((strip) => {
          strip.classList.remove("is-expanded");
          strip.setAttribute("aria-expanded", "false");
        });
        computeBlendLayout();
        applyBlendStrips();
      }
    });

    reduceMotion.addEventListener("change", () => {
      if (isStaticProducts()) {
        teardownScrollProducts();
      } else {
        initScrollProducts();
      }
    });

    function syncMenuState(isOpen: boolean) {
      document.documentElement.classList.toggle("menu-open", isOpen);
      document.body.classList.toggle("menu-open", isOpen);
      if (isOpen) {
        scrollLockY = window.scrollY;
        document.body.style.top = `-${scrollLockY}px`;
      } else {
        document.body.style.top = "";
        window.scrollTo(0, scrollLockY);
      }
      hamburger.setAttribute("aria-expanded", String(isOpen));
      hamburger.classList.toggle("is-open", isOpen);
    }

    function openMenu() {
      window.clearTimeout(closeTimer);
      if (!dialog.open) {
        if (typeof dialog.showModal === "function") {
          dialog.showModal();
        } else {
          dialog.show();
        }
      }
      void dialog.offsetWidth;
      dialog.classList.add("is-visible");
      syncMenuState(true);
      requestAnimationFrame(() => {
        (
          dialog.querySelector(".menu-close") as HTMLButtonElement | null
        )?.focus();
      });
    }

    function closeMenu() {
      if (!dialog.open) {
        syncMenuState(false);
        return;
      }

      dialog.classList.remove("is-visible");
      syncMenuState(false);
      closeTimer = window.setTimeout(() => {
        if (dialog.open) dialog.close();
      }, menuTransitionMs);
    }

    hamburger.addEventListener("click", () => {
      dialog.open ? closeMenu() : openMenu();
    });

    dialog.addEventListener("close", () => {
      window.clearTimeout(closeTimer);
      dialog.classList.remove("is-visible");
      hamburger.focus();
    });

    dialog.addEventListener("cancel", (event) => {
      event.preventDefault();
      closeMenu();
    });

    dialog.addEventListener("click", (event) => {
      if (event.target === dialog) closeMenu();
    });

    dialog.querySelector(".menu-close")?.addEventListener("click", closeMenu);

    dialog.querySelectorAll(".menu-link").forEach((link) => {
      link.addEventListener("click", (e) => {
        const href = (link as HTMLAnchorElement).getAttribute("href");
        if (href && href.startsWith("#")) {
          e.preventDefault();
          const target = document.querySelector(href) as HTMLElement | null;
          if (target) {
            scrollLockY = target.offsetTop;
          }
          dialog.classList.remove("is-visible");
          closeTimer = window.setTimeout(() => {
            if (dialog.open) dialog.close();
          }, menuTransitionMs);
        } else {
          closeMenu();
        }
      });
    });

    if (!reduceMotion.matches) {
      const kickerObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            entry.target.classList.toggle("is-visible", entry.isIntersecting);
          });
        },
        { threshold: 0.01, rootMargin: "0px 0px -24% 0px" },
      );

      document.querySelectorAll("[data-kicker-reveal]").forEach((kicker) => {
        if (kicker === productsKicker && !isStaticProducts()) return;
        kickerObserver.observe(kicker);
      });
    } else {
      document.querySelectorAll("[data-kicker-reveal]").forEach((kicker) => {
        kicker.classList.add("is-visible");
      });
    }
  </script>
</Base>
