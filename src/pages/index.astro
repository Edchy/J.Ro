      </dialog>
      <div class="hero-logo-wrap">
        <LogoMark color="var(--jr-gold)" width="clamp(18rem, 80vw, 42rem)" />
      </div>
      <span class="hero-corner hero-corner--bl"
        >Ekologiskt <span class="hero-dot">·</span> Biodynamiskt <span
          class="hero-dot">·</span
        > Kaffe</span
      >
    </div>
  </section>
  <!-- ─── PRODUCTS ─────────────────────────────────────────────── -->
  <div class="products-scroller" data-blend-scroller>
    <div class="products-stage" data-blend-stage>
      {
        blends.map((blend, index) => (
          <div
            class="blend-strip"
            data-blend-strip
            data-index={index}
            style={`--strip-index: ${index};`}
          >
            <img
              class="blend-strip-image"
              src={`${base}/assets/images/${blend.image}`}
              alt={blend.name}
            />
          </div>
        ))
      }
    </div>
  </div>

  <!-- ─── ABOUT ────────────────────────────────────────────────── -->
  <section
    id="about"
    class="about-section"
    aria-label="Kollage från Järna Rosteri"
    data-reveal
  >
    <div class="about-section-inner">
      <div class="about-section-copy">
        <p class="section-kicker">Om rosteriet</p>
        <p>
          Hos oss handlar kaffe om mer än bara rostning – det är ett hantverk
          grundat i relationer, hållbarhet och passion. Vi samarbetar direkt med
          Demeter-certifierade kaffegårdar, där varje böna odlas i samklang med
          naturen och bär på en berättelse om balans, respekt och mänskliga
          möten. Vårt personliga engagemang genomsyrar hela processen, från
          ursprung till kopp.
        </p>
      </div>
      <div
        class="about-section-image"
        style={`background-image: url('${base}/assets/images/collage.avif')`}
        aria-hidden="true"
      >
      </div>
    </div>
  </section>

  <!-- ─── CONTACT ──────────────────────────────────────────────── -->
  <section id="contact" class="contact-section" data-reveal>
    <div class="contact-section-inner">
      <div class="contact-section-copy">
        <p class="section-kicker section-kicker--contact">Kontakt</p>
        <p class="contact-section-text">
          För priser, sortiment och frågor om kaffe till café, butik eller
          restaurang, hör av er.
        </p>
      </div>

      <div class="contact-section-links" aria-label="Kontaktvägar">
        <a href="mailto:info@jarnarosteri.se" class="contact-section-link">
          <span class="contact-section-link-value">info@jarnarosteri.se</span>
        </a>
        <a href="tel:+46708401365" class="contact-section-link">
          <span class="contact-section-link-value">070-840 13 65</span>
        </a>
        <a
          href="https://www.instagram.com/jarnarosteri"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-section-link"
        >
          <span class="contact-section-link-value">instagram</span>
        </a>
        <p class="contact-section-address">Maskinvägen 5, 153 30 Järna</p>
      </div>
    </div>
  </section>

  <!-- ─── PACKAGES ─────────────────────────────────────────────── -->
  <!-- <section class="packages-section" data-reveal>
    <div class="packages-section-inner">
      <img
        src={`${base}/assets/images/coffee-packages.png`}
        alt="Kaffepåsar från Järna Rosteri"
        class="packages-section-image"
      />
      <p class="packages-section-caption">
        <span class="section-kicker section-kicker--warm">Aktuell påse</span>
        POAB'S ESP. En av våra espresso sorter. Indisk arabica och robusta.
      </p>
    </div>
  </section> -->

  <!-- ─── IMAGE + CAPTION ──────────────────────────────────────── -->
  <section class="image-block" data-reveal>
    <div
      class="image-block-photo"
      style={`background-image: url('${base}/assets/images/hero-no-text.avif')`}
    >
    </div>
    <div class="image-block-caption">
      <div class="image-block-caption-inner">
        <p>För mer från våra resor,<br /> rosteriet & vardagen</p>
        <a
          href="https://www.instagram.com/jarnarosteri"
          target="_blank"
          rel="noopener noreferrer"
          class="image-block-instagram"
        >
          <span>instagram</span>
        </a>
      </div>
    </div>
    <div class="image-block-scrim"></div>
  </section>

  <!-- ─── FOOTER ───────────────────────────────────────────────── -->
  <footer class="index-footer">
    <div class="index-footer-inner">
      <span
        class="index-footer-wordmark"
        style={`--wordmark-mask: url('${base}/assets/images/jarna-rosteri-wordmark.svg')`}
        role="img"
        aria-label="Järna Rosteri"></span>
      <nav class="index-footer-nav">
        <a href="#contact" class="index-footer-link">Kontakt</a>
        <a href="#about" class="index-footer-link">Om oss</a>
      </nav>
      <p class="index-footer-copyright">© Järna Rosteri AB</p>
    </div>
  </footer>
</Base>

<style>
  :root {
    --page-inset: var(--space-lg);
    --page-max: 1080px;
    --content-shell-max: 1200px;
    --content-line-start: max(
      var(--page-inset),
      calc((100vw - var(--content-shell-max)) / 2 + var(--page-inset))
    );
    --header-height: 4.5rem;
    --hamburger-size: 2.35rem;
  }

  :global(body) {
    background: var(--jr-gron);
  }

  :global(html.menu-open) {
    overflow-y: scroll;
    scrollbar-gutter: stable;
  }

  :global(body.menu-open) {
    overflow: hidden;
  }

  :global(body.menu-open) {
    position: fixed;
    inset: 0;
    width: 100%;
    touch-action: none;
  }

  /* ── HERO ─────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    background-color: var(--jr-gron);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero::after {
    content: "";
    position: absolute;
    bottom: 0;
    inset-inline: 0;
    height: 40rem;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      color-mix(in srgb, var(--jr-gron) 10%, transparent) 25%,
      color-mix(in srgb, var(--jr-gron) 35%, transparent) 48%,
      color-mix(in srgb, var(--jr-gron) 68%, transparent) 68%,
      color-mix(in srgb, var(--jr-gron) 88%, transparent) 82%,
      var(--jr-gron) 100%
    );
    pointer-events: none;
    z-index: 2;
  }

  .hero-parallax-bg {
    position: absolute;
    inset: -30% 0;
    z-index: 0;
    background-color: var(--jr-gron);
    background-image: var(--hero-bg-image);
    background-size: cover;
    background-position: center;
    will-change: transform;
    pointer-events: none;
  }

  .hero-inner {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--content-shell-max);
    height: 100svh;
    margin: 0 auto;
    padding: 2rem;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding-bottom: 8svh;
  }

  .hero-corner {
    position: absolute;
    font-family: var(--font);
    font-size: var(--text-body);
    text-transform: uppercase;
    letter-spacing: 0.45em;
    color: var(--jr-ljusgul);
    opacity: 0.5;
    line-height: 1;
  }

  .hero-corner--tl {
    top: var(--space-lg);
    left: 2rem;
    pointer-events: none;
  }
  .hero-corner--tr {
    position: fixed;
    z-index: 60;
    top: calc(
      var(--space-lg) - ((var(--hamburger-size) - (var(--text-ui) * 1.5)) / 2) -
        (var(--text-ui) * 0.375)
    );
    right: max(2rem, calc(50vw - 600px + 2rem));
  }
  .hero-corner--bl {
    bottom: var(--space-lg);
    left: 2rem;
    padding: 0;
    color: var(--jr-gold);
    background: transparent;
    border: none;
    backdrop-filter: none;
  }
  .hero-corner--br {
    bottom: var(--space-lg);
    right: var(--space-lg);
  }

  /* ── HAMBURGER ───────────────────────────────────────────────── */
  .hamburger {
    position: fixed;
    z-index: 60;
    background: transparent;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: none;
    border-radius: 50%;
    box-shadow: none;
    cursor: pointer;
    padding: 0;
    width: var(--hamburger-size);
    height: var(--hamburger-size);
    color: var(--jr-ljusgul);
    transition:
      opacity 0.25s ease,
      border-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  :global(body.menu-open) .hamburger {
    background: color-mix(in srgb, var(--jr-svart) 20%, transparent);
    box-shadow: none;
  }

  .hamburger:hover {
    opacity: 0.8;
  }

  .hamburger-bar {
    display: block;
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18px;
    height: 1.5px;
    background: currentColor;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }

  .hamburger-bar--top {
    transform: translate(-50%, calc(-50% - 2.5px));
  }
  .hamburger-bar--bot {
    transform: translate(-50%, calc(-50% + 2.5px));
  }

  .hamburger.is-open .hamburger-bar--top {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .hamburger.is-open .hamburger-bar--bot {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  .hamburger.is-open {
    opacity: 0.5;
  }

  .hamburger.is-open:hover {
    opacity: 0.8;
  }

  /* ── MENU DIALOG ─────────────────────────────────────────────── */
  .menu-dialog {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background-color: var(--jr-gron);
    color: var(--jr-ljusgul);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(0.25rem);
    transition:
      opacity 0.08s linear,
      transform 0.12s cubic-bezier(0.2, 0.8, 0.2, 1),
      visibility 0s linear 0.12s;
