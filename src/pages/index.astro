---
import Base from "../layouts/Base.astro";
import DevNav from "../components/DevNav.astro";
import LogoMark from "../components/LogoMark.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Järna Rosteri">
  <DevNav active="IDX" />

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-photo" style={`background-image: url('${base}/assets/images/hero-no-text.png')`}></div>
    <div class="hero-veil"></div>

    <header class="hero-header">
      <span class="label">Järna Rosteri</span>
      <span class="label">Est. 2013</span>
    </header>

    <div class="hero-body">
      <h1 class="hero-title">JÄRNA<br />ROSTERI</h1>
      <p class="hero-sub">Specialkaffe från källa till kopp</p>
    </div>

    <div class="hero-scroll-hint" aria-hidden="true">↓</div>

    <div class="hero-info">
      <p>Tja Robin. Här kommer lite olike förslag och riktningar. Du kan bläddra igenom alla 14 olika varianter uppe i högra hörnet. Testa gärna på datorn då inget är mobilanpassat ännu. Som sagt detta är bara förslag på olika riktningar. Man kan sedan plocka och välja olika sektioner från olika sidor och sätta ihop något.</p>
    </div>
  </section>

  <!-- ─── TEXT SECTION ─────────────────────────────────────────── -->
  <section class="text-block text-block--dark">
    <div class="text-inner">
      <div class="text-col-label">
        <span class="eyebrow">Om oss</span>
      </div>
      <div class="text-col-body">
        <p class="body-copy">
          Vi grundades med en enkel övertygelse: att varje kopp kaffe bär på
          ett ursprung värt att berätta om. Våra rostningar är långsamma,
          varsamma och alltid spårbara — från odlarens hand till din mugg.
        </p>
        <p class="body-copy">
          Järna Rosteri arbetar uteslutande med ekologiskt odlat och
          KRAV-certifierat kaffe. Vi väljer bönor som uppfyller
          Fairtrade-standarder för rättvis handel och betalar priser som
          faktiskt gör skillnad för odlaren.
        </p>
        <span class="sig">— Robin Wilson, Medgrundare</span>
      </div>
    </div>
  </section>

  <!-- ─── IMAGE + CAPTION ──────────────────────────────────────── -->
  <section class="image-block">
    <div class="image-block-photo" style={`background-image: url('${base}/assets/images/view.png')`}></div>
    <div class="image-block-caption">
      <span class="eyebrow eyebrow--light">Ursprung</span>
      <p>
        I Hondurasbergens svalka, på över 1 400 meters höjd, odlas bönorna
        långsamt under skuggan av inhemska träd. Det är den höjden som ger
        kaffet sin täthet — och odlaren kontrollen över sitt arbete.
      </p>
    </div>
    <div class="image-block-scrim"></div>
  </section>

  <!-- ─── PRODUCTS ─────────────────────────────────────────────── -->
  <section class="products">
    <div class="products-header">
      <span class="eyebrow eyebrow--ochre">Vårt kaffe</span>
    </div>

    <div class="products-grid">
      <article class="product-card">
        <div class="product-card-body">
          <span class="product-num">01</span>
          <span class="product-origin">Honduras</span>
          <h3 class="product-name">Franchese</h3>
          <p class="product-note">
            Mjuk och balanserad med toner av mörk choklad och nötter.
            Lämplig för espresso och bryggkaffe.
          </p>
          <span class="product-cert">Fairtrade · Ekologisk</span>
        </div>
      </article>

      <article class="product-card">
        <div class="product-card-body">
          <span class="product-num">02</span>
          <span class="product-origin">Etiopien</span>
          <h3 class="product-name">Grande</h3>
          <p class="product-note">
            Blommig och fruktig karaktär med citrusaccenter och lång
            eftersmak. Idealisk för pour-over.
          </p>
          <span class="product-cert">KRAV · Ekologisk</span>
        </div>
      </article>

      <article class="product-card">
        <div class="product-card-body">
          <span class="product-num">03</span>
          <span class="product-origin">Colombia</span>
          <h3 class="product-name">Mezzo</h3>
          <p class="product-note">
            Röd frukt, karamell och en hint av körsbär. Fungerar lika bra
            svart som med mjölk.
          </p>
          <span class="product-cert">Demeter · Biodynamisk</span>
        </div>
      </article>

      <article class="product-card">
        <div class="product-card-body">
          <span class="product-num">04</span>
          <span class="product-origin">Kenya</span>
          <h3 class="product-name">Poabs Esp</h3>
          <p class="product-note">
            Intensiv och fruktig med tydlig syra och toner av vinbär.
            Utmärkt som espresso och i mjölkdrycker.
          </p>
          <span class="product-cert">Fairtrade · Ekologisk</span>
        </div>
      </article>

      <article class="product-card">
        <div class="product-card-body">
          <span class="product-num">05</span>
          <span class="product-origin">Guatemala</span>
          <h3 class="product-name">Poabs Bry</h3>
          <p class="product-note">
            Fyllig kropp med inslag av mörka bär och varm krydda. Perfekt
            för bryggkaffe och pour-over.
          </p>
          <span class="product-cert">KRAV · Ekologisk</span>
        </div>
      </article>

      <article class="product-card">
        <div class="product-card-body">
          <span class="product-num">06</span>
          <span class="product-origin">Peru</span>
          <h3 class="product-name">Conejo</h3>
          <p class="product-note">
            Len och jordnära med lätt nötighet och subtil sötma. En
            tillgänglig och välbalanserad blandning.
          </p>
          <span class="product-cert">Demeter · Biodynamisk</span>
        </div>
      </article>
    </div>

    <div class="products-bags">
      <div class="bags-img" style={`background-image: url('${base}/assets/images/allbags.png')`}></div>
    </div>
  </section>

  <!-- ─── FOOTER ───────────────────────────────────────────────── -->
  <footer class="footer">
    <div class="footer-watermark" aria-hidden="true">
      <LogoMark color="var(--jr-ljusgul)" width="80vw" />
    </div>

    <span class="footer-copy-vert" aria-hidden="true">© 2026 Järna Rosteri</span>

    <div class="footer-inner">
      <div class="footer-rule-row">
        <span class="footer-rule"></span>
        <span class="footer-est">Est. 2013</span>
      </div>

      <div class="footer-fields">
        <div class="footer-field">
          <span class="footer-field-label">Kontakt</span>
          <a href="mailto:info@jarnarosteri.se" class="footer-link">info@jarnarosteri.se</a>
          <a href="tel:+46708401365" class="footer-link">070-840 13 65</a>
        </div>
        <div class="footer-field">
          <span class="footer-field-label">Adress</span>
          <span class="footer-link footer-link--muted">Maskinvägen 5</span>
          <span class="footer-link footer-link--muted">153 30 Järna</span>
        </div>
        <div class="footer-field">
          <span class="footer-field-label">Socialt</span>
          <a
            href="https://www.instagram.com/jarnarosteri"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-link">Instagram</a>
        </div>
      </div>
    </div>
  </footer>
</Base>

<style>
  :root {
    --page-inset: clamp(var(--space-lg), 5vw, 4rem);
    --page-max: 1080px;
  }

  /* ── HERO ─────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: 600px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: var(--jr-gron);
  }

  .hero-photo {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 30%;
  }

  .hero-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 30%,
      rgba(0, 0, 0, 0.25) 60%,
      rgba(0, 0, 0, 0.55) 100%
    );
  }

  .hero-header {
    position: absolute;
    top: var(--page-inset);
    left: var(--page-inset);
    right: var(--page-inset);
    display: flex;
    justify-content: space-between;
    z-index: 2;
  }

  .label {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--jr-ljusgul);
    opacity: 0.75;
  }

  .hero-body {
    position: relative;
    z-index: 2;
    padding: var(--page-inset);
    padding-bottom: clamp(var(--space-xl), 5vw, 4rem);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 10vw, 9rem);
    color: var(--jr-ljusgul);
    line-height: 0.88;
    letter-spacing: -0.02em;
    margin-bottom: clamp(0.75rem, 1.5vw, 1.25rem);
  }

  .hero-sub {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--jr-ljusgul);
    opacity: 0.6;
  }

  .hero-info {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    background: rgba(0, 0, 0, 0.65);
    color: var(--jr-vit);
    font-family: var(--font);
    font-size: var(--text-body);
    line-height: 1.7;
    padding: var(--space-lg);
    max-width: 480px;
    width: calc(100% - 4rem);
    backdrop-filter: blur(4px);
    text-align: center;
  }

  .hero-scroll-hint {
    position: absolute;
    bottom: var(--page-inset);
    right: var(--page-inset);
    z-index: 2;
    font-family: var(--font);
    font-size: var(--text-ui);
    color: var(--jr-ljusgul);
    opacity: 0.4;
  }

  /* ── TEXT BLOCK ───────────────────────────────────────────────── */
  .text-block {
    width: 100%;
    padding: clamp(5rem, 10vw, 9rem) 0;
  }

  .text-block--dark {
    background: var(--jr-gron);
  }

  .text-inner {
    max-width: var(--page-max);
    margin: 0 auto;
    padding-inline: var(--page-inset);
    display: grid;
    grid-template-columns: 1fr 1.618fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .text-col-label {
    padding-top: 0.2em;
  }

  .eyebrow {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    display: block;
  }

  .text-block--dark .eyebrow {
    color: var(--jr-ljusgul);
    opacity: 0.5;
  }

  .text-col-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .body-copy {
    font-family: var(--font);
    font-size: var(--text-body);
    line-height: 1.8;
    color: var(--jr-ljusgul);
  }

  .sig {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--jr-ljusgul);
    opacity: 0.4;
  }

  /* ── IMAGE BLOCK ─────────────────────────────────────────────── */
  .image-block {
    position: relative;
    width: 100%;
    height: 100svh;
    overflow: hidden;
  }

  .image-block-photo {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center center;
  }

  .image-block-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.28) 0%,
      transparent 45%
    );
    pointer-events: none;
  }

  .image-block-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-xl) var(--page-inset);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 640px;
    z-index: 1;
  }

  .eyebrow--light {
    color: var(--jr-ljusgul);
    opacity: 0.6;
  }

  .image-block-caption p {
    font-family: var(--font);
    font-size: var(--text-ui);
    line-height: var(--line-height);
    text-transform: uppercase;
    max-width: 50ch;
    color: var(--jr-vit);
    opacity: 0.85;
  }

  /* ── PRODUCTS ────────────────────────────────────────────────── */
  .products {
    background: var(--jr-ocra);
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(3rem, 6vw, 5rem);
    overflow: hidden;
  }

  .products-header {
    max-width: var(--page-max);
    margin: 0 auto clamp(3rem, 5vw, 4.5rem);
    padding-inline: var(--page-inset);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .eyebrow--ochre {
    color: var(--jr-morkrost);
    opacity: 0.6;
  }

  .products-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: var(--jr-morkrost);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .products-grid {
    max-width: var(--page-max);
    margin: 0 auto;
    padding-inline: var(--page-inset);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    align-items: start;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    border-top: 1px solid rgba(58, 40, 23, 0.2);
    padding-top: var(--space-lg);
  }

  .product-card-body {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-bottom: clamp(2rem, 4vw, 3rem);
  }

  .product-num {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.1em;
    color: var(--jr-morkrost);
    opacity: 0.3;
    margin-bottom: var(--space-sm);
    display: block;
  }

  .product-origin {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--jr-morkrost);
    opacity: 0.5;
  }

  .product-name {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.2vw, 1.75rem);
    color: var(--jr-morkrost);
    letter-spacing: -0.01em;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .product-note {
    font-family: var(--font);
    font-size: var(--text-body);
    line-height: 1.7;
    color: var(--jr-morkrost);
    opacity: 0.75;
  }

  .product-cert {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--jr-morkrost);
    opacity: 0.4;
    margin-top: 0.5rem;
  }

  .products-bags {
    margin-top: clamp(3rem, 6vw, 5rem);
  }

  .bags-img {
    width: 100%;
    height: clamp(240px, 35vw, 500px);
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
  }

  /* ── FOOTER ──────────────────────────────────────────────────── */
  .footer {
    background: var(--jr-gron);
    color: var(--jr-ljusgul);
    position: relative;
    overflow: hidden;
  }

  .footer-watermark {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0.05;
  }

  .footer-copy-vert {
    position: absolute;
    left: var(--page-inset);
    bottom: var(--page-inset);
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--jr-ljusgul);
    opacity: 0.25;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .footer-inner {
    position: relative;
    z-index: 1;
    max-width: var(--page-max);
    margin: 0 auto;
    padding: clamp(5rem, 10vw, 8rem) var(--page-inset) clamp(3rem, 6vw, 5rem);
  }

  .footer-rule-row {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: clamp(3rem, 7vw, 6rem);
  }

  .footer-rule {
    flex: 1;
    height: 1px;
    background: rgba(239, 214, 120, 0.18);
    display: block;
  }

  .footer-est {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--jr-ljusgul);
    opacity: 0.35;
    white-space: nowrap;
  }

  .footer-fields {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    align-items: start;
  }

  .footer-field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .footer-field-label {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--jr-ljusgul);
    opacity: 0.4;
    margin-bottom: 0.6rem;
  }

  .footer-link {
    font-family: var(--font);
    font-size: var(--text-body);
    color: var(--jr-ljusgul);
    text-decoration: none;
    opacity: 0.7;
    line-height: 1.7;
    transition: opacity 0.15s ease;
  }

  a.footer-link:hover {
    opacity: 1;
  }

  .footer-link--muted {
    opacity: 0.35;
    font-size: var(--text-ui);
  }

  /* ── RESPONSIVE ──────────────────────────────────────────────── */
  @media (max-width: 800px) {
    .text-inner {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .products-grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-fields {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-lg);
    }

    .footer-copy-vert {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .footer-fields {
      grid-template-columns: 1fr;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
