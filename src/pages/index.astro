</style>

<script>
  const hamburger = document.querySelector(".hamburger") as HTMLButtonElement;
  const dialog = document.getElementById("site-menu") as HTMLDialogElement;
  const menuTransitionMs = 120;
  let closeTimer: number | undefined;
  let scrollLockY = 0;
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  requestAnimationFrame(() => {
    document.body.classList.add("is-loaded");
  });

  function syncScrolledState() {
    document.body.classList.toggle("is-scrolled", window.scrollY > 0);
  }

  syncScrolledState();
  window.addEventListener("scroll", syncScrolledState, { passive: true });

  function syncMenuState(isOpen: boolean) {
    document.documentElement.classList.toggle("menu-open", isOpen);
    document.body.classList.toggle("menu-open", isOpen);
    if (isOpen) {
      scrollLockY = window.scrollY;
      document.body.style.top = `-${scrollLockY}px`;
    } else {
      document.body.style.top = "";
      window.scrollTo(0, scrollLockY);
    }
    hamburger.setAttribute("aria-expanded", String(isOpen));
    hamburger.classList.toggle("is-open", isOpen);
  }

  function openMenu() {
    window.clearTimeout(closeTimer);
    if (!dialog.open) dialog.show();
    void dialog.offsetWidth;
    dialog.classList.add("is-visible");
    syncMenuState(true);
  }

  function closeMenu() {
    if (!dialog.open) {
      syncMenuState(false);
      return;
    }

    dialog.classList.remove("is-visible");
    syncMenuState(false);
    closeTimer = window.setTimeout(() => {
      if (dialog.open) dialog.close();
    }, menuTransitionMs);
  }

  hamburger.addEventListener("click", () => {
    dialog.open ? closeMenu() : openMenu();
  });

  dialog.addEventListener("close", () => {
    window.clearTimeout(closeTimer);
    dialog.classList.remove("is-visible");
    syncMenuState(false);
  });

  dialog.addEventListener("click", (event) => {
    if (event.target === dialog) closeMenu();
  });

  dialog.querySelectorAll(".menu-link").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  if (!reduceMotion.matches) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.22, rootMargin: "0px 0px -8% 0px" },
    );

    document
      .querySelectorAll("[data-reveal]:not([data-reveal='hero'])")
      .forEach((section) => {
        observer.observe(section);
      });
  } else {
    document.querySelectorAll("[data-reveal]").forEach((section) => {
      section.classList.add("is-visible");
    });
  }
</script>
