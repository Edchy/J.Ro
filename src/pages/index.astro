            ></path>
            <path
              d="M640 1138 c0 -282 -4 -447 -11 -473 -29 -107 -121 -160 -212 -121 -72 30 -96 81 -104 214 l-6 92 -55 0 -54 0 4 -112 c5 -132 23 -183 87 -246 113 -109 319 -88 408 42 56 83 57 84 60 579 l4 457 -60 0 -61 0 0 -432z"
            ></path>
            <path
              d="M8410 1001 l0 -571 60 0 60 0 0 255 0 255 60 0 61 0 125 -257 c68 -141 126 -259 129 -261 5 -5 94 29 100 39 3 4 -47 114 -110 245 -112 231 -119 253 -82 254 21 0 107 96 128 143 20 43 23 69 24 157 0 120 -17 171 -77 232 -67 66 -92 73 -295 76 l-183 4 0 -571z m367 433 c42 -31 64 -77 70 -143 11 -119 -37 -219 -115 -241 -20 -5 -74 -10 -119 -10 l-83 0 0 211 0 211 109 -4 c93 -2 114 -6 138 -24z"
