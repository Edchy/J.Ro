            ></path>
            <path
              d="M6182 1258 c-11 -35 -72 -225 -136 -424 -110 -343 -122 -384 -111 -384 2 0 27 -9 54 -20 l50 -19 43 132 43 132 154 0 155 0 39 -131 40 -132 58 20 c33 11 59 21 59 21 0 1 -62 196 -138 432 l-139 430 -76 3 -76 3 -19 -63z m158 -285 l58 -188 -115 -3 c-64 -1 -118 -1 -120 2 -3 3 21 91 53 195 31 105 59 189 62 186 3 -2 31 -89 62 -192z"
            ></path>
            <path
              d="M12660 1270 l0 -49 123 -3 122 -3 3 -393 2 -393 58 3 57 3 3 393 2 392 115 0 115 0 0 50 0 50 -300 0 -300 0 0 -50z"
            ></path>
            <path
              d="M14160 875 l0 -445 275 0 275 0 0 55 0 55 -215 0 -215 0 0 155 0 155 181 0 180 0 -3 53 -3 52 -177 3 -178 2 0 130 0 130 215 0 215 0 0 50 0 50 -275 0 -275 0 0 -445z"
            ></path>
            <path
              d="M15582 878 l3 -443 58 -3 57 -3 0 191 0 190 83 0 82 0 109 -195 c60 -107 113 -195 118 -195 15 0 98 51 94 58 -2 4 -49 82 -105 175 -55 92 -101 169 -101 171 0 2 20 16 45 30 74 44 125 135 125 225 0 98 -42 170 -124 214 -37 20 -59 22 -244 25 l-202 4 2 -444z m373 321 c47 -23 70 -64 70 -124 0 -58 -18 -91 -69 -129 -23 -18 -45 -22 -142 -24 l-114 -4 0 144 c0 80 3 148 8 152 12 13 216 0 247 -15z"
            ></path>
            <path
              d="M17100 1270 l0 -49 58 -3 57 -3 3 -337 2 -338 -60 0 -60 0 0 -55 0 -55 180 0 180 0 0 55 0 55 -60 0 -60 0 2 338 3 337 58 3 57 3 0 49 0 50 -180 0 -180 0 0 -50z"
            ></path>
          </g>
        </svg>
      </span>
      <button
        class="hamburger hero-corner hero-corner--tr"
        aria-label="Öppna meny"
        aria-expanded="false"
        aria-controls="site-menu"
      >
        <span class="hamburger-bar hamburger-bar--top"></span>
        <span class="hamburger-bar hamburger-bar--bot"></span>
      </button>

      <dialog id="site-menu" class="menu-dialog">
        <nav class="menu-nav">
          <a href="mailto:info@jarnarosteri.se" class="menu-link"
            >info@jarnarosteri.se</a
          >
          <a href="tel:+46708401365" class="menu-link">070-840 13 65</a>
          <a
            href="https://www.instagram.com/jarnarosteri"
            target="_blank"
            rel="noopener noreferrer"
            class="menu-link">INSTAGRAM ↗</a
          >
        </nav>
      </dialog>
      <div class="hero-logo-wrap">
        <LogoMark
          color="var(--jr-morkrost)"
          width="clamp(18rem, 80vw, 42rem)"
        />
      </div>
      <span class="hero-corner hero-corner--bl"
        >Ekologiskt <span class="hero-dot">·</span> Biodynamiskt <span
          class="hero-dot">·</span
        > Kaffe</span
      >
    </div>
  </section>
  <!-- ─── PACKAGES ─────────────────────────────────────────────── -->
  <section class="packages-section" data-reveal>
    <img
      src={`${base}/assets/images/coffee-packages.png`}
      alt="Kaffepåsar från Järna Rosteri"
      class="packages-section-image"
    />
    <p class="packages-section-caption">
      <span class="section-kicker section-kicker--warm">Aktuell påse</span>
      POAB'S ESP. En av våra espresso sorter. Indisk arabica och robusta.
    </p>
  </section>

  <!-- ─── ABOUT ────────────────────────────────────────────────── -->
  <section
    id="about"
    class="about-section"
    style={`background-image: url('${base}/assets/images/collage.avif')`}
    aria-label="Kollage från Järna Rosteri"
    data-reveal
  >
    <div class="about-section-copy">
      <p class="section-kicker">Om rosteriet</p>
      <p>
        Hos oss handlar kaffe om mer än bara rostning – det är ett hantverk
        grundat i relationer, hållbarhet och passion. Vi samarbetar direkt med
        Demeter-certifierade kaffegårdar, där varje böna odlas i samklang med
        naturen och bär på en berättelse om balans, respekt och mänskliga möten.
        Vårt personliga engagemang genomsyrar hela processen, från ursprung till
        kopp.
      </p>
    </div>
    <div
      class="about-section-image"
      style={`background-image: url('${base}/assets/images/collage.avif')`}
      aria-hidden="true"
    >
    </div>
  </section>

  <!-- ─── CONTACT ──────────────────────────────────────────────── -->
  <section id="contact" class="contact-section" data-reveal>
    <div class="contact-section-inner">
      <div class="contact-section-copy">
        <p class="section-kicker section-kicker--contact">Kontakt</p>
        <p class="contact-section-text">
          För priser, sortiment och frågor om kaffe till café, butik eller
          restaurang, hör av er.
        </p>
      </div>

      <div class="contact-section-links" aria-label="Kontaktvägar">
        <a href="mailto:info@jarnarosteri.se" class="contact-section-link">
          <span class="contact-section-link-label">E-post</span>
          <span class="contact-section-link-value">info@jarnarosteri.se</span>
        </a>
        <a href="tel:+46708401365" class="contact-section-link">
          <span class="contact-section-link-label">Telefon</span>
          <span class="contact-section-link-value">070-840 13 65</span>
        </a>
        <a
          href="https://www.instagram.com/jarnarosteri"
          target="_blank"
          rel="noopener noreferrer"
          class="contact-section-link"
        >
          <span class="contact-section-link-label">Instagram</span>
          <span class="contact-section-link-value">@jarnarosteri ↗</span>
        </a>
        <p class="contact-section-address">Maskinvägen 5, 153 30 Järna</p>
      </div>
    </div>
  </section>

  <!-- ─── PRODUCTS ─────────────────────────────────────────────── -->
  <section class="products" data-reveal>
    <!-- <div class="product-row">
      <div class="product-info">
        <div class="product-name-row">
          <h3 class="product-name">POAB´S ESP</h3>
        </div>
        <p class="product-desc">
          Demeter-certifierad espresso med indisk arabica och robusta. Fyllig,
          kryddig och chokladig med låg syra och lång eftersmak.
        </p>
        <div class="product-tags">
          <span class="tag">Honduras</span>
          <span class="tag">Hela bönor</span>
          <span class="tag">450 gram</span>
        </div>
      </div>
      <div class="product-image-col">
        <div
          class="product-image"
          style={`background-image: url('${base}/assets/images/frontbag.png');`}
        >
        </div>
      </div>
    </div> -->

    <div class="product-row product-row--reverse">
      <div class="product-info">
        <div class="product-name-row">
          <h3 class="product-name">POAB´S ESP</h3>
        </div>
        <p class="product-desc">
          Demeter-certifierad espresso med indisk arabica och robusta. Fyllig,
          kryddig och chokladig med låg syra och lång eftersmak.
        </p>
        <div class="product-tags">
          <span class="tag">Honduras</span>
          <span class="tag">Hela bönor</span>
          <span class="tag">450 gram</span>
        </div>
      </div>
      <div class="product-image-col">
        <div
          class="product-image"
          style={`background-image: url('${base}/assets/images/frontbag.png');`}
        >
        </div>
      </div>
    </div>
  </section>

  <!-- ─── IMAGE + CAPTION ──────────────────────────────────────── -->
  <section class="image-block" data-reveal>
    <div
      class="image-block-photo"
      style={`background-image: url('${base}/assets/images/hero-no-text.avif')`}
    >
    </div>
    <div class="image-block-caption">
      <div class="image-block-caption-inner">
        <p>För mer från våra resor,<br /> rosteriet & vardagen</p>
        <a
          href="https://www.instagram.com/jarnarosteri"
          target="_blank"
          rel="noopener noreferrer"
          class="image-block-instagram"
        >
          <span>INSTAGRAM</span>
          <span class="image-block-instagram-arrow" aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
    <div class="image-block-scrim"></div>
  </section>

  <!-- ─── FOOTER ───────────────────────────────────────────────── -->
  <footer class="index-footer">
    <div class="index-footer-inner">
      <img
        src={`${base}/assets/images/jarna-rosteri-wordmark.svg`}
        alt="Järna Rosteri"
        class="index-footer-wordmark"
      />
      <nav class="index-footer-nav">
        <a href="#contact" class="index-footer-link">Kontakt</a>
        <a href="#about" class="index-footer-link">Om oss</a>
      </nav>
    </div>
  </footer>
</Base>

<style>
  :root {
    --page-inset: var(--space-lg);
    --page-max: 1080px;
    --content-shell-max: 1400px;
    --content-line-start: max(
      var(--page-inset),
      calc((100vw - var(--content-shell-max)) / 2 + var(--page-inset))
    );
    --header-height: 4.5rem;
    --hamburger-size: 2.35rem;
  }

  :global(body) {
    background: var(--jr-vit);
  }

  :global(html.menu-open),
  :global(body.menu-open) {
    overflow: hidden;
  }

  :global(body.menu-open) {
    position: fixed;
    inset: 0;
    width: 100%;
    touch-action: none;
  }

  /* ── HERO ─────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    background: var(--jr-ocra);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-inner {
    position: relative;
    width: 100%;
    max-width: var(--content-shell-max);
    height: 100svh;
    margin: 0 auto;
    padding: 1rem;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding-bottom: 8svh;
  }


  .hero::after {
    content: "";
    position: absolute;
    inset: auto 0 0;
    height: clamp(8rem, 18vw, 14rem);
    background:
      radial-gradient(
        ellipse at 18% 110%,
        color-mix(in srgb, var(--jr-ljusgul) 44%, transparent) 0%,
        transparent 68%
      ),
      linear-gradient(
        180deg,
        transparent 0%,
        color-mix(in srgb, var(--jr-morkrost) 10%, transparent) 100%
      );
    opacity: 0.65;
    pointer-events: none;
  }

  .hero-corner {
    position: absolute;
    font-family: var(--font);
    font-size: var(--text-body);
    text-transform: uppercase;
    letter-spacing: 0.45em;
    color: var(--jr-morkrost);
    opacity: 0.5;
    line-height: 1;
  }

  .hero-corner--tl {
    top: var(--space-lg);
    left: 1rem;
    pointer-events: none;
  }
  .hero-corner--tr {
    position: fixed;
    z-index: 60;
    top: calc(
      var(--space-lg) - ((var(--hamburger-size) - (var(--text-ui) * 1.5)) / 2) -
        (var(--text-ui) * 0.375)
    );
    right: max(1rem, calc(50vw - 700px + 1rem));
  }
  .hero-corner--bl {
    bottom: var(--space-lg);
    left: 1rem;
  }
  .hero-corner--br {
    bottom: var(--space-lg);
    right: var(--space-lg);
  }

  /* ── HAMBURGER ───────────────────────────────────────────────── */
  .hamburger {
    position: fixed;
    z-index: 60;
    background: transparent;
    border: none;
    border-radius: 999px;
    box-shadow: none;
    cursor: pointer;
    padding: 0;
    width: var(--hamburger-size);
    height: var(--hamburger-size);
    color: var(--jr-morkrost);
    transition:
      opacity 0.25s ease,
      background-color 0.25s ease,
      box-shadow 0.25s ease;
  }

  :global(body.is-scrolled) .hamburger,
  :global(body.menu-open) .hamburger {
    background: var(--jr-ljusgul);
    box-shadow: 0 0.2rem 0.7rem
      color-mix(in srgb, var(--jr-morkrost) 18%, transparent);
  }

  .hamburger:hover {
    opacity: 0.8;
  }

  .hamburger-bar {
    display: block;
    position: absolute;
    left: 50%;
    top: 50%;
    width: 18px;
    height: 1.5px;
    background: currentColor;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }

  .hamburger-bar--top {
    transform: translate(-50%, calc(-50% - 2.5px));
  }
  .hamburger-bar--bot {
    transform: translate(-50%, calc(-50% + 2.5px));
  }

  .hamburger.is-open .hamburger-bar--top {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .hamburger.is-open .hamburger-bar--bot {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  .hamburger.is-open {
    opacity: 0.5;
  }

  .hamburger.is-open:hover {
    opacity: 0.8;
  }

  /* ── MENU DIALOG ─────────────────────────────────────────────── */
  .menu-dialog {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    margin: 0;
    padding: 0;
    border: none;
    background-color: var(--jr-ocra);
    color: var(--jr-vit);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(0.25rem);
    transition:
      opacity 0.08s linear,
      transform 0.12s cubic-bezier(0.2, 0.8, 0.2, 1),
      visibility 0s linear 0.12s;
  }

  .menu-dialog[open] {
    visibility: visible;
  }

  .menu-dialog::backdrop {
    background: transparent;
  }

  .menu-dialog.is-visible {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
    transition:
      opacity 0.08s linear,
      transform 0.1s cubic-bezier(0.2, 0.8, 0.2, 1),
      visibility 0s linear 0s;
  }

  .menu-nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    opacity: 0;
    transform: translateY(0.25rem);
    transition:
      opacity 0.08s linear,
      transform 0.12s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .menu-dialog.is-visible .menu-nav {
    opacity: 1;
    transform: translateY(0);
  }

  .menu-link {
    font-family: var(--font);
    font-size: clamp(1.15rem, 3vw, 2rem);
    text-transform: none;
    letter-spacing: 0.08em;
    color: inherit;
    text-decoration: none;
    opacity: 0.8;
    line-height: 1.1;
  }

  .menu-link:hover {
    opacity: 1;
  }

  .hero-wordmark {
    height: calc(var(--text-ui) * 1.5);
    width: auto;
    display: block;
    color: var(--jr-morkrost);
    transform: translateY(-25%);
  }

  .hero-logo-wrap {
    display: flex;
    position: relative;
    z-index: 1;
  }

  .hero-logo-wrap :global(svg) {
    transition:
      transform 1.1s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero:hover .hero-logo-wrap :global(svg) {
    transform: translateY(-0.2rem);
    filter: drop-shadow(0 1rem 1.8rem rgba(58, 40, 23, 0.08));
  }

  @media (max-width: 550px) {
    .hero-logo-wrap {
      margin-left: 0;
    }

    .hero-corner--bl {
      letter-spacing: 0.18em;
    }

    .hero-dot {
      display: none;
    }

    .hero-corner--tl,
    .hero-corner--tr {
      font-size: calc(var(--text-body) * 0.75);
    }

    .hero-wordmark {
      height: calc(var(--text-ui) * 1.5 * 0.75);
    }
  }

  .section-kicker {
    display: inline-block;
    margin-bottom: 1rem;
    font-family: var(--font);
    font-size: var(--text-body);
    text-transform: uppercase;
    letter-spacing: 0.28em;
    color: var(--jr-svart);
    opacity: 0.42;
  }

  .section-kicker--warm {
    display: block;
    color: var(--jr-morkrost);
    opacity: 0.5;
  }

  .section-kicker--contact {
    color: inherit;
    opacity: 0.5;
  }

  /* ── ABOUT SECTION ──────────────────────────────────────────── */
  .about-section {
    width: 100%;
    min-height: 100svh;
    padding: clamp(4rem, 10vw, 7rem) var(--page-inset) clamp(2rem, 6vw, 4rem);
    background-color: var(--jr-vit);
    background-size: min(72vw, 56rem);
    background-origin: content-box;
    background-position: top right;
    background-repeat: no-repeat;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
  }

  .about-section-copy {
    width: min(100%, 64ch);
  }

  .about-section-image {
    display: none;
  }

  .about-section-copy p {
    font-family: var(--font);
    font-size: var(--text-body);
    line-height: 1.75;
    color: var(--jr-svart);
    opacity: 0.9;
    text-align: left;
  }

  .about-section-copy p:not(.section-kicker) {
    padding-bottom: var(--space-xl);
  }

  @media (min-width: 1000px) {
    .about-section {
      padding-top: clamp(2rem, 5vw, 3.5rem);
    }

    .about-section-copy {
      padding-top: 1rem;
    }
  }

  .about-section-copy > p:last-child::selection {
    background: color-mix(in srgb, var(--jr-ljusgul) 72%, white);
    color: var(--jr-morkrost);
  }

  @media (min-width: 551px) and (max-width: 900px) {
    .about-section {
      background-image: none !important;
      display: grid;
      grid-template-columns: 1fr;
      align-items: start;
      justify-items: start;
      position: relative;
      padding-bottom: 0;
    }

    .about-section-copy {
      width: 100%;
      position: relative;
      z-index: 1;
    }

    .about-section-image {
      display: block;
      width: calc(100% + var(--page-inset) * 2);
      margin-left: calc(-1 * var(--page-inset));
      aspect-ratio: 16 / 9;
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      margin-top: calc(-1 * var(--space-xl));
    }
  }

  @media (max-width: 550px) {
    .about-section {
      min-height: auto;
      padding: clamp(3rem, 8vw, 4.5rem) var(--page-inset) 0;
