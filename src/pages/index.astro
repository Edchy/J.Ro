---
import Base from "../layouts/Base.astro";
import DevNav from "../components/DevNav.astro";
import LogoMark from "../components/LogoMark.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title="Järna Rosteri">
  <DevNav active="IDX" />

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="hero" data-reveal="hero">
    <div class="hero-inner">
      <span class="hero-corner hero-corner--tl">
        <svg
          class="hero-wordmark"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 1770 190"
          aria-label="Järna Rosteri"
          role="img"
        >
          <g
            transform="translate(0,190) scale(0.1,-0.1)"
            fill="currentColor"
            stroke="none"
          >
            <path
              d="M1755 1566 c-50 -50 -39 -157 18 -184 73 -35 140 62 104 151 -25 60 -80 75 -122 33z"
            ></path>
            <path
              d="M2073 1575 c-28 -20 -46 -75 -38 -119 18 -95 120 -112 153 -24 37 96 -42 194 -115 143z"
            ></path>
            <path
