---
import Base from "../layouts/Base.astro";
import DevNav from "../components/DevNav.astro";
import LogoMark from "../components/LogoMark.astro";
---

<Base title="Järna Røsteri — V8">
  <DevNav active="V8" />

  <!-- ─── HERO ─────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-meta">
      <span class="meta-item">Lorem, Sverige</span>
      <span class="meta-item">Est. —</span>
      <span class="meta-item">Ipsum Dolor</span>
    </div>

    <div class="hero-logo">
      <LogoMark color="var(--jr-svart)" width="clamp(14rem, 42vw, 42rem)" />
    </div>

    <div class="hero-foot">
      <span class="foot-label">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</span>
    </div>
  </section>

  <!-- ─── IMAGE SECTION ────────────────────────────────────────────────── -->
  <section class="image-full">
    <div class="image-full__inner" style="background-image: url('/assets/images/view.png');"></div>
    <div class="image-full__caption">
      <span class="caption-index">01</span>
      <span class="caption-text">Lorem — Ipsum</span>
    </div>
  </section>

  <!-- ─── TEXT / ABOUT SECTION ─────────────────────────────────────────── -->
  <section class="text-section">
    <div class="text-section__grid">
      <div class="text-col text-col--label">
        <span class="section-label">Lorem Ipsum</span>
      </div>
      <div class="text-col text-col--body">
        <p class="body-text">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod
          tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim
          veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip.
        </p>
        <p class="body-text">
          Duis aute irure dolor in reprehenderit in voluptate velit esse cillum
          dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non
          proident, sunt in culpa qui officia deserunt mollit anim id est laborum.
        </p>
        <div class="text-sig">
          <span class="sig-text">— Lorem Ipsum</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SECOND IMAGE ─────────────────────────────────────────────────── -->
  <section class="image-split">
    <div
      class="image-split__panel image-split__panel--left"
      style="background-image: url('/assets/images/honduras.png'); background-position: center 35%;"
    ></div>
    <div class="image-split__panel image-split__panel--right">
      <div class="split-text">
        <span class="split-label">Lorem Ipsum</span>
        <p class="split-body">
          Sed ut perspiciatis unde omnis iste natus error sit voluptatem
          accusantium doloremque laudantium, totam rem aperiam eaque ipsa.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── PRODUCTS SECTION ─────────────────────────────────────────────── -->
  <section class="products">
    <div class="products__header">
      <span class="products-label">Lorem Ipsum</span>
      <span class="products-count">3 Dolor</span>
    </div>

    <div class="product-row">
      <div class="product-image-col">
        <div class="product-image" style="background-image: url('/assets/images/frontbag.png');"></div>
      </div>
      <div class="product-info">
        <div class="product-name-row">
          <span class="product-name">Lorem Ipsum</span>
        </div>
        <p class="product-desc">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do
          eiusmod tempor incididunt ut labore et dolore magna aliqua ut enim.
        </p>
        <div class="product-tags">
          <span class="tag">Lorem</span>
          <span class="tag">Ipsum</span>
          <span class="tag">Dolor</span>
        </div>
      </div>
    </div>

    <div class="product-row product-row--reverse">
      <div class="product-image-col">
        <div class="product-image" style="background-image: url('/assets/images/coffee-packages.png'); background-size: 70%; background-color: var(--jr-mezzo);"></div>
      </div>
      <div class="product-info">
        <div class="product-name-row">
          <span class="product-name">Amet Consec</span>
        </div>
        <p class="product-desc">
          Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris
          nisi ut aliquip ex ea commodo consequat duis aute irure dolor.
        </p>
        <div class="product-tags">
          <span class="tag">Adipiscing</span>
          <span class="tag">Elit</span>
          <span class="tag">Sed Do</span>
        </div>
      </div>
    </div>

    <div class="product-row">
      <div class="product-image-col">
        <div class="product-image product-image--bags" style="background-image: url('/assets/images/allbags.png');"></div>
      </div>
      <div class="product-info">
        <div class="product-name-row">
          <span class="product-name">Tempor</span>
        </div>
        <p class="product-desc">
          Excepteur sint occaecat cupidatat non proident, sunt in culpa qui
          officia deserunt mollit anim id est laborum et dolore magna.
        </p>
        <div class="product-tags">
          <span class="tag">Incididunt</span>
          <span class="tag">Labore</span>
          <span class="tag">Magna</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FOOTER ───────────────────────────────────────────────────────── -->
  <footer class="footer">
    <div class="footer__logo">
      <LogoMark color="var(--jr-vit)" width="clamp(10rem, 28vw, 28rem)" />
    </div>
    <div class="footer__grid">
      <div class="footer-col">
        <span class="footer-col-label">Lorem</span>
        <p>lorem@ipsum.se</p>
        <p>070-000 00 00</p>
      </div>
      <div class="footer-col">
        <span class="footer-col-label">Ipsum</span>
        <p>Dolor sit 5</p>
        <p>153 30 Amet</p>
      </div>
      <div class="footer-col">
        <span class="footer-col-label">Consectetur</span>
        <p>Lorem</p>
        <p>Ipsum</p>
        <p>Dolor</p>
      </div>
      <div class="footer-col footer-col--right">
        <span class="footer-col-label">© 2026</span>
        <p>Lorem Ipsum AB</p>
        <p>Dolor sit amet</p>
      </div>
    </div>
  </footer>
</Base>

<style>
  /* ─── GLOBAL RESET FOR THIS PAGE ─────────────────────────────────────── */
  :global(body) {
    background: var(--jr-vit);
    color: var(--jr-svart);
  }

  /* ─── HERO ────────────────────────────────────────────────────────────── */
  .hero {
    min-height: 100svh;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: var(--space-lg);
    background: var(--jr-vit);
    color: var(--jr-svart);
    overflow: hidden;
  }

  .hero-meta {
    display: flex;
    gap: var(--space-lg);
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.45;
    padding-top: 0.25rem;
    animation: fadeUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    animation: fadeUp 1.1s 0.15s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .hero-foot {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-bottom: 0.5rem;
    animation: fadeUp 1.1s 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .foot-label {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
  }

  /* ─── IMAGE FULL ─────────────────────────────────────────────────────── */
  .image-full {
    width: 100%;
    height: 100svh;
    position: relative;
    background: var(--jr-morkrost);
  }

  .image-full__inner {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 25%;
  }

  .image-full__caption {
    position: absolute;
    bottom: var(--space-lg);
    left: var(--space-lg);
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    color: var(--jr-vit);
    z-index: 1;
  }

  .caption-index {
    font-family: var(--font);
    font-size: var(--text-ui);
    opacity: 0.5;
    letter-spacing: 0.12em;
  }

  .caption-text {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.8;
  }

  /* ─── TEXT SECTION ───────────────────────────────────────────────────── */
  .text-section {
    background: var(--jr-vit);
    padding: calc(var(--space-xl) * 2) var(--space-lg);
  }

  .text-section__grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-xl);
    align-items: start;
  }

  .text-col--label {
    padding-top: 0.2rem;
  }

  .section-label {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    opacity: 0.4;
  }

  .body-text {
    font-family: var(--font);
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    line-height: 1.65;
    color: var(--jr-svart);
    margin-bottom: var(--space-lg);
  }

  .body-text:last-of-type {
    margin-bottom: var(--space-xl);
  }

  .text-sig {
    display: flex;
    align-items: center;
  }

  .sig-text {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.1em;
    opacity: 0.4;
    font-style: italic;
  }

  /* ─── IMAGE SPLIT ────────────────────────────────────────────────────── */
  .image-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 100svh;
    background: var(--jr-svart);
  }

  .image-split__panel {
    position: relative;
    overflow: hidden;
  }

  .image-split__panel--left {
    background-size: cover;
  }

  .image-split__panel--right {
    display: flex;
    align-items: flex-end;
    padding: var(--space-xl) var(--space-xl) calc(var(--space-xl) * 1.5);
    background: var(--jr-morkrost);
  }

  .split-text {
    width: 100%;
    color: var(--jr-vit);
  }

  .split-label {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 4vw, 4rem);
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: var(--space-lg);
    color: var(--jr-ljusgul);
  }

  .split-body {
    font-family: var(--font);
    font-size: var(--text-body);
    line-height: 1.65;
    opacity: 0.7;
    max-width: 38ch;
    margin-bottom: var(--space-xl);
  }

  /* ─── PRODUCTS ───────────────────────────────────────────────────────── */
  .products {
    background: var(--jr-vit);
    padding: calc(var(--space-xl) * 2) var(--space-lg);
  }

  .products__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    max-width: 1100px;
    margin: 0 auto calc(var(--space-xl) * 1.5);
  }

  .products-label {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    opacity: 0.4;
  }

  .products-count {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.25;
  }

  .product-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 1100px;
    margin: 0 auto calc(var(--space-xl) * 2);
    overflow: hidden;
  }

  .product-row--reverse {
    direction: rtl;
  }

  .product-row--reverse > * {
    direction: ltr;
  }

  .product-image-col {
    overflow: hidden;
  }

  .product-image {
    width: 100%;
    height: 44vh;
    background-size: contain;
    background-position: center;
    background-repeat: no-repeat;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .product-row:hover .product-image {
    transform: scale(1.03);
  }

  .product-image--bags {
    background-size: cover;
    background-position: center;
  }

  .product-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--space-xl) calc(var(--space-xl) * 1.2);
    gap: var(--space-lg);
  }

  .product-name-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-lg);
  }

  .product-index {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.1em;
    opacity: 0.25;
  }

  .product-name {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3.5vw, 3rem);
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--jr-svart);
  }

  .product-desc {
    font-family: var(--font);
    font-size: var(--text-body);
    line-height: 1.65;
    color: var(--jr-svart);
    opacity: 0.65;
    max-width: 42ch;
  }

  .product-tags {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.35rem 0.7rem;
    border: 1px solid rgba(0, 0, 0, 0.18);
    color: var(--jr-svart);
    opacity: 0.6;
  }

  /* ─── FOOTER ─────────────────────────────────────────────────────────── */
  .footer {
    background: var(--jr-svart);
    color: var(--jr-vit);
    padding: calc(var(--space-xl) * 2) var(--space-lg) var(--space-xl);
  }

  .footer__logo {
    margin-bottom: calc(var(--space-xl) * 2);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    padding-top: var(--space-xl);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col--right {
    text-align: right;
  }

  .footer-col-label {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    opacity: 0.35;
    margin-bottom: 0.5rem;
  }

  .footer-col p {
    font-family: var(--font);
    font-size: var(--text-ui);
    line-height: 1.7;
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ─── ANIMATIONS ─────────────────────────────────────────────────────── */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(1.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ─── RESPONSIVE ─────────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .text-section__grid {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .image-split {
      grid-template-columns: 1fr;
      height: auto;
    }

    .image-split__panel--left {
      height: 60svh;
    }

    .image-split__panel--right {
      padding: var(--space-xl) var(--space-lg);
    }

    .product-row,
    .product-row--reverse {
      grid-template-columns: 1fr;
      direction: ltr;
    }

    .product-info {
      padding: var(--space-xl) 0;
    }

    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }

    .footer-col--right {
      text-align: left;
    }

    .hero-meta {
      flex-wrap: wrap;
      gap: var(--space-sm);
    }
  }

  @media (max-width: 480px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
