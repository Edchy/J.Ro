---
import Base from "../layouts/Base.astro";
import DevNav from "../components/DevNav.astro";
import LogoMark from "../components/LogoMark.astro";
---

<Base title="Järna Rosteri — V3">
  <DevNav active="V3" />

  <!-- ░░ HERO ░░ -->
  <section class="hero">
    <div class="hero-eyebrow">
      <span>Järna Rosteri</span>
      <span>Est. 2019</span>
    </div>
    <LogoMark color="var(--jr-ocra)" width="clamp(14rem, 50vw, 42rem)" />
    <p class="hero-sub">Från böna till kopp, med omsorg om ursprunget</p>
  </section>

  <!-- ░░ IMAGE SECTION ░░ -->
  <section class="image-section">
    <img src="/assets/images/hero-no-text.png" alt="Kaffeplantage" class="image-section-img" />
    <p class="image-caption">Rostade med omsorg — Järna, Sverige.</p>
  </section>

  <!-- ░░ TEXT / ABOUT SECTION ░░ -->
  <section class="text-section">
    <p class="text-lead">
      Vi rostar kaffe på liten skala, med full kontroll från grön böna till
      färdig kopp.
    </p>
    <p class="text-body">
      Järna Røsteri grundades ur en övertygelse om att kaffe förtjänar samma
      uppmärksamhet som vin eller hantverk. Vi arbetar direkt med odlare vi
      litar på, betalar rättvisa priser och rostar varje parti med precision
      och respekt för råvaran.
    </p>
  </section>

  <!-- ░░ PRODUCTS SECTION ░░ -->
  <section class="products-section">
    <header class="products-header">
      <span class="section-label section-label--light">Sortiment</span>
      <span class="section-index section-label--light">— 03</span>
    </header>

    <ul class="products-list">
      <li class="product-item">
        <div class="product-meta">
          <span class="product-number">001</span>
          <span class="product-origin">Honduras</span>
        </div>
        <div class="product-center">
          <h3 class="product-name">Poabs Brygg</h3>
          <p class="product-notes">Apelsin · Karamell · Ljus stekpanna</p>
        </div>
        <div class="product-right">
          <span class="product-weight">250 g</span>
          <span class="product-color-dot" style="background: var(--jr-poabs-bry);"></span>
        </div>
      </li>

      <li class="product-item">
        <div class="product-meta">
          <span class="product-number">002</span>
          <span class="product-origin">Etiopien</span>
        </div>
        <div class="product-center">
          <h3 class="product-name">Mezzo</h3>
          <p class="product-notes">Blåbär · Jasmin · Medium</p>
        </div>
        <div class="product-right">
          <span class="product-weight">250 g</span>
          <span class="product-color-dot" style="background: var(--jr-mezzo);"></span>
        </div>
      </li>

      <li class="product-item">
        <div class="product-meta">
          <span class="product-number">003</span>
          <span class="product-origin">Colombia</span>
        </div>
        <div class="product-center">
          <h3 class="product-name">Conejo</h3>
          <p class="product-notes">Druva · Kakao · Medium-mörk</p>
        </div>
        <div class="product-right">
          <span class="product-weight">250 g</span>
          <span class="product-color-dot" style="background: var(--jr-conejo);"></span>
        </div>
      </li>

      <li class="product-item">
        <div class="product-meta">
          <span class="product-number">004</span>
          <span class="product-origin">Guatemala</span>
        </div>
        <div class="product-center">
          <h3 class="product-name">Grande Espresso</h3>
          <p class="product-notes">Mörk choklad · Rökt · Mörk</p>
        </div>
        <div class="product-right">
          <span class="product-weight">250 g</span>
          <span class="product-color-dot" style="background: var(--jr-grande);"></span>
        </div>
      </li>

      <li class="product-item">
        <div class="product-meta">
          <span class="product-number">005</span>
          <span class="product-origin">Brasilien</span>
        </div>
        <div class="product-center">
          <h3 class="product-name">Franchese</h3>
          <p class="product-notes">Nöt · Smör · Ljus-medium</p>
        </div>
        <div class="product-right">
          <span class="product-weight">250 g</span>
          <span class="product-color-dot" style="background: var(--jr-franchese);"></span>
        </div>
      </li>

      <li class="product-item product-item--featured">
        <div class="product-meta">
          <span class="product-number">006</span>
          <span class="product-origin">Blandning</span>
        </div>
        <div class="product-center">
          <h3 class="product-name">Poabs Espresso</h3>
          <p class="product-notes">Citrus · Honung · Intensiv</p>
        </div>
        <div class="product-right">
          <span class="product-weight">250 g</span>
          <span class="product-color-dot" style="background: var(--jr-poabs-esp);"></span>
        </div>
      </li>
    </ul>

    <div class="products-image-strip">
      <img src="/assets/images/allbags.png" alt="Kaffepaket" class="products-img" />
    </div>
  </section>

  <!-- ░░ FOOTER ░░ -->
  <footer class="footer">
    <div class="footer-top">
      <div class="footer-wordmark">
        <span class="footer-logo-line">J.R&#248;</span>
      </div>
      <div class="footer-info">
        <div class="footer-info-col">
          <span class="footer-info-label">Kontakt</span>
          <a href="mailto:info@jarnarosteri.se">info@jarnarosteri.se</a>
          <a href="tel:+46708401365">070-840 13 65</a>
        </div>
        <div class="footer-info-col">
          <span class="footer-info-label">Besök oss</span>
          <span>Maskinvägen 5</span>
          <span>153 30 Järna</span>
        </div>
        <div class="footer-info-col">
          <span class="footer-info-label">Öppettider</span>
          <span>Mån–Fre 08–17</span>
          <span>Lör 10–14</span>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span class="footer-copy">© 2026 Järna Røsteri AB</span>
      <span class="footer-cert">Demeter-certifierad · KRAV-godkänd</span>
    </div>
  </footer>
</Base>

<style>
  /* ── HERO ───────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    background: var(--jr-gron);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-lg);
    padding-bottom: var(--space-xl);
    gap: var(--space-lg);
  }

  .hero-eyebrow {
    position: absolute;
    top: var(--space-lg);
    left: var(--space-lg);
    right: var(--space-lg);
    display: flex;
    justify-content: space-between;
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--jr-ocra);
    opacity: 0.5;
  }

  .hero-sub {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--jr-ocra);
    opacity: 0.5;
  }

  /* ── IMAGE SECTION ──────────────────────────────────────── */
  .image-section {
    position: relative;
    height: 70vh;
  }

  .image-section-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }

  .image-caption {
    position: absolute;
    bottom: var(--space-lg);
    right: var(--space-lg);
    font-family: var(--font);
    font-size: var(--text-ui);
    color: var(--jr-vit);
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* ── TEXT / ABOUT ───────────────────────────────────────── */
  .text-section {
    background: var(--jr-brun);
    padding: clamp(6rem, 14vh, 14rem) var(--space-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .text-lead {
    font-family: var(--font);
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1.35;
    color: var(--jr-ljusgul);
    max-width: 28ch;
    text-align: center;
  }

  .text-body {
    font-family: var(--font);
    font-size: var(--text-body);
    line-height: 1.75;
    color: var(--jr-vit);
    opacity: 0.55;
    max-width: 48ch;
    text-align: center;
  }

  .section-label--light {
    color: var(--jr-ocra);
  }

  /* ── PRODUCTS ───────────────────────────────────────────── */
  .products-section {
    background: var(--jr-morkrost);
    padding: clamp(4rem, 10vh, 10rem) var(--space-lg);
  }

  .products-header {
    max-width: 1200px;
    margin: 0 auto 4rem;
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
  }

  .products-list {
    list-style: none;
    max-width: 1200px;
    margin: 0 auto;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .product-item {
    display: grid;
    grid-template-columns: 8rem 1fr auto;
    align-items: center;
    gap: var(--space-lg);
    padding: clamp(1.25rem, 2.5vh, 2rem) 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    transition: background 0.2s ease;
  }

  .product-item:hover {
    background: rgba(255, 255, 255, 0.03);
    margin: 0 calc(-1 * var(--space-lg));
    padding-left: var(--space-lg);
    padding-right: var(--space-lg);
  }

  .product-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .product-number {
    font-family: var(--font);
    font-size: var(--text-ui);
    color: var(--jr-ocra);
    opacity: 0.4;
    letter-spacing: 0.08em;
  }

  .product-origin {
    font-family: var(--font);
    font-size: var(--text-ui);
    color: var(--jr-vit);
    opacity: 0.4;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .product-center {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .product-name {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.6rem);
    color: var(--jr-ljusgul);
    font-weight: var(--weight-regular);
    letter-spacing: var(--letter-spacing-tight);
  }

  .product-notes {
    font-family: var(--font);
    font-size: var(--text-ui);
    color: var(--jr-vit);
    opacity: 0.4;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .product-right {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .product-weight {
    font-family: var(--font);
    font-size: var(--text-ui);
    color: var(--jr-vit);
    opacity: 0.3;
    letter-spacing: 0.08em;
  }

  .product-color-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .products-image-strip {
    max-width: 1200px;
    margin: 5rem auto 0;
    overflow: hidden;
    height: clamp(16rem, 35vh, 32rem);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .products-img {
    height: 100%;
    width: 100%;
    object-fit: contain;
    object-position: center;
  }

  /* ── FOOTER ─────────────────────────────────────────────── */
  .footer {
    background: var(--jr-svart);
    color: var(--jr-vit);
    padding: clamp(4rem, 10vh, 10rem) var(--space-lg) var(--space-xl);
  }

  .footer-top {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--space-xl);
    padding-bottom: clamp(4rem, 8vh, 8rem);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    align-items: end;
  }

  .footer-wordmark {
    line-height: 1;
  }

  .footer-logo-line {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 7rem);
    color: var(--jr-vit);
    letter-spacing: var(--letter-spacing-tight);
    opacity: 0.9;
  }

  .footer-info {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    align-items: end;
  }

  .footer-info-col {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-info-label {
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--jr-ocra);
    opacity: 0.5;
    margin-bottom: 0.5rem;
  }

  .footer-info-col span,
  .footer-info-col a {
    font-family: var(--font);
    font-size: var(--text-ui);
    color: var(--jr-vit);
    opacity: 0.6;
    text-decoration: none;
    line-height: 1.7;
  }

  .footer-info-col a:hover {
    opacity: 1;
  }

  .footer-bottom {
    max-width: 1200px;
    margin: var(--space-lg) auto 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-copy,
  .footer-cert {
    font-family: var(--font);
    font-size: 8px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--jr-vit);
    opacity: 0.25;
  }

  /* ── RESPONSIVE ─────────────────────────────────────────── */
  @media (max-width: 768px) {
    .image-section {
      height: 55vw;
    }

    .text-section {
      padding-left: var(--space-lg);
      padding-right: var(--space-lg);
    }

    .product-item {
      grid-template-columns: 5rem 1fr auto;
      gap: var(--space-sm);
    }

    .footer-top {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .footer-info {
      grid-template-columns: 1fr 1fr;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }
  }

  @media (max-width: 480px) {
    .footer-info {
      grid-template-columns: 1fr;
    }
  }
</style>
