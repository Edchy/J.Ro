---
import Base from "../layouts/Base.astro";
import DevNav from "../components/DevNav.astro";
import ColorGrid from "../components/ColorGrid.astro";
import LoremSection from "../components/LoremSection.astro";
import ImageSection from "../components/ImageSection.astro";
import Footer from "../components/Footer.astro";
import LogoMark from "../components/LogoMark.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Järna Rosteri — V9">
  <DevNav active="V9" />

  <!-- HERO V9 — Editorial split layout -->
  <section class="hero-v9">
    <!-- Background texture layer -->
    <div class="hero-bg"></div>

    <!-- Top rule + metadata bar -->
    <header class="hero-meta">
      <span class="meta-tag">Est. Lorem, Ipsum</span>
      <span class="meta-divider">—</span>
      <span class="meta-tag">59°N 17°E</span>
      <span class="meta-divider">—</span>
      <span class="meta-tag">Dolor sit</span>
    </header>

    <!-- Main content: split wordmark / descriptor -->
    <div class="hero-body">
      <div class="hero-left">
        <div class="wordmark-stack">
          <LogoMark color="var(--jr-brun)" width="clamp(14rem, 30vw, 28rem)" />
        </div>
        <div class="hero-sub">
          <div class="sub-rule"></div>
          <p class="sub-text">Lorem ipsum<br />Dolor sit amet</p>
        </div>
      </div>

      <div class="hero-rule-vert"></div>

      <div class="hero-right">
        <div class="provenance-block">
          <span class="prov-label">Lorem</span>
          <ul class="prov-list">
            <li>Ipsum — Consectetur</li>
            <li>Dolor — Adipiscing</li>
            <li>Amet — Eiusmod</li>
          </ul>
        </div>
        <div class="provenance-block">
          <span class="prov-label">Ipsum</span>
          <ul class="prov-list">
            <li>Labore</li>
            <li>Tempor &amp; Magna</li>
            <li>Aliqua-veniam</li>
          </ul>
        </div>
        <div class="scroll-indicator">
          <span class="scroll-line"></span>
          <span class="scroll-label">Lorem</span>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <footer class="hero-foot">
      <span class="foot-mark">L.I</span>
      <span class="foot-year">MMXXVI</span>
    </footer>
  </section>

  <ImageSection
    image={`${base}/assets/images/frontbag.png`}
    bgSize="20%"
    bg="var(--jr-ocra)"
  />

  <LoremSection bg="var(--jr-orostat)" textColor="var(--jr-ocra)" />

  <ColorGrid
    colors={[
      "var(--jr-gron)",
      "var(--jr-orostat)",
      "var(--jr-brun)",
      "var(--jr-morkrost)",
    ]}
    iconColors={[
      "var(--jr-orostat)",
      "var(--jr-gron)",
      "var(--jr-ocra)",
      "var(--jr-brun)",
    ]}
    columns={2}
    rows={2}
    image={`${base}/assets/images/frontbag.png`}
  />

  <ImageSection
    image={`${base}/assets/images/hero-no-text.png`}
    bgPosition="center 20%"
    caption="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua veniam."
    captionPosition="bottom-left"
  />

  <Footer
    bg="var(--jr-gron)"
    textColor="var(--jr-ocra)"
    accentColor="var(--jr-ocra)"
  />
</Base>

<style>
  /* ── Hero V9 shell ── */
  .hero-v9 {
    width: 100%;
    height: 100svh;
    min-height: 600px;
    background-color: var(--jr-morkrost);
    position: relative;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: var(--space-lg);
    overflow: hidden;
  }

  /* Subtle grain texture via SVG filter */
  .hero-v9::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(
        ellipse 80% 60% at 70% 110%,
        rgba(107, 80, 45, 0.18) 0%,
        transparent 65%
      ),
      radial-gradient(
        ellipse 40% 40% at 10% -10%,
        rgba(239, 214, 120, 0.06) 0%,
        transparent 60%
      );
    pointer-events: none;
  }

  /* ── Meta bar ── */
  .hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    animation: fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.1s;
  }

  .meta-tag {
    font-family: var(--font);
    font-size: var(--text-ui);
    color: var(--jr-brun);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.7;
  }

  .meta-divider {
    color: var(--jr-brun);
    opacity: 0.3;
    font-family: var(--font);
    font-size: var(--text-ui);
  }

  /* ── Body split ── */
  .hero-body {
    display: flex;
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
    padding: clamp(2rem, 5vh, 4rem) 0;
  }

  /* ── Left: wordmark ── */
  .hero-left {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(1.5rem, 3vw, 2.5rem);
    animation: fade-up 1s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.2s;
  }

  .wordmark-stack {
    display: flex;
    flex-direction: column;
    line-height: 0.88;
  }

  .wordmark-line {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 10.5vw, 9.5rem);
    color: var(--jr-brun);
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .hero-sub {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
  }

  .sub-rule {
    width: clamp(2rem, 6vw, 5rem);
    height: 1px;
    background: var(--jr-brun);
    opacity: 0.45;
    flex-shrink: 0;
  }

  .sub-text {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--jr-brun);
    opacity: 0.6;
    line-height: var(--line-height);
  }

  /* ── Vertical divider ── */
  .hero-rule-vert {
    width: 1px;
    align-self: stretch;
    background: var(--jr-brun);
    opacity: 0.15;
    flex-shrink: 0;
    animation: fade-up 1s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.35s;
  }

  /* ── Right: provenance data ── */
  .hero-right {
    flex: 0 0 clamp(180px, 25vw, 280px);
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 4vh, 2.5rem);
    animation: fade-up 1s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.45s;
  }

  .provenance-block {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .prov-label {
    font-family: var(--font);
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--jr-brun);
    opacity: 0.5;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid rgba(107, 80, 45, 0.2);
  }

  .prov-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .prov-list li {
    font-family: var(--font);
    font-size: var(--text-ui);
    color: var(--jr-brun);
    opacity: 0.55;
    letter-spacing: 0.04em;
    line-height: var(--line-height);
  }

  /* ── Scroll indicator ── */
  .scroll-indicator {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
    margin-top: auto;
    padding-top: 1rem;
  }

  .scroll-line {
    display: block;
    width: 1px;
    height: 2.5rem;
    background: var(--jr-brun);
    opacity: 0.3;
    animation: scroll-pulse 2.5s ease-in-out infinite;
  }

  .scroll-label {
    font-family: var(--font);
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--jr-brun);
    opacity: 0.35;
    writing-mode: vertical-lr;
    transform: rotate(180deg);
  }

  /* ── Footer bar ── */
  .hero-foot {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    animation: fade-up 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.6s;
  }

  .foot-mark {
    font-family: var(--font-display);
    font-size: clamp(0.9rem, 1.5vw, 1.1rem);
    color: var(--jr-brun);
    opacity: 0.4;
    letter-spacing: -0.03em;
  }

  .foot-year {
    font-family: var(--font);
    font-size: var(--text-ui);
    color: var(--jr-brun);
    opacity: 0.25;
    letter-spacing: 0.15em;
  }

  /* ── Animations ── */
  @keyframes fade-up {
    from {
      opacity: 0;
      transform: translateY(1.2rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scroll-pulse {
    0%, 100% { opacity: 0.15; transform: scaleY(0.7); transform-origin: top; }
    50%       { opacity: 0.4;  transform: scaleY(1);   transform-origin: top; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-meta,
    .hero-left,
    .hero-rule-vert,
    .hero-right,
    .hero-foot {
      animation: none;
    }
    .scroll-line {
      animation: none;
    }
  }

  /* ── Responsive: collapse right panel on small screens ── */
  @media (max-width: 640px) {
    .hero-v9 {
      padding: var(--space-lg) var(--space-lg) var(--space-lg);
    }

    .hero-body {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-lg);
    }

    .hero-rule-vert {
      display: none;
    }

    .hero-right {
      flex: unset;
      width: 100%;
      flex-direction: row;
      flex-wrap: wrap;
      gap: var(--space-lg);
    }

    .scroll-indicator {
      display: none;
    }

    .wordmark-line {
      font-size: clamp(2.8rem, 14vw, 5rem);
    }

  }
</style>
