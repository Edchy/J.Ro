---
import Base from "../layouts/Base.astro";
import DevNav from "../components/DevNav.astro";
import FooterX from "../components/FooterX.astro";
---

<Base title="Järna Rosteri">
  <DevNav active="V12" />

  <!-- 01 · HERO -->
  <section class="hero">
    <div class="hero-img"></div>
    <div class="hero-vignette"></div>
    <span class="hero-eyebrow">Järna Rosteri</span>
    <span class="hero-year">Est. 2013</span>
    <div class="hero-content">
      <h1>JÄRNA<br />ROSTERI</h1>
      <p class="hero-sub">Något · Kaffe · Något</p>
    </div>
  </section>

  <!-- 12 · FOOTER -->
  <FooterX bg="var(--jr-ocra)" textColor="var(--jr-ljusgul)" />
</Base>

<style>
  /* ─── HERO ───────────────────────────────────────────────────── */
  .hero {
    position: relative;
    width: 100%;
    height: 100svh;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    background-image: url("/assets/images/view.png");
    background-size: cover;
    background-position: center 30%;
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 40%,
      rgba(0, 0, 0, 0.52) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: var(--space-lg);
    padding-bottom: clamp(var(--space-lg), 3.5vw, 2.5rem);
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .hero-content h1 {
    font-family: var(--font-display);
    font-size: clamp(3.8rem, 11vw, 10rem);
    color: var(--jr-vit);
    line-height: 0.88;
    letter-spacing: -0.025em;
    margin-bottom: 0;
  }

  .hero-sub {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--jr-vit);
  }

  .hero-eyebrow,
  .hero-year {
    position: absolute;
    z-index: 2;
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--jr-vit);
  }

  .hero-eyebrow {
    top: var(--space-lg);
    left: var(--space-lg);
  }

  .hero-year {
    top: var(--space-lg);
    right: var(--space-lg);
  }
</style>
