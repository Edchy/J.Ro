---
import Base from "../layouts/Base.astro";
import DevNav from "../components/DevNav.astro";
import LogoMark from "../components/LogoMark.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Järna Rosteri — V1">
  <DevNav active="V1" />

  <!-- ═══ HERO ═══ -->
  <section class="hero">
    <div class="hero-eyebrow">
      <span>Lorem Ipsum</span>
      <span>Est. 2019</span>
    </div>
    <div class="hero-logo-wrap">
      <LogoMark color="var(--jr-morkrost)" width="clamp(20rem, 90vw, 72rem)" />
    </div>
    <p class="hero-sub">Lorem ipsum dolor sit amet, consectetur adipiscing</p>
  </section>

  <!-- ═══ IMAGE SECTION ═══ -->
  <section class="image-section">
    <div class="image-section-photo">
      <img src={`${base}/assets/images/honduras.png`} alt="Bergslandskap, Honduras" />
    </div>
    <div class="image-section-text">
      <blockquote class="image-section-quote">
        Lorem ipsum dolor sit amet. Consectetur adipiscing elit.
      </blockquote>
      <p class="image-section-caption">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod
        tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim
        veniam quis nostrud exercitation ullamco laboris nisi ut aliquip.
      </p>
    </div>
  </section>

  <!-- ═══ ABOUT / TEXT SECTION ═══ -->
  <section class="about">
    <div class="about-inner">
      <div class="about-left">
        <span class="about-rotated-label">Lorem</span>
      </div>
      <div class="about-right">
        <div class="about-body">
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do
            eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim
            veniam quis nostrud exercitation ullamco laboris nisi ut aliquip.
          </p>
          <p>
            Duis aute irure dolor in reprehenderit in voluptate velit esse
            cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat
            cupidatat non proident sunt in culpa qui officia deserunt mollit.
          </p>
        </div>
        <div class="about-credentials">
          <span>Lorem ipsum</span>
          <span>Dolor</span>
          <span>Amet</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ LANDSCAPE BREAK ═══ -->
  <div class="landscape-break">
    <img src={`${base}/assets/images/view.png`} alt="Utsikt över kaffeodling" />
    <div class="landscape-caption">
      <span>Lorem — Ipsum Dolor</span>
      <span>1 600 m</span>
    </div>
  </div>

  <!-- ═══ PRODUCTS ═══ -->
  <section class="products">
    <p class="products-label">Lorem ipsum</p>

    <div class="products-grid">
      <article class="product-card" style="background: var(--jr-franchese); color: var(--jr-vit);">
        <span class="product-origin">Lorem</span>
        <h3 class="product-name">Franchese</h3>
        <p class="product-notes">Lorem ipsum dolor sit amet, toner adipiscing jasmin et fläder.</p>
      </article>

      <article class="product-card" style="background: var(--jr-poabs-esp); color: var(--jr-svart);">
        <span class="product-origin">Ipsum</span>
        <h3 class="product-name">Poabs Esp</h3>
        <p class="product-notes">Dolor sit amet consectetur adipiscing sed eiusmod tempor magna.</p>
      </article>

      <article class="product-card" style="background: var(--jr-grande); color: var(--jr-vit);">
        <span class="product-origin">Dolor</span>
        <h3 class="product-name">Grande</h3>
        <p class="product-notes">Ut enim ad minim veniam nostrud exercitation ullamco aliquip.</p>
      </article>

      <article class="product-card" style="background: var(--jr-conejo); color: var(--jr-vit);">
        <span class="product-origin">Amet</span>
        <h3 class="product-name">Conejo</h3>
        <p class="product-notes">Duis aute irure dolor reprehenderit voluptate nougat cillum.</p>
      </article>

      <article class="product-card" style="background: var(--jr-poabs-bry); color: var(--jr-vit);">
        <span class="product-origin">Consectetur</span>
        <h3 class="product-name">Poabs Bry</h3>
        <p class="product-notes">Excepteur sint occaecat cupidatat non proident deserunt mollit.</p>
      </article>

      <article class="product-card" style="background: var(--jr-mezzo); color: var(--jr-vit);">
        <span class="product-origin">Adipiscing</span>
        <h3 class="product-name">Mezzo</h3>
        <p class="product-notes">Sed ut perspiciatis unde omnis natus voluptatem honung kola.</p>
      </article>
    </div>
  </section>

  <!-- ═══ FOOTER ═══ -->
  <footer class="footer">
    <div class="footer-top">
      <LogoMark color="var(--jr-vit)" width="clamp(12rem, 40vw, 32rem)" />
      <div class="footer-rule"></div>
    </div>
    <div class="footer-mid">
      <div class="footer-col">
        <span class="footer-col-label">Kontakt</span>
        <p>info@jarnarosteri.se</p>
        <p>070-840 13 65</p>
      </div>
      <div class="footer-col">
        <span class="footer-col-label">Besök</span>
        <p>Maskinvägen 5</p>
        <p>153 30 Järna</p>
      </div>
      <div class="footer-col">
        <span class="footer-col-label">Följ oss</span>
        <a class="footer-instagram" href="https://www.instagram.com/jarnarosteri" target="_blank" rel="noopener">Instagram</a>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Järna Rosteri</span>
    </div>
  </footer>
</Base>

<style>
  /* ─── HERO ─────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    background: var(--jr-ocra);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-lg);
    padding-bottom: var(--space-xl);
    gap: var(--space-lg);
    overflow-x: clip;
  }

  .hero-eyebrow {
    position: absolute;
    top: var(--space-lg);
    left: var(--space-lg);
    right: var(--space-lg);
    display: flex;
    justify-content: space-between;
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--jr-morkrost);
    opacity: 0.5;
  }

  .hero-logo-wrap {
    margin-left: -8vw;
  }

  .hero-sub {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--jr-morkrost);
    opacity: 0.5;
  }

  /* ─── IMAGE SECTION ────────────────────────────────────── */
  .image-section {
    display: grid;
    grid-template-columns: 61.8% 1fr;
    min-height: 80vh;
    background: var(--jr-vit);
  }

  .image-section-photo {
    overflow: hidden;
  }

  .image-section-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: right center;
    display: block;
  }

  .image-section-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: var(--space-lg);
    padding: var(--space-xl);
    background: var(--jr-vit);
    color: var(--jr-svart);
  }

  .image-section-quote {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-style: normal;
    line-height: 1.4;
    color: var(--jr-morkrost);
    border: none;
    padding: 0;
  }

  .image-section-caption {
    font-family: var(--font);
    font-size: var(--text-body);
    line-height: 1.75;
    color: var(--jr-svart);
    opacity: 0.6;
  }

  /* ─── ABOUT ─────────────────────────────────────────────── */
  .about {
    background: var(--jr-vit);
    color: var(--jr-svart);
    padding: clamp(4rem, 10vw, 10rem) var(--space-xl);
  }

  .about-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-xl);
    max-width: 1200px;
    margin: 0 auto;
  }

  .about-left {
    display: flex;
    align-items: flex-start;
    padding-top: 0.3rem;
  }

  .about-rotated-label {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--jr-svart);
    opacity: 0.45;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  .about-right {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .about-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    max-width: 60ch;
  }

  .about-body p {
    font-family: var(--font);
    font-size: var(--text-body);
    line-height: 1.75;
    color: var(--jr-svart);
    opacity: 0.8;
  }

  .about-credentials {
    display: flex;
    gap: var(--space-lg);
    border-top: 1px solid rgba(0, 0, 0, 0.12);
    padding-top: var(--space-lg);
  }

  .about-credentials span {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--jr-svart);
    opacity: 0.4;
  }

  /* ─── LANDSCAPE BREAK ───────────────────────────────────── */
  .landscape-break {
    position: relative;
    width: 100%;
    height: 60vh;
    overflow: hidden;
    background: var(--jr-morkrost);
  }

  .landscape-break img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 50%;
    opacity: 0.7;
  }

  .landscape-caption {
    position: absolute;
    bottom: var(--space-lg);
    right: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
  }

  .landscape-caption span {
    font-family: var(--font);
    font-size: var(--text-ui);
    color: var(--jr-vit);
    opacity: 0.5;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ─── PRODUCTS ──────────────────────────────────────────── */
  .products {
    background: var(--jr-brun);
    padding: clamp(3rem, 6vw, 6rem) var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .products-label {
    font-family: var(--font);
    font-size: var(--text-ui);
    color: var(--jr-vit);
    opacity: 0.3;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .products-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: var(--space-lg);
    padding: var(--space-xl) var(--space-lg);
    min-height: 320px;
  }

  .product-origin {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.55;
  }

  .product-name {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1;
    letter-spacing: var(--letter-spacing-tight);
    flex: 1;
    display: flex;
    align-items: flex-end;
  }

  .product-notes {
    font-family: var(--font);
    font-size: var(--text-ui);
    line-height: 1.6;
    opacity: 0.6;
  }

  /* ─── FOOTER ────────────────────────────────────────────── */
  .footer {
    background: var(--jr-brun);
    color: var(--jr-vit);
    text-transform: uppercase;
    padding: clamp(4rem, 8vw, 8rem) var(--space-xl) var(--space-xl);
  }

  .footer-top {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-bottom: clamp(3rem, 6vw, 6rem);
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
  }


  .footer-rule {
    width: 100%;
    height: 1px;
    background: rgba(255, 255, 255, 0.12);
  }

  .footer-mid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
    max-width: 1200px;
    margin: 0 auto var(--space-xl);
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col-label {
    font-family: var(--font-display);
    font-size: var(--text-ui);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--jr-ocra);
    margin-bottom: 0.5rem;
  }

  .footer-col p {
    font-family: var(--font);
    font-size: var(--text-ui);
    line-height: var(--line-height);
    opacity: 0.5;
  }

  .footer-instagram {
    font-family: var(--font);
    font-size: var(--text-ui);
    color: var(--jr-vit);
    opacity: 0.5;
    text-decoration: none;
    line-height: var(--line-height);
    transition: opacity 0.2s ease;
  }

  .footer-instagram:hover {
    opacity: 1;
  }

  .footer-bottom {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: var(--space-lg);
  }

  .footer-bottom span {
    font-family: var(--font);
    font-size: var(--text-ui);
    opacity: 0.25;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
</style>
