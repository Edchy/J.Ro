---
import Base from "../layouts/Base.astro";
import DevNav from "../components/DevNav.astro";
import LogoMark from "../components/LogoMark.astro";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title="Järna Rosteri">
  <DevNav active="V13" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-img" style={`background-image: url('${base}/assets/images/hero-no-text.png')`}></div>
    <div class="hero-fade"></div>
    <span class="hero-eyebrow">Järna Rosteri</span>
    <span class="hero-year">Est. 2013</span>
    <div class="hero-text">
      <h1>JÄRNA<br />ROSTERI</h1>
      <p>Specialkaffe från källa till kopp</p>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="text-section text-section--green">
    <div class="prose">
      <p class="prose-body">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod
        tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim
        veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea
        commodo consequat.
      </p>
      <span class="prose-sig">— Lorem Ipsum</span>
    </div>
  </section>

  <!-- LANDSCAPE IMAGE -->
  <section class="img-section">
    <div class="img-section-fill img-section-fill--landscape" style={`background-image: url('${base}/assets/images/view.png')`}></div>
  </section>

  <!-- CAPTION STRIP -->
  <div class="caption-strip caption-strip--green">
    <p>
      Ekologiskt odlat &amp; KRAV-certifierat — Våra kaffebönor odlas utan
      kemiska bekämpningsmedel och uppfyller Fairtrade-standarder för rättvis
      handel.
    </p>
  </div>

  <!-- PHILOSOPHY -->
  <section class="text-section text-section--white">
    <div class="prose">
      <p class="prose-body">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod
        tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim
        veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea
        commodo consequat.
      </p>
      <span class="prose-sig">— Lorem Ipsum</span>
    </div>
  </section>

  <!-- PRODUCTS IMAGE -->
  <section class="img-section img-section--products">
    <div class="img-section-fill img-section-fill--bags" style={`background-image: url('${base}/assets/images/coffee-packages.png')`}></div>
  </section>

  <!-- FOOTER -->
  <footer class="site-footer">
    <!-- Watermark logo, absolutely positioned behind content -->
    <div class="footer-logo-bg" aria-hidden="true">
      <LogoMark color="var(--jr-vit)" width="72vw" />
    </div>

    <!-- Left margin: vertical copyright -->
    <span class="footer-margin-copy" aria-hidden="true"
      >© 2026 Järna Rosteri</span
    >

    <!-- Main content -->
    <div class="footer-content">
      <!-- Top rule + year -->
      <div class="footer-header">
        <span class="footer-header-line"></span>
        <span class="footer-header-year">Est. 2013</span>
      </div>

      <!-- Three fields: typeset like a printed document -->
      <div class="footer-fields">
        <div class="footer-field">
          <svg class="footer-field-n" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="292" height="292" viewBox="0 0 292 292" fill="currentColor"><path transform="scale(0.285156 0.285156)" d="M624.271 203.204C627.463 203.055 630.658 202.981 633.853 202.982C694.493 202.628 746.716 225.446 789.751 267.559C826.571 303.667 852.591 350.102 860.498 401.073C875.61 498.501 813.021 585.751 748.253 651.956C677.405 724.377 586.869 785.355 490.797 818.775C465.377 827.617 433.86 835.858 406.799 835.909C405.647 838.136 404.037 837.433 401.625 837.446C337.201 837.442 289.054 819.638 240.747 777.398C199.463 741.723 172.15 692.576 163.656 638.677C154.333 578.452 170.472 529.815 201.131 478.698C216.022 454.093 233.11 430.888 252.188 409.366C331.758 319.638 456.486 232.497 575.934 208.156C594.417 204.39 605.784 204.318 624.271 203.204ZM331.517 721.766C337.325 724.282 343.838 727.677 349.641 729.651C373.35 735.951 386.432 737.486 410.965 733.975C459.015 727.101 502.105 705.263 543.629 681.17C574.242 662.064 606.365 641.03 633.305 616.71C682.747 572.079 738.523 518.529 759.865 453.831C764.427 440.001 764.034 389.393 751.298 381.864C746.954 386.318 740.381 391.381 735.427 395.374L711.768 414.384L639.928 472.395L410.17 657.584L362.055 695.942C356.532 700.341 334.604 716.99 331.517 721.766ZM269.944 656.694C279.333 650.074 288.432 641.817 297.523 634.641L599.075 390.88C629.419 366.297 660.681 341.811 690.735 316.987C672.173 309.27 659.291 303.535 638.475 303.958C635.534 304.017 635.22 302.638 631.25 303.054C631.063 303.125 630.878 303.199 630.69 303.266C623.145 305.971 614.456 304.539 606.621 305.801C602.536 306.46 598.496 307.873 594.466 308.831C581.837 311.833 569.786 314.599 557.574 319.165C465.628 353.545 367.297 426.372 307.644 504.112C295.075 520.492 283.461 537.42 274.408 556.022C261.957 581.608 257.104 607.894 263.664 635.823C265.331 642.92 268.314 649.645 269.944 656.694Z"/></svg>
          <a href="mailto:info@jarnarosteri.se" class="footer-field-val"
            >info@jarnarosteri.se</a
          >
          <a href="tel:+46708401365" class="footer-field-val">070-840 13 65</a>
        </div>
        <div class="footer-field footer-field--right">
          <svg class="footer-field-n" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="292" height="292" viewBox="0 0 292 292" fill="currentColor"><path transform="scale(0.285156 0.285156)" d="M624.271 203.204C627.463 203.055 630.658 202.981 633.853 202.982C694.493 202.628 746.716 225.446 789.751 267.559C826.571 303.667 852.591 350.102 860.498 401.073C875.61 498.501 813.021 585.751 748.253 651.956C677.405 724.377 586.869 785.355 490.797 818.775C465.377 827.617 433.86 835.858 406.799 835.909C405.647 838.136 404.037 837.433 401.625 837.446C337.201 837.442 289.054 819.638 240.747 777.398C199.463 741.723 172.15 692.576 163.656 638.677C154.333 578.452 170.472 529.815 201.131 478.698C216.022 454.093 233.11 430.888 252.188 409.366C331.758 319.638 456.486 232.497 575.934 208.156C594.417 204.39 605.784 204.318 624.271 203.204ZM331.517 721.766C337.325 724.282 343.838 727.677 349.641 729.651C373.35 735.951 386.432 737.486 410.965 733.975C459.015 727.101 502.105 705.263 543.629 681.17C574.242 662.064 606.365 641.03 633.305 616.71C682.747 572.079 738.523 518.529 759.865 453.831C764.427 440.001 764.034 389.393 751.298 381.864C746.954 386.318 740.381 391.381 735.427 395.374L711.768 414.384L639.928 472.395L410.17 657.584L362.055 695.942C356.532 700.341 334.604 716.99 331.517 721.766ZM269.944 656.694C279.333 650.074 288.432 641.817 297.523 634.641L599.075 390.88C629.419 366.297 660.681 341.811 690.735 316.987C672.173 309.27 659.291 303.535 638.475 303.958C635.534 304.017 635.22 302.638 631.25 303.054C631.063 303.125 630.878 303.199 630.69 303.266C623.145 305.971 614.456 304.539 606.621 305.801C602.536 306.46 598.496 307.873 594.466 308.831C581.837 311.833 569.786 314.599 557.574 319.165C465.628 353.545 367.297 426.372 307.644 504.112C295.075 520.492 283.461 537.42 274.408 556.022C261.957 581.608 257.104 607.894 263.664 635.823C265.331 642.92 268.314 649.645 269.944 656.694Z"/></svg>
          <a
            href="https://www.instagram.com/jarnarosteri"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-field-val">INSTAGRAM</a
          >
        </div>
        <div class="footer-field footer-field--address">
          <span class="footer-field-val footer-field-val--muted">Maskinvägen 5, 153 30 Järna</span>
        </div>
      </div>
    </div>
  </footer>
</Base>

<style>
  /* HERO */
  .hero {
    position: relative;
    width: 100%;
    height: 100svh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    background: var(--jr-gron);
  }

  .hero-img {
    display: none;
  }

  .hero-fade {
    display: none;
  }

  .hero-eyebrow,
  .hero-year {
    position: absolute;
    z-index: 2;
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--jr-ljusgul);
  }

  .hero-eyebrow {
    top: var(--space-lg);
    left: var(--space-lg);
  }

  .hero-year {
    top: var(--space-lg);
    right: var(--space-lg);
  }

  .hero-text {
    position: relative;
    z-index: 2;
    padding: var(--space-lg);
    padding-bottom: clamp(var(--space-lg), 4vw, 3rem);
  }

  .hero-text h1 {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 10vw, 9rem);
    color: var(--jr-ljusgul);
    line-height: 0.9;
    letter-spacing: -0.02em;
    margin-bottom: clamp(0.75rem, 1.5vw, 1.25rem);
  }

  .hero-text p {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--jr-ljusgul);
    opacity: 0.7;
    padding-left: 0;
  }

  /* TEXT SECTIONS */
  .text-section {
    width: 100%;
    padding: clamp(5rem, 12vw, 10rem) var(--space-lg);
  }

  .text-section--green {
    background: var(--jr-gron);
  }

  .text-section--white {
    background: var(--jr-vit);
  }

  .prose {
    max-width: 560px;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .prose-body {
    font-family: var(--font);
    font-size: var(--text-body);
    line-height: 1.75;
    color: var(--jr-ljusgul);
  }

  .text-section--white .prose-body {
    color: var(--jr-brun);
  }

  .prose-sig {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--jr-ljusgul);
    opacity: 0.45;
  }

  .text-section--white .prose-sig {
    color: var(--jr-brun);
  }

  /* IMAGE SECTIONS */
  .img-section {
    width: 100%;
    height: 100svh;
    overflow: hidden;
  }

  .img-section--products {
    height: 80svh;
    background: var(--jr-ocra);
  }

  .img-section-fill {
    width: 100%;
    height: 100%;
  }

  .img-section-fill--landscape {
    background-size: cover;
    background-position: center center;
  }

  .img-section-fill--bags {
    background-size: 35%;
    background-position: center center;
    background-repeat: no-repeat;
  }

  /* CAPTION STRIP */
  .caption-strip {
    padding: var(--space-lg);
    padding-top: var(--space-lg);
    padding-bottom: var(--space-xl);
  }

  .caption-strip--green {
    background: var(--jr-gron);
  }

  .caption-strip p {
    font-family: var(--font);
    font-size: var(--text-ui);
    line-height: 1.7;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--jr-ljusgul);
    opacity: 0.5;
    max-width: 600px;
  }

  /* FOOTER */
  .site-footer {
    background: var(--jr-gron);
    color: var(--jr-vit);
    position: relative;
    overflow: hidden;
  }

  /* LogoMark watermark — centered, large, ghosted behind */
  .footer-logo-bg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0.06;
  }

  /* Vertical copyright along left margin */
  .footer-margin-copy {
    position: absolute;
    left: var(--space-lg);
    bottom: var(--space-lg);
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--jr-vit);
    opacity: 0.3;
    writing-mode: vertical-rl;
    transform: rotate(180deg);
  }

  /* Main content — offset right to clear the margin label */
  .footer-content {
    position: relative;
    z-index: 1;
    padding: clamp(4rem, 8vw, 7rem) var(--space-lg) clamp(3rem, 6vw, 5rem);
    padding-left: clamp(3.5rem, 7vw, 6rem);
  }

  /* Header row: full-width rule + year pushed right */
  .footer-header {
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    margin-bottom: clamp(3rem, 7vw, 6rem);
  }

  .footer-header-line {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.2);
    display: block;
  }

  .footer-header-year {
    font-family: var(--font);
    font-size: var(--text-ui);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--jr-vit);
    opacity: 0.4;
    white-space: nowrap;
  }

  /* Two primary fields + address row below */
  .footer-fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    align-items: start;
    gap: var(--space-lg);
  }

  .footer-field--address {
    grid-column: 1 / -1;
    padding-top: var(--space-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-field--mid,
  .footer-field--right {
    padding-top: 0;
  }

  .footer-field-n {
    width: 1.1rem;
    height: 1.1rem;
    margin-bottom: 0.6rem;
    display: block;
    color: var(--jr-ljusgul);
  }

  .footer-field-val {
    font-family: var(--font);
    font-size: var(--text-body);
    letter-spacing: 0.04em;
    color: var(--jr-ljusgul);
    text-decoration: none;
    opacity: 0.7;
    line-height: 1.65;
    display: block;
  }

  a.footer-field-val {
    transition: opacity 0.18s ease;
  }

  a.footer-field-val:hover {
    opacity: 1;
  }

  .footer-field-val--muted {
    opacity: 0.35;
    font-size: var(--text-ui);
  }

  /* RESPONSIVE */
  @media (max-width: 640px) {
    .img-section-fill--bags {
      background-size: 75%;
    }

    .footer-margin-copy {
      display: none;
    }

    .footer-content {
      padding-left: var(--space-lg);
    }

    .footer-fields {
      grid-template-columns: 1fr;
      gap: clamp(1.5rem, 4vw, 2.5rem);
    }

    .footer-field--address {
      grid-column: 1;
    }
  }
</style>
