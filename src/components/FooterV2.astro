---
// V2 — franchese (blue-teal) bg, two columns, bean icon top-right
---

<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <span class="footer-logo">J.Ro</span>
      <div class="footer-right">
        <div class="footer-contact">
          <p>info@jarnarosteri.se</p>
          <p>070-840 13 65</p>
          <p>Maskinvägen 5, 153 30 Järna</p>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Järna Røsteri</span>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--jr-gron);
    color: var(--jr-vit);
    width: 100%;
    padding: var(--space-lg);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 12rem 0 6rem;
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: var(--text-display);
    color: var(--jr-vit);
    line-height: 1;
  }

  .footer-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-lg);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-align: right;
  }

  .footer-contact p {
    font-family: var(--font);
    font-size: var(--text-ui);
    line-height: var(--line-height);
    color: var(--jr-vit);
    text-transform: uppercase;
  }

  .footer-bottom {
    text-align: center;
  }

  .footer-bottom span {
    font-family: var(--font);
    font-size: 8px;
    color: var(--jr-vit);
    opacity: 0.4;
    text-transform: uppercase;
  }

  @media (max-width: 640px) {
    .footer-top {
      flex-direction: column;
      gap: var(--space-lg);
    }

    .footer-right {
      align-items: flex-start;
    }

    .footer-contact {
      text-align: left;
    }
  }
</style>
