---
import LogoMark from "./LogoMark.astro";

interface Props {
  bg?: string;
  textColor?: string;
}

const { bg = "var(--jr-svart)", textColor = "var(--jr-ljusgul)" } = Astro.props;
---

<footer
  style={`background:${bg};color:${textColor};width:100%;display:flex;flex-direction:column;`}
>
  <!-- Main grid: image+wordmark | nav | info -->
  <div style="display:grid;grid-template-columns:2fr 2fr 3fr;min-height:80vh;">
    <!-- LEFT: product image top, logo below -->
    <div
      style="display:flex;flex-direction:column;justify-content:flex-start;overflow:hidden;"
    >
      <div style="padding:clamp(2rem,4vw,4rem) clamp(1.5rem,3vw,3rem);">
        <LogoMark color="var(--jr-ocra)" />
      </div>
      <div
        style="margin:0 clamp(1.5rem,3vw,3rem);flex:1;background-image:url('/assets/images/allbags.png');background-size:contain;background-position:center 30%;background-repeat:no-repeat;min-height:35vh;background-color:transparent;"
      >
      </div>
    </div>

    <!-- MIDDLE: nav links -->
    <div
      style="padding:clamp(2rem,4vw,4rem) clamp(1.5rem,3vw,3rem);display:flex;flex-direction:column;justify-content:flex-start;border-left:1px solid rgba(255,255,255,0.07);"
    >
      <span
        style="font-family:var(--font);font-size:var(--text-ui);letter-spacing:0.15em;text-transform:uppercase;opacity:0.35;margin-bottom:1.5rem;display:block;"
        >(Navigation)</span
      >
      <nav style="display:flex;flex-direction:column;gap:0.1rem;">
        <a href="#" class="footer-nav-link">Kaffe</a>
        <a href="#" class="footer-nav-link">Om oss</a>
        <a href="#" class="footer-nav-link">Ursprung</a>
        <a href="#" class="footer-nav-link">Hållbarhet</a>
      </nav>
    </div>

    <!-- RIGHT: info -->
    <div
      style="padding:clamp(2rem,4vw,4rem) clamp(1.5rem,3vw,3rem);display:flex;flex-direction:column;justify-content:flex-start;border-left:1px solid rgba(255,255,255,0.07);"
    >
      <span
        style="font-family:var(--font);font-size:var(--text-ui);letter-spacing:0.15em;text-transform:uppercase;opacity:0.35;margin-bottom:1.5rem;display:block;"
        >(Acknowledgement)</span
      >
      <p
        style="font-family:var(--font);font-size:var(--text-ui);line-height:1.7;opacity:0.7;max-width:32ch;"
      >
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod
        tempor incididunt ut labore et dolore magna aliqua.
      </p>
      <!-- <img
        src="/assets/images/demeter-logo-svg-vector.svg"
        alt="Demeter"
        style="width:7rem;margin-top:1.5rem;display:block;"
      /> -->

      <div style="margin-top:clamp(2rem,4vw,4rem);">
        <span
          style="font-family:var(--font);font-size:var(--text-ui);letter-spacing:0.15em;text-transform:uppercase;opacity:0.35;margin-bottom:1.5rem;display:block;"
          >(Info)</span
        >
        <div style="display:flex;flex-direction:column;gap:0.3rem;">
          <a href="mailto:info@jarnarosteri.se" class="footer-info-link"
            >e: info@jarnarosteri.se</a
          >
          <a href="tel:+46708401365" class="footer-info-link"
            >t: 070-840 13 65</a
          >
          <span
            style="font-family:var(--font);font-size:var(--text-ui);line-height:1.7;opacity:0.7;"
            >a: Maskinvägen 5, 153 30 Järna</span
          >
          <a
            href="https://www.instagram.com/jarnarosteri"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-info-link footer-social-link">Instagram ↗</a
          >
          <a
            href="https://www.facebook.com/jarnarosteri"
            target="_blank"
            rel="noopener noreferrer"
            class="footer-info-link footer-social-link">Facebook ↗</a
          >
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom strip -->

  <div
    style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:0.5rem;padding:1rem clamp(1.5rem,3vw,3rem);border-top:1px solid rgba(255,255,255,0.07);"
  >
    <span
      style="font-family:var(--font);font-size:var(--text-ui);opacity:0.25;letter-spacing:0.05em;text-transform:uppercase;"
      >© 2026 Järna Rosteri</span
    >
  </div>
</footer>

<style>
  .footer-nav-link {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.5vw, 2.2rem);
    color: inherit;
    text-decoration: none;
    line-height: 1.35;
    opacity: 0.9;
    transition: opacity 0.2s ease;
  }
  .footer-nav-link:hover {
    opacity: 0.5;
  }

  .footer-info-link {
    font-family: var(--font);
    font-size: var(--text-ui);
    color: inherit;
    text-decoration: none;
    line-height: 1.7;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  .footer-social-link {
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .footer-info-link:first-of-type {
    margin-top: 0;
  }
  a.footer-social-link:first-of-type {
    margin-top: 0.5rem;
  }
  .footer-info-link:hover {
    opacity: 1;
  }
</style>
