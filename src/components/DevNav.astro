---
interface Props {
  active: string;
}

const { active } = Astro.props;

const b = import.meta.env.BASE_URL.replace(/\/$/, '');

const links = [
  { href: `${b}/`, label: 'IDX' },
  { href: `${b}/v1`, label: 'V1' },
  { href: `${b}/v2`, label: 'V2' },
  { href: `${b}/v3`, label: 'V3' },
  { href: `${b}/v4`, label: 'V4' },
  { href: `${b}/v5`, label: 'V5' },
  { href: `${b}/v6`, label: 'V6' },
  { href: `${b}/v7`, label: 'V7' },
  { href: `${b}/v8`, label: 'V8' },
  { href: `${b}/v9`, label: 'V9' },
  { href: `${b}/v10`, label: 'V10' },
  { href: `${b}/v11`, label: 'V11' },
  { href: `${b}/v12`, label: 'V12' },
  { href: `${b}/v13`, label: 'V13' },
];
---

<nav class="dev-nav">
  <span class="dev-nav-label">DEV</span>
  {links.map(({ href, label }) => (
    <a href={href} class={active === label ? 'active' : ''}>{label}</a>
  ))}
</nav>

<style>
  .dev-nav {
    position: fixed;
    top: calc(var(--space-sm) + 200px);
    right: var(--space-sm);
    z-index: 100;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--jr-morkrost);
    padding: 0.4rem 0.75rem;
    font-family: var(--font);
    font-size: var(--text-nav);
  }

  .dev-nav-label {
    color: var(--jr-ocra);
    margin-right: 0.25rem;
  }

  .dev-nav a {
    color: var(--jr-vit);
    text-decoration: none;
  }

  .dev-nav a.active {
    color: var(--jr-ljusgul);
  }

  .dev-nav a:hover {
    color: var(--jr-ljusgul);
  }
</style>
