---
import LogoMark from "./LogoMark.astro";

interface Props {
  image?: string;
  eyebrow?: string;
  year?: string;
  caption?: string;
  logoWidth?: string;
}

const {
  image = "/assets/images/hero-no-text.png",
  eyebrow = "Järna Rosteri",
  year = "Est. 2013",
  caption = "Something here?",
  logoWidth = "clamp(14rem, 32vw, 32rem)",
} = Astro.props;
---

<section class="hero">
  <div class="hero-img" style={`background-image: url('${image}');`}></div>
  <div class="hero-overlay"></div>

  <!-- top bar: eyebrow left / year right, separated by a hairline -->
  <header class="hero-header">
    <span class="hero-eyebrow">{eyebrow}</span>
    <span class="hero-rule-h" aria-hidden="true"></span>
    <span class="hero-year">{year}</span>
  </header>

  <!-- vertical rule left edge -->
  <span class="hero-rule-v" aria-hidden="true"></span>

  <!-- center stage: logomark -->
  <div class="hero-center">
    <LogoMark color="var(--jr-vit)" width={logoWidth} />
  </div>

  <!-- bottom bar: caption right -->
  <footer class="hero-footer">
    <span class="hero-caption">{caption}</span>
  </footer>
</section>

<style>
  /* ── SHELL ───────────────────────────────────────────────── */
  .hero {
    width: 100%;
    height: 100svh;
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-rows: auto 1fr auto;
    grid-template-columns: auto 1fr;
    /* col 0: left gutter with vertical rule | col 1: content */
  }

  /* ── PHOTO ───────────────────────────────────────────────── */
  .hero-img {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center 38%;
    /* slight zoom-out feel — photograph sits high, sky at top */
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    /* gradient: nearly clear in middle, darker at top + bottom
       creates depth without muddying the photograph */
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.38) 0%,
      rgba(0, 0, 0, 0) 30%,
      rgba(0, 0, 0, 0) 55%,
      rgba(0, 0, 0, 0.58) 100%
    );
  }

  /* ── VERTICAL RULE ───────────────────────────────────────── */
  .hero-rule-v {
    /* col 0, rows 1-2 (spans center + footer rows) */
    grid-column: 1;
    grid-row: 2 / 4;
    position: relative;
    z-index: 3;
    width: var(--space-lg);
    /* hairline drawn via border */
    border-right: 1px solid rgba(255, 255, 255, 0.22);
  }

  /* ── HEADER ──────────────────────────────────────────────── */
  .hero-header {
    grid-column: 1 / -1;
    grid-row: 1;
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-lg);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
  }

  .hero-eyebrow,
  .hero-year {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--jr-vit);
    white-space: nowrap;
  }

  /* thin horizontal rule between eyebrow and year */
  .hero-rule-h {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.18);
  }

  /* ── CENTER (LOGOMARK) ────────────────────────────────────── */
  .hero-center {
    grid-column: 2;
    grid-row: 2;
    position: relative;
    z-index: 3;
    /* golden ratio vertical placement: top ~38% of the center band */
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding: clamp(var(--space-xl), 6.18vw, 8rem) var(--space-lg);
  }

  /* ── FOOTER ──────────────────────────────────────────────── */
  .hero-footer {
    grid-column: 2;
    grid-row: 3;
    position: relative;
    z-index: 3;
    display: flex;
    justify-content: flex-end;
    align-items: flex-end;
    padding: var(--space-lg);
    padding-bottom: clamp(var(--space-lg), 3.82vw, 3rem);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .hero-caption {
    font-family: var(--font);
    font-size: var(--text-ui);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--jr-vit);
    max-width: 28ch;
    text-align: right;
    line-height: 1.65;
  }

  /* ── MOBILE ──────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .hero-rule-v {
      display: none;
    }

    .hero-center {
      grid-column: 1 / -1;
      justify-content: flex-start;
      padding-left: var(--space-lg);
    }

    .hero-footer {
      grid-column: 1 / -1;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
    }
  }
</style>
