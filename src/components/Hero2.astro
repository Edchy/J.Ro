---
interface Props {
  image?: string;
  bg?: string;
  gradient?: string;
  gradientSize?: string;
  title?: string;
  titleColor?: string;
  titleSize?: string;
  titleLetterSpacing?: string;
  titleAlign?: "left" | "center" | "right";
  titlePosition?: "top" | "center" | "bottom";
  titleOffsetX?: string;
  titleOffsetY?: string;
  subtitle?: string;
  subtitleColor?: string;
  subtitleSize?: string;
  bgPosition?: string;
  overlay?: string;
}

const {
  image,
  bg = "var(--jr-vit)",
  gradient = "none",
  gradientSize = "auto",
  title,
  titleColor = "var(--jr-vit)",
  titleSize = "var(--text-display)",
  titleLetterSpacing = "normal",
  titleAlign = "center",
  titlePosition = "center",
  titleOffsetX = "0px",
  titleOffsetY = "0px",
  subtitle,
  subtitleColor = "var(--jr-vit)",
  subtitleSize = "var(--text-body)",
  bgPosition = "center center",
  overlay = "none",
} = Astro.props;

const alignItems =
  titlePosition === "top"
    ? "flex-start"
    : titlePosition === "bottom"
      ? "flex-end"
      : "center";
const justifyContent =
  titleAlign === "left"
    ? "flex-start"
    : titleAlign === "right"
      ? "flex-end"
      : "center";
---

<section class="hero">
  <div class="bg"></div>
  {
    (title || subtitle) && (
      <div class="hero-content">
        <div class="hero-text">
          {title && <h1>{title}</h1>}
        </div>
        {subtitle && <p class="subtitle">{subtitle}</p>}
      </div>
    )
  }
</section>

<style
  define:vars={{
    image: image ? `url('${image}')` : "none",
    bg,
    titleColor,
    titleSize,
    titleLetterSpacing,
    titleAlign,
    alignItems,
    justifyContent,
    titleOffsetX,
    titleOffsetY,
    subtitleColor,
    subtitleSize,
    bgPosition,
    overlay,
    gradient,
    gradientSize,
  }}
>
  .hero {
    width: 100%;
    height: 100vh;
    position: relative;
    overflow: hidden;
  }

  .bg {
    position: absolute;
    inset: 0;
    background-color: var(--bg);
    background-image: var(--gradient), var(--image);
    background-size: var(--gradientSize), cover;
    background-position: var(--bgPosition);
  }

  .bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--overlay);
  }

  .hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: var(--alignItems);
    justify-content: var(--justifyContent);
    z-index: 1;
    padding: var(--space-lg);
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: var(--justifyContent);
    gap: 0;
    transform: translate(var(--titleOffsetX), var(--titleOffsetY));
  }

  h1 {
    font-family: var(--font-display);
    font-size: var(--titleSize);
    color: var(--titleColor);
    text-align: var(--titleAlign);
    white-space: nowrap;
    line-height: 1;
    letter-spacing: var(--titleLetterSpacing);
  }

  .subtitle {
    font-family: var(--font-mono);
    font-size: var(--subtitleSize);
    color: var(--subtitleColor);
    text-align: center;
    line-height: 1;
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
  }
</style>
