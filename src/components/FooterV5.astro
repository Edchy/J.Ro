---
// V5 — morkrost bg, enormous logo left, contact tucked bottom-right, asymmetric
import LogoMark from "./LogoMark.astro";
---

<footer>
  <div class="footer-inner">
    <LogoMark color="var(--jr-vit)" width="clamp(6rem, 22vw, 18rem)" class="footer-logomark" />
    <div class="footer-meta">
      <div class="footer-contact">
        <a
          href="https://www.instagram.com/jarnarosteri"
          target="_blank"
          rel="noopener noreferrer"
        >
          instagram
        </a>
        <p>info@jarnarosteri.se</p>
        <p>070-840 13 65</p>
        <p>Maskinvägen 5, 153 30 Järna</p>
      </div>
      <!-- <span class="footer-copy">© 2026 Järna Røsteri</span> -->
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--jr-gron);
    color: var(--jr-ljusgul);
    width: 100%;
    padding: var(--space-lg);
  }

  .footer-inner {
    width: min(100%, var(--content-shell-max, 1400px));
    margin: 0 auto;
    padding: 6rem var(--page-inset, 2rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-xl);
  }

  .footer-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-lg);
    padding-bottom: 0.5rem;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-align: left;
  }

  .footer-contact p {
    font-family: var(--font);
    font-size: var(--text-ui);
    line-height: var(--line-height);
    color: var(--jr-vit);
    text-transform: lowercase;
  }

  .footer-contact a {
    font-family: var(--font);
    font-size: var(--text-ui);
    line-height: var(--line-height);
    color: var(--jr-vit);
    text-transform: lowercase;
    text-decoration: none;
  }

  /*.footer-copy {
    font-size: var(--text-ui);
    color: var(--jr-vit);
    opacity: 0.3;
  }*/

  @media (max-width: 640px) {
    .footer-inner {
      gap: var(--space-lg);
    }
  }
</style>
