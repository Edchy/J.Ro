---
// V5 — morkrost bg, enormous logo left, contact tucked bottom-right, asymmetric
---

<footer>
  <div class="footer-inner">
    <span class="footer-logo">J.Ro</span>
    <div class="footer-meta">
      <div class="footer-contact">
        <p>info@jarnarosteri.se</p>
        <p>070-840 13 65</p>
        <p>Maskinvägen 5, 153 30 Järna</p>
      </div>
      <!-- <span class="footer-copy">© 2026 Järna Røsteri</span> -->
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--jr-gron);
    color: var(--jr-ljusgul);
    width: 100%;
    padding: var(--space-lg);
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 12rem 0 6rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: clamp(6rem, 22vw, 18rem);
    color: var(--jr-vit);
    letter-spacing: var(--letter-spacing-tight);
    line-height: 1;
  }

  .footer-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-lg);
    padding-bottom: 0.5rem;
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-align: right;
  }

  .footer-contact p {
    font-family: var(--font);
    font-size: var(--text-ui);
    line-height: var(--line-height);
    color: var(--jr-vit);
    text-transform: uppercase;
  }

  /*.footer-copy {
    font-size: var(--text-ui);
    color: var(--jr-vit);
    opacity: 0.3;
  }*/

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-lg);
    }

    .footer-meta {
      align-items: flex-start;
    }

    .footer-contact {
      text-align: left;
    }
  }
</style>
