---
interface Props {
  bg?: string;
  textColor?: string;
  labelColor?: string;
  label?: string;
  sig?: string;
  body?: string;
}

const {
  bg = "var(--jr-vit)",
  textColor = "var(--jr-svart)",
  labelColor,
  label = "Lorem Ipsum",
  sig = "— Lorem Ipsum",
  body = "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.",
} = Astro.props;

const resolvedLabelColor = labelColor ?? textColor;
---

<section class="lorem-section">
  <div class="lorem-inner">
    <span class="lorem-label">{label}</span>
    <p>{body}</p>
    <span class="lorem-sig">{sig}</span>
  </div>
</section>

<style define:vars={{ bg, textColor, labelColor: resolvedLabelColor }}>
  .lorem-section {
    width: 100%;
    min-height: 100vh;
    background: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lorem-inner {
    max-width: 540px;
    padding: 6rem var(--space-lg);
    text-align: center;
  }

  .lorem-label {
    font-family: var(--font-display);
    font-size: var(--text-body);
    text-transform: uppercase;
    color: var(--labelColor);
    display: block;
    margin-bottom: var(--space-lg);
  }

  p {
    font-size: var(--text-body);
    line-height: var(--line-height);
    color: var(--textColor);
  }

  .lorem-sig {
    display: block;
    margin-top: var(--space-lg);
    font-size: var(--text-body);
    text-transform: uppercase;
    color: var(--labelColor);
  }
</style>
