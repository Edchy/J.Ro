---
interface Props {
  image: string;
  bg?: string;
  bgPosition?: string;
  bgSize?: string;
  caption?: string;
}

const {
  image,
  bg = "transparent",
  bgPosition = "center center",
  bgSize = "cover",
  caption,
} = Astro.props;
---

<section class="image-section">
  <div class="bg"></div>
  {caption && <p class="caption">{caption}</p>}
</section>

<style define:vars={{ image: `url('${image}')`, bg, bgPosition, bgSize }}>
  .image-section {
    width: 100%;
    height: 100vh;
    position: relative;
    overflow: hidden;
    background: var(--bg);
  }

  .bg {
    position: absolute;
    inset: 0;
    background-image: var(--image);
    background-size: var(--bgSize);
    background-position: var(--bgPosition);
    background-repeat: no-repeat;
  }

  .caption {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    margin: 0;
    max-width: 360px;
    font-family: var(--font-mono);
    font-size: var(--text-body);
    line-height: var(--line-height);
    color: var(--jr-vit);
    text-shadow: 0 1px 8px var(--overlay-dark);
    text-align: center;
    z-index: 1;
    /* text-wrap: pretty; */
  }
</style>
