---
// Theme picker — fixed bottom-left, switches data-theme on <html>
---

<div id="theme-picker" class="theme-picker" aria-label="Välj tema">
  {[0, 1, 2, 3, 4, 5].map((i) => (
    <button
      type="button"
      class="theme-swatch"
      data-theme-index={i}
      aria-label={`Tema ${i + 1}`}
    />
  ))}
</div>

<style>
  .theme-picker {
    position: fixed;
    bottom: 1.5rem;
    left: 1.5rem;
    z-index: 200;
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 0.45rem;
    mix-blend-mode: normal;
  }

  .theme-swatch {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 50%;
    border: 1.5px solid transparent;
    cursor: pointer;
    padding: 0;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      opacity 0.18s ease;
    opacity: 0.55;
    outline: none;
  }

  .theme-swatch:focus-visible {
    outline: 1px solid currentColor;
    outline-offset: 2px;
  }

  .theme-swatch:hover {
    opacity: 1;
    transform: scale(1.25);
  }

  .theme-swatch.is-active {
    opacity: 1;
    transform: scale(1.3);
    border-color: currentColor;
  }

  /* Swatch dot colors — represent the hero bg of each theme */
  .theme-swatch[data-theme-index="0"] { background: rgb(63, 69, 44); }
  .theme-swatch[data-theme-index="1"] { background: rgb(255, 255, 255); border-color: rgba(63,69,44,0.3); }
  .theme-swatch[data-theme-index="2"] { background: rgb(58, 40, 23); }
  .theme-swatch[data-theme-index="3"] { background: rgb(43, 75, 88); }
  .theme-swatch[data-theme-index="4"] { background: rgb(188, 149, 72); }
  .theme-swatch[data-theme-index="5"] { background: rgb(131, 150, 120); }
</style>

<script>
  const STORAGE_KEY = "jr-theme";

  const themes: Record<string, Record<string, string>> = {
    "0": {
      // Default — dark forest green
      "--t-hero-bg": "var(--jr-gron)",
      "--t-hero-text": "var(--jr-ljusgul)",
      "--t-hero-text-opacity": "0.6",
      "--t-hero-rule": "color-mix(in srgb, var(--jr-ljusgul) 25%, transparent)",
      "--t-hero-accent": "var(--jr-ocra)",
      "--t-hero-wordmark": "var(--jr-ocra)",
      "--t-hamburger": "var(--jr-ljusgul)",
      "--t-menu-bg": "var(--jr-gron)",
      "--t-menu-text": "var(--jr-ljusgul)",
      "--t-menu-footer": "var(--jr-vit)",
      "--t-products-bg": "var(--jr-gron)",
      "--t-products-strip-shadow": "var(--jr-gron)",
      "--t-about-bg": "var(--jr-vit)",
      "--t-about-text": "var(--jr-morkrost)",
      "--t-about-kicker": "var(--jr-ocra)",
      "--t-contact-bg": "var(--jr-gron)",
      "--t-contact-text": "var(--jr-ljusgul)",
      "--t-contact-address": "var(--jr-ocra)",
      "--t-footer-bg": "var(--jr-vit)",
      "--t-footer-text": "var(--jr-gron)",
      "--t-scrollbar-thumb": "var(--jr-gron)",
      "--t-scrollbar-track": "var(--jr-vit)",
    },
    "1": {
      // Light — white everywhere, green text
      "--t-hero-bg": "var(--jr-vit)",
      "--t-hero-text": "var(--jr-gron)",
      "--t-hero-text-opacity": "0.75",
      "--t-hero-rule": "color-mix(in srgb, var(--jr-gron) 20%, transparent)",
      "--t-hero-accent": "var(--jr-ocra)",
      "--t-hero-wordmark": "var(--jr-gron)",
      "--t-hero-bar-wordmark": "var(--jr-ocra)",
      "--t-hamburger": "var(--jr-gron)",
      "--t-menu-bg": "var(--jr-vit)",
      "--t-menu-text": "var(--jr-gron)",
      "--t-menu-footer": "var(--jr-gron)",
      "--t-products-bg": "var(--jr-vit)",
      "--t-products-strip-shadow": "var(--jr-vit)",
      "--t-about-bg": "var(--jr-vit)",
      "--t-about-text": "var(--jr-gron)",
      "--t-about-kicker": "var(--jr-ocra)",
      "--t-contact-bg": "var(--jr-vit)",
      "--t-contact-text": "var(--jr-gron)",
      "--t-contact-kicker": "var(--jr-ocra)",
      "--t-contact-address": "var(--jr-ocra)",
      "--t-footer-bg": "var(--jr-vit)",
      "--t-footer-text": "var(--jr-gron)",
      "--t-scrollbar-thumb": "var(--jr-gron)",
      "--t-scrollbar-track": "var(--jr-vit)",
    },
    "2": {
      // Dark roast — deep brown / morkrost ground
      "--t-hero-bg": "var(--jr-morkrost)",
      "--t-hero-text": "var(--jr-ocra)",
      "--t-hero-text-opacity": "0.65",
      "--t-hero-rule": "color-mix(in srgb, var(--jr-ocra) 22%, transparent)",
      "--t-hero-accent": "var(--jr-ljusgul)",
      "--t-hero-wordmark": "var(--jr-ocra)",
      "--t-hamburger": "var(--jr-ocra)",
      "--t-menu-bg": "var(--jr-morkrost)",
      "--t-menu-text": "var(--jr-ljusgul)",
      "--t-menu-footer": "var(--jr-ocra)",
      "--t-products-bg": "var(--jr-morkrost)",
      "--t-products-strip-shadow": "var(--jr-morkrost)",
      "--t-about-bg": "var(--jr-brun)",
      "--t-about-text": "var(--jr-ljusgul)",
      "--t-about-kicker": "var(--jr-vit)",
      "--t-contact-bg": "var(--jr-brun)",
      "--t-contact-text": "var(--jr-ljusgul)",
      "--t-contact-kicker": "var(--jr-vit)",
      "--t-contact-address": "var(--jr-ljusgul)",
      "--t-footer-bg": "var(--jr-brun)",
      "--t-footer-text": "var(--jr-vit)",
      "--t-scrollbar-thumb": "var(--jr-brun)",
      "--t-scrollbar-track": "var(--jr-morkrost)",
    },
    "3": {
      // Ocean — franchese teal throughout
      "--t-hero-bg": "var(--jr-franchese)",
      "--t-hero-text": "var(--jr-vit)",
      "--t-hero-text-opacity": "0.6",
      "--t-hero-rule": "color-mix(in srgb, var(--jr-vit) 18%, transparent)",
      "--t-hero-accent": "var(--jr-ljusgul)",
      "--t-hero-wordmark": "var(--jr-ljusgul)",
      "--t-hamburger": "var(--jr-vit)",
      "--t-menu-bg": "var(--jr-franchese)",
      "--t-menu-text": "var(--jr-vit)",
      "--t-menu-footer": "var(--jr-ljusgul)",
      "--t-products-bg": "var(--jr-franchese)",
      "--t-products-strip-shadow": "var(--jr-franchese)",
      "--t-about-bg": "var(--jr-vit)",
      "--t-about-text": "var(--jr-franchese)",
      "--t-about-kicker": "var(--jr-franchese)",
      "--t-contact-bg": "var(--jr-franchese)",
      "--t-contact-text": "var(--jr-vit)",
      "--t-contact-address": "var(--jr-ljusgul)",
      "--t-footer-bg": "var(--jr-franchese)",
      "--t-footer-text": "var(--jr-vit)",
      "--t-scrollbar-thumb": "var(--jr-franchese)",
      "--t-scrollbar-track": "var(--jr-vit)",
    },
    "4": {
      // Harvest — warm ocra hero, morkrost about, brun contact
      "--t-hero-bg": "var(--jr-ocra)",
      "--t-hero-text": "var(--jr-morkrost)",
      "--t-hero-text-opacity": "0.75",
      "--t-hero-rule": "color-mix(in srgb, var(--jr-morkrost) 20%, transparent)",
      "--t-hero-accent": "var(--jr-morkrost)",
      "--t-hero-wordmark": "var(--jr-morkrost)",
      "--t-hamburger": "var(--jr-morkrost)",
      "--t-menu-bg": "var(--jr-ocra)",
      "--t-menu-text": "var(--jr-morkrost)",
      "--t-menu-footer": "var(--jr-morkrost)",
      "--t-products-bg": "var(--jr-ocra)",
      "--t-products-strip-shadow": "var(--jr-ocra)",
      "--t-about-bg": "var(--jr-vit)",
      "--t-about-text": "var(--jr-morkrost)",
      "--t-about-kicker": "var(--jr-ocra)",
      "--t-contact-bg": "var(--jr-brun)",
      "--t-contact-text": "var(--jr-ljusgul)",
      "--t-contact-address": "var(--jr-ocra)",
      "--t-footer-bg": "var(--jr-vit)",
      "--t-footer-text": "var(--jr-morkrost)",
      "--t-scrollbar-thumb": "var(--jr-ocra)",
      "--t-scrollbar-track": "var(--jr-morkrost)",
    },
    "5": {
      // Brun/orostat — medium brown hero, soft sage about
      "--t-hero-bg": "var(--jr-orostat)",
      "--t-hero-text": "var(--jr-morkrost)",
      "--t-hero-text-opacity": "0.75",
      "--t-hero-rule": "color-mix(in srgb, var(--jr-morkrost) 20%, transparent)",
      "--t-hero-accent": "var(--jr-vit)",
      "--t-hero-wordmark": "var(--jr-morkrost)",
      "--t-hero-bar-wordmark": "var(--jr-vit)",
      "--t-hamburger": "var(--jr-morkrost)",
      "--t-menu-bg": "var(--jr-orostat)",
      "--t-menu-text": "var(--jr-morkrost)",
      "--t-menu-footer": "var(--jr-morkrost)",
      "--t-products-bg": "var(--jr-orostat)",
      "--t-products-strip-shadow": "var(--jr-orostat)",
      "--t-about-bg": "var(--jr-vit)",
      "--t-about-text": "var(--jr-morkrost)",
      "--t-about-kicker": "var(--jr-orostat)",
      "--t-contact-bg": "var(--jr-orostat)",
      "--t-contact-text": "var(--jr-morkrost)",
      "--t-contact-kicker": "var(--jr-vit)",
      "--t-contact-address": "var(--jr-morkrost)",
      "--t-footer-bg": "var(--jr-orostat)",
      "--t-footer-text": "var(--jr-vit)",
      "--t-scrollbar-thumb": "var(--jr-morkrost)",
      "--t-scrollbar-track": "var(--jr-orostat)",
    },
  };

  function applyTheme(index: number) {
    const vars = themes[String(index)];
    const root = document.documentElement;
    if (!vars) return;
    Object.entries(vars).forEach(([k, v]) => root.style.setProperty(k, v));
    root.dataset.theme = String(index);
    localStorage.setItem(STORAGE_KEY, String(index));
    document.querySelectorAll<HTMLElement>(".theme-swatch").forEach((btn) => {
      btn.classList.toggle(
        "is-active",
        Number(btn.dataset.themeIndex) === index,
      );
    });
  }

  const saved = Number(localStorage.getItem(STORAGE_KEY) ?? "0");
  applyTheme(saved);

  document.querySelectorAll<HTMLElement>(".theme-swatch").forEach((btn) => {
    btn.addEventListener("click", () => {
      applyTheme(Number(btn.dataset.themeIndex));
    });
  });
</script>
