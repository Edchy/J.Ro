---
// V1 — dark roast bg, centered stacked layout, gold accents
---

<footer>
  <div class="footer-inner">
    <span class="footer-logo">J.Ro</span>
    <div class="divider"></div>
    <div class="footer-contact">
      <p>info@jarnarosteri.se</p>
      <p>070-840 13 65</p>
      <p>Maskinvägen 5, 153 30 Järna</p>
    </div>
    <span class="footer-copy">© 2026 Järna Røsteri</span>
  </div>
</footer>

<style>
  footer {
    background: var(--jr-morkrost);
    color: var(--jr-vit);
    width: 100%;
    padding: var(--space-lg);
  }

  .footer-inner {
    max-width: 600px;
    margin: 0 auto;
    padding: 8rem 0 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
    text-align: center;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: var(--text-display);
    color: var(--jr-ljusgul);
    letter-spacing: var(--letter-spacing-tight);
    line-height: 1;
  }

  .divider {
    width: 3rem;
    height: 1px;
    background: var(--jr-ocra);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-contact p {
    font-family: var(--font);
    font-size: var(--text-ui);
    line-height: var(--line-height);
    color: var(--jr-vit);
    text-transform: uppercase;
  }

  .footer-copy {
    font-family: var(--font);
    font-size: 8px;
    color: var(--jr-vit);
    opacity: 0.35;
    margin-top: var(--space-lg);
    text-transform: uppercase;
  }
</style>
