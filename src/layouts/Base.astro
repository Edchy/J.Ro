---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Järna Røsteri" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const fonts = `
  @font-face {
    font-family: "Orator Std";
    src: url("${base}/assets/fonts/orator-std-medium.woff") format("woff");
    font-weight: 400;
    font-style: normal;
  }
  @font-face {
    font-family: "Maax Mono";
    src: url("${base}/assets/fonts/MaaxMonoTrial-Regular.otf") format("opentype");
    font-weight: 400;
    font-style: normal;
  }
  @font-face {
    font-family: "Maax Mono";
    src: url("${base}/assets/fonts/MaaxMonoTrial-Italic.otf") format("opentype");
    font-weight: 400;
    font-style: italic;
  }
  @font-face {
    font-family: "Maax Mono";
    src: url("${base}/assets/fonts/MaaxMonoTrial-Bold.otf") format("opentype");
    font-weight: 700;
    font-style: normal;
  }
  @font-face {
    font-family: "Maax Mono";
    src: url("${base}/assets/fonts/MaaxMonoTrial-BoldItalic.otf") format("opentype");
    font-weight: 700;
    font-style: italic;
  }
`;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon3.svg`} />
    <style set:html={fonts}></style>
  </head>
  <body>
    <slot />
  </body>
</html>
